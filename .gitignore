override.tf.json
*_override.tf
*_override.tf.json

# Local Alfred scratch worktrees
.worktrees/

# Per-operator launchd artifacts. alfred-init writes agents.conf for the
# host's chosen fleet; deploy.sh renders host-specific plists (with absolute
# paths to $ALFRED_HOME) into launchd/_generated. Both are operator data, not
# source: shipping them would leak private paths and overwrite every other
# operator's fleet config on pull.
launchd/agents.conf
launchd/_generated/

# Operator-specific scrub patterns (exact private values like AWS account IDs).
# These are loaded by bin/scrub-check.sh at runtime so this PUBLIC script never
# embeds the very identifiers it scans for. bin/.scrub-extra-patterns is now a
# tracked DEFAULT carrying only GENERIC patterns and ships with the repo; keep
# any operator-specific OVERRIDE (real account IDs, private hostnames) in a
# gitignored .local file and point ALFRED_SCRUB_EXTRA_PATTERNS at it.
# Copy bin/.scrub-extra-patterns.example to start.
bin/.scrub-extra-patterns.local

