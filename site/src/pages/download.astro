---
/**
 * Download page for alfred.luminik.io.
 *
 * Links and tracking only. Deliberately shows no download count or numbers:
 * low or zero counts at launch read as weak proof, so we never render them.
 *
 * Release links point at stable assets on the latest GitHub Release.
 * Each package button carries data-download-os and data-download-source so the
 * inline tracker below can send one GA4 "download" event per real asset click,
 * gated on the same cookie-consent decision the rest of the site uses.
 */

import MarketingLayout from "../layouts/MarketingLayout.astro";
import Hero from "../components/marketing/Hero.astro";
import SectionHeader from "../components/marketing/SectionHeader.astro";
import CodeBlock from "../components/marketing/CodeBlock.astro";
import DownloadTracker from "../components/marketing/DownloadTracker.astro";

const REPO = "https://github.com/luminik-io/alfred-os";
const RELEASE = `${REPO}/releases/latest`;
const RELEASE_DOWNLOADS = `${REPO}/releases/latest/download`;
const MAC_DMG = `${RELEASE_DOWNLOADS}/Alfred.dmg`;
const MAC_APP_ZIP = `${RELEASE_DOWNLOADS}/Alfred.app.zip`;
const LINUX_APPIMAGE = `${RELEASE_DOWNLOADS}/Alfred.AppImage`;
const LINUX_DEB = `${RELEASE_DOWNLOADS}/Alfred.deb`;
---

<MarketingLayout
  title="Download Alfred Desktop | macOS, Linux, or install Alfred core"
  description="Download Alfred Desktop for macOS or Linux, or install the Alfred core runtime from source. Alfred Desktop is an optional local companion for the CLI runtime."
  path="/download/"
>
  <Hero
    eyebrow="DOWNLOAD"
    headline="Download Alfred Desktop."
    sub="Alfred Desktop is the optional Mac/Linux app for a local Alfred runtime. It connects to `alfred serve`; it does not run agents by itself. Install Alfred core from source or Homebrew when you want the scheduled coding agents."
    headlineSize="lg"
    primaryCta={{
      label: "Download Desktop for macOS",
      href: MAC_DMG,
      data: {
        "data-download-os": "macos",
        "data-download-source": "download-page-hero",
        "data-download-kind": "asset",
      },
    }}
    secondaryCta={{ label: "Linux packages", href: "#linux" }}
    tertiaryCta={{ label: "GitHub", href: REPO }}
  />

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="PICK YOUR BUILD"
        title="Desktop app builds, plus the core runtime."
        lede="Alfred Desktop gives you a local control surface for plans, agents, setup checks, and logs. The core runtime runs coding agents through the CLI and scheduler."
      />

      <div class="dl-grid">
        <article class="m-card dl-card">
          <div class="dl-card__head">
            <span class="m-eyebrow">MACOS</span>
            <span class="m-mono m-mute">macOS 10.15+</span>
          </div>
          <h3 class="m-h3">Alfred Desktop for macOS</h3>
          <p class="dl-card__body">
            Open the disk image, drag Alfred to Applications, and launch it
            beside your local <span class="m-mono">alfred serve</span>. Install
            Alfred core first if you want real agents, schedules, and local state.
            The app bundle inside the DMG is signed, notarized, and stapled.
          </p>
          <div class="dl-card__actions">
            <a
              class="m-btn dl-card__btn"
              href={MAC_DMG}
              rel="noopener"
              data-download-os="macos"
              data-download-source="download-page"
              data-download-kind="asset"
            >Download DMG</a>
            <a
              class="m-link"
              href={MAC_APP_ZIP}
              rel="noopener"
              data-download-os="macos"
              data-download-source="download-page-app-zip"
              data-download-kind="asset"
            >App zip</a>
          </div>
          <p class="dl-card__note m-mute">
            The DMG is the normal install path. The app zip is available for
            automation and verification.
          </p>
        </article>

        <article id="linux" class="m-card dl-card">
          <div class="dl-card__head">
            <span class="m-eyebrow">LINUX</span>
            <span class="m-mono m-mute">Debian / Ubuntu</span>
          </div>
          <h3 class="m-h3">Alfred Desktop for Linux</h3>
          <p class="dl-card__body">
            Use the AppImage when you want a portable binary, or the
            <span class="m-mono">.deb</span> package on apt-based systems. Both
            connect to the local Alfred core runtime over localhost.
          </p>
          <div class="dl-card__actions">
            <a
              class="m-btn dl-card__btn"
              href={LINUX_APPIMAGE}
              rel="noopener"
              data-download-os="linux"
              data-download-source="download-page-appimage"
              data-download-kind="asset"
            >Download AppImage</a>
            <a
              class="m-link"
              href={LINUX_DEB}
              rel="noopener"
              data-download-os="linux"
              data-download-source="download-page-deb"
              data-download-kind="asset"
            >Download .deb</a>
          </div>
          <p class="dl-card__note m-mute">
            Run <span class="m-mono">chmod +x Alfred.AppImage</span> once before
            launching the AppImage. Linux packages are unsigned; review the
            release asset digests on GitHub if your environment requires it.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section id="from-source" class="m-section m-section--soft">
    <div class="m-container">
      <SectionHeader
        eyebrow="FROM SOURCE"
        title="Install Alfred core from the code."
        lede="This is the runtime path: the operator CLI, local state, scheduler files, labels, and agents. Clone the repo and run the installer, or use the Homebrew tap on macOS."
      />

      <div class="dl-source">
        <div class="dl-source__col">
          <h3 class="m-h3">Install Alfred core from source</h3>
          <p class="dl-source__lede">
            Clone the repo, step in, and run the installer. Works on macOS and
            Debian or Ubuntu Linux. Safe to re-run.
          </p>
          <CodeBlock
            title="install from source"
            lines={[
              "$ git clone https://github.com/luminik-io/alfred-os.git ~/code/alfred-os",
              "$ cd ~/code/alfred-os",
              "$ bash install.sh",
            ]}
          />
          <p class="dl-source__after">
            Use this path when you want the latest <span class="m-mono">main</span>,
            core runtime, framework edits, or Linux.
          </p>
        </div>

        <div class="dl-source__col">
          <h3 class="m-h3">Install Alfred core with Homebrew</h3>
          <p class="dl-source__lede">
            For macOS, if you prefer a package-manager install of the latest
            tagged release.
          </p>
          <CodeBlock
            title="install with homebrew"
            lines={[
              "$ brew tap luminik-io/alfred-os https://github.com/luminik-io/alfred-os",
              "$ brew install alfred-os",
              "$ alfred-install",
            ]}
          />
          <p class="dl-source__after">
            Puts <span class="m-mono">alfred</span>,
            <span class="m-mono">alfred-init</span>, and the rest of the operator
            commands on your PATH.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="WHAT YOU GET"
        title="Core runtime first. Desktop when you want the app."
        lede="Alfred core picks up the Slack drafts, plans, and GitHub issues you mark for it, writes code in isolated repo copies, opens pull requests, routes review, and posts a short summary to Slack. Alfred Desktop reads and controls that local runtime."
      />
      <div class="dl-reqs">
        <article class="m-card">
          <h3 class="m-h3">Alfred core runtime</h3>
          <ul class="dl-reqs__list">
            <li>Four agents to start: Drake, Lucius, Ra's al Ghul, and a cleanup agent</li>
            <li>Scheduled runs for each agent while your chosen host is awake</li>
            <li>Planning and approval in Slack, plus optional inspection in Alfred Desktop</li>
            <li>Open source, MIT licensed, yours to read and fork</li>
          </ul>
        </article>
        <article class="m-card">
          <h3 class="m-h3">Alfred Desktop</h3>
          <ul class="dl-reqs__list">
            <li>Shows plans, agents, logs, setup checks, memory review, and safe actions</li>
            <li>Starts or reconnects to <span class="m-mono">alfred serve</span> on localhost</li>
            <li>Opens Slack and GitHub links outside the app</li>
            <li>Does not replace the CLI, scheduler, GitHub labels, or Slack approval gates</li>
          </ul>
        </article>
      </div>
      <p class="dl-docs">
        New to all this? Read the
        <a class="m-link" href="/getting-started/install/">install guide</a>
        or pick a
        <a class="m-link" href="/install/">starting point</a>.
      </p>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container" style="text-align:center;">
      <a
        class="m-btn"
        href={RELEASE}
        rel="noopener"
        style="font-size:16px;padding:16px 28px;"
      >See all release files</a>
    </div>
  </section>

  <DownloadTracker />
</MarketingLayout>

<style>
  .dl-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }
  @media (max-width: 720px) { .dl-grid { grid-template-columns: 1fr; } }

  .dl-card { display: flex; flex-direction: column; gap: 14px; }
  .dl-card__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .dl-card__body {
    color: var(--alfred-text);
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
  }
  .dl-card__actions {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .dl-card__btn { align-self: start; }
  .dl-card__note {
    font-size: 13px;
    line-height: 1.55;
    margin: 0;
  }

  .dl-source {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
    align-items: start;
  }
  @media (max-width: 880px) { .dl-source { grid-template-columns: 1fr; } }
  .dl-source__col { display: grid; gap: 12px; min-width: 0; }
  .dl-source__lede,
  .dl-source__after {
    color: var(--alfred-text);
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
  }
  .dl-source__after { color: var(--alfred-mute); }

  .dl-reqs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }
  @media (max-width: 720px) { .dl-reqs { grid-template-columns: 1fr; } }
  .dl-reqs__list {
    list-style: none;
    padding: 0;
    margin: 14px 0 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    color: var(--alfred-text);
    font-size: 15px;
    line-height: 1.55;
  }
  .dl-reqs__list li { padding-left: 20px; position: relative; }
  .dl-reqs__list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--alfred-accent);
  }
  .dl-docs { margin-top: 28px; color: var(--alfred-text); font-size: 15px; }
</style>
