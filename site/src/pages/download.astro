---
/**
 * Download page for alfred.luminik.io.
 *
 * Links and tracking only. Deliberately shows no download count or numbers:
 * low or zero counts at launch read as weak proof, so we never render them.
 *
 * Release links point at stable assets on the latest GitHub Release.
 * Each package button carries data-download-os and data-download-source so the
 * inline tracker below can send one GA4 "download" event per real asset click,
 * gated on the same cookie-consent decision the rest of the site uses.
 */

import MarketingLayout from "../layouts/MarketingLayout.astro";
import Hero from "../components/marketing/Hero.astro";
import SectionHeader from "../components/marketing/SectionHeader.astro";
import CodeBlock from "../components/marketing/CodeBlock.astro";
import DownloadTracker from "../components/marketing/DownloadTracker.astro";

const REPO = "https://github.com/luminik-io/alfred-os";
const RELEASE = `${REPO}/releases/latest`;
const RELEASE_DOWNLOADS = `${REPO}/releases/latest/download`;
const MAC_DMG = `${RELEASE_DOWNLOADS}/Alfred.dmg`;
const MAC_APP_ZIP = `${RELEASE_DOWNLOADS}/Alfred.app.zip`;
const LINUX_APPIMAGE = `${RELEASE_DOWNLOADS}/Alfred.AppImage`;
const LINUX_DEB = `${RELEASE_DOWNLOADS}/Alfred.deb`;
---

<MarketingLayout
  title="Download Alfred | macOS, Linux, or from source"
  description="Get Alfred for macOS or Linux, or install it from source in a few commands. Open source, MIT. Pick the build for your machine and start a team of coding agents on hardware you already own."
  path="/download/"
>
  <Hero
    eyebrow="DOWNLOAD"
    headline="Download Alfred for your machine."
    sub="Alfred runs on a Mac or Linux box you already own. Grab the signed macOS app, the Linux package for your system, or install from source if you would rather work from the code."
    headlineSize="lg"
    primaryCta={{
      label: "Download for macOS",
      href: MAC_DMG,
      data: {
        "data-download-os": "macos",
        "data-download-source": "download-page-hero",
        "data-download-kind": "asset",
      },
    }}
    secondaryCta={{ label: "Linux packages", href: "#linux" }}
    tertiaryCta={{ label: "GitHub", href: REPO }}
  />

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="PICK YOUR BUILD"
        title="Two ready-made builds, or install from source."
        lede="The macOS disk image is signed and notarized. Linux ships as an AppImage or a Debian package. If you want to inspect or edit the code first, install from source below."
      />

      <div class="dl-grid">
        <article class="m-card dl-card">
          <div class="dl-card__head">
            <span class="m-eyebrow">MACOS</span>
            <span class="m-mono m-mute">macOS 13+</span>
          </div>
          <h3 class="m-h3">The signed macOS app</h3>
          <p class="dl-card__body">
            Open the disk image, drag Alfred to Applications, and launch it
            beside your local <span class="m-mono">alfred serve</span>. The app
            bundle inside the DMG is signed, notarized, and stapled.
          </p>
          <div class="dl-card__actions">
            <a
              class="m-btn dl-card__btn"
              href={MAC_DMG}
              rel="noopener"
              data-download-os="macos"
              data-download-source="download-page"
              data-download-kind="asset"
            >Download DMG</a>
            <a
              class="m-link"
              href={MAC_APP_ZIP}
              rel="noopener"
              data-download-os="macos"
              data-download-source="download-page-app-zip"
              data-download-kind="asset"
            >App zip</a>
          </div>
          <p class="dl-card__note m-mute">
            The DMG is the normal install path. The app zip is available for
            automation and verification.
          </p>
        </article>

        <article id="linux" class="m-card dl-card">
          <div class="dl-card__head">
            <span class="m-eyebrow">LINUX</span>
            <span class="m-mono m-mute">Debian / Ubuntu</span>
          </div>
          <h3 class="m-h3">The Linux build</h3>
          <p class="dl-card__body">
            Use the AppImage when you want a portable binary, or the
            <span class="m-mono">.deb</span> package on apt-based systems.
          </p>
          <div class="dl-card__actions">
            <a
              class="m-btn dl-card__btn"
              href={LINUX_APPIMAGE}
              rel="noopener"
              data-download-os="linux"
              data-download-source="download-page-appimage"
              data-download-kind="asset"
            >Download AppImage</a>
            <a
              class="m-link"
              href={LINUX_DEB}
              rel="noopener"
              data-download-os="linux"
              data-download-source="download-page-deb"
              data-download-kind="asset"
            >Download .deb</a>
          </div>
          <p class="dl-card__note m-mute">
            Linux packages are unsigned. Verify checksums on the GitHub release
            if your environment requires it.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section id="from-source" class="m-section m-section--soft">
    <div class="m-container">
      <SectionHeader
        eyebrow="FROM SOURCE"
        title="Rather work from the code? A few commands get you running."
        lede="Built for the developer crowd. Clone the repo and run the installer, or use the Homebrew tap on macOS. Both put the operator commands on your PATH."
      />

      <div class="dl-source">
        <div class="dl-source__col">
          <h3 class="m-h3">Install from source (three commands)</h3>
          <p class="dl-source__lede">
            Clone the repo, step in, and run the installer. Works on macOS and
            Debian or Ubuntu Linux. Safe to re-run.
          </p>
          <CodeBlock
            title="install from source"
            lines={[
              "$ git clone https://github.com/luminik-io/alfred-os.git ~/code/alfred-os",
              "$ cd ~/code/alfred-os",
              "$ bash install.sh",
            ]}
          />
          <p class="dl-source__after">
            Use this path when you want the latest <span class="m-mono">main</span>,
            framework edits, or Linux.
          </p>
        </div>

        <div class="dl-source__col">
          <h3 class="m-h3">The Homebrew tap</h3>
          <p class="dl-source__lede">
            For macOS, if you prefer a package-manager install of the latest
            tagged release.
          </p>
          <CodeBlock
            title="install with homebrew"
            lines={[
              "$ brew tap luminik-io/alfred-os https://github.com/luminik-io/alfred-os",
              "$ brew install alfred-os",
              "$ alfred-install",
            ]}
          />
          <p class="dl-source__after">
            Puts <span class="m-mono">alfred</span>,
            <span class="m-mono">alfred-init</span>, and the rest of the operator
            commands on your PATH.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="WHAT YOU GET"
        title="A team of coding agents on your own machine."
        lede="Alfred installs a local runtime that picks up tasks, writes code, opens pull requests, and posts a short summary to Slack. You review and merge. Nothing runs in the cloud and there is no vendor account."
      />
      <div class="dl-reqs">
        <article class="m-card">
          <h3 class="m-h3">What you get</h3>
          <ul class="dl-reqs__list">
            <li>Four agents to start: Drake, Lucius, Ra's al Ghul, and a cleanup agent</li>
            <li>A run every 20 minutes, around the clock</li>
            <li>Planning and approval in Slack, or the desktop app</li>
            <li>Open source, MIT licensed, yours to read and fork</li>
          </ul>
        </article>
        <article class="m-card">
          <h3 class="m-h3">What you need</h3>
          <ul class="dl-reqs__list">
            <li>macOS 13 or newer, or Debian / Ubuntu Linux</li>
            <li>A Claude Code subscription you already pay for</li>
            <li>A GitHub account for the repos you want worked on</li>
            <li>A machine that stays awake during the hours you set</li>
          </ul>
        </article>
      </div>
      <p class="dl-docs">
        New to all this? Read the
        <a class="m-link" href="/getting-started/install/">install guide</a>
        or pick a
        <a class="m-link" href="/install/">starting point</a>.
      </p>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container" style="text-align:center;">
      <a
        class="m-btn"
        href={RELEASE}
        rel="noopener"
        style="font-size:16px;padding:16px 28px;"
      >See all release files</a>
    </div>
  </section>

  <DownloadTracker />
</MarketingLayout>

<style>
  .dl-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }
  @media (max-width: 720px) { .dl-grid { grid-template-columns: 1fr; } }

  .dl-card { display: flex; flex-direction: column; gap: 14px; }
  .dl-card__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .dl-card__body {
    color: var(--alfred-text);
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
  }
  .dl-card__actions {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .dl-card__btn { align-self: start; }
  .dl-card__note {
    font-size: 13px;
    line-height: 1.55;
    margin: 0;
  }

  .dl-source {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
    align-items: start;
  }
  @media (max-width: 880px) { .dl-source { grid-template-columns: 1fr; } }
  .dl-source__col { display: grid; gap: 12px; min-width: 0; }
  .dl-source__lede,
  .dl-source__after {
    color: var(--alfred-text);
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
  }
  .dl-source__after { color: var(--alfred-mute); }

  .dl-reqs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }
  @media (max-width: 720px) { .dl-reqs { grid-template-columns: 1fr; } }
  .dl-reqs__list {
    list-style: none;
    padding: 0;
    margin: 14px 0 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    color: var(--alfred-text);
    font-size: 15px;
    line-height: 1.55;
  }
  .dl-reqs__list li { padding-left: 20px; position: relative; }
  .dl-reqs__list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--alfred-accent);
  }
  .dl-docs { margin-top: 28px; color: var(--alfred-text); font-size: 15px; }
</style>
