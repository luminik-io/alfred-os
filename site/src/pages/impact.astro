---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import Hero from "../components/marketing/Hero.astro";
import SectionHeader from "../components/marketing/SectionHeader.astro";
import ImpactCounter from "../components/marketing/ImpactCounter.astro";
import ImpactProofBoard from "../components/marketing/ImpactProofBoard.astro";
import CodeBlock from "../components/marketing/CodeBlock.astro";
import proof from "../data/impact-proof.json";
import dogfood from "../data/luminik-dogfood-proof.json";

const fmt = (n: number) => n.toLocaleString("en-US");
const dogfoodGenerated = dogfood.generated_at.slice(0, 10);
---

<MarketingLayout
  title="Impact | Alfred"
  description="Public Alfred proof from inspectable GitHub signals: merged pull requests, issue labels, changed files, and the anonymous opt-in community counter."
  path="/impact/"
>
  <Hero
    eyebrow="PUBLIC GITHUB PROOF"
    headline="Proof you can inspect."
    sub="This page counts public Alfred OS work only when GitHub shows runtime evidence: an Alfred branch prefix or a shipped label. If the current window has no matches, the page says so and keeps wider repo activity separate."
    headlineSize="lg"
    primaryCta={{ label: "View GitHub", href: "https://github.com/luminik-io/alfred-os" }}
    secondaryCta={{ label: "Read telemetry docs", href: "/reference/telemetry/" }}
  >
    <div slot="panel" class="impact-panel">
      <div class="impact-panel__head">
        <span class="m-eyebrow">ROLLING WINDOW</span>
        <span class="m-mono m-mute">{proof.window.days} days</span>
      </div>
      <div class="hero-proof">
        <span>{proof.summary.prs_merged.toLocaleString("en-US")}</span>
        <p>merged runtime PRs</p>
      </div>
      <div class="hero-proof__grid">
        <div>
          <span>{proof.summary.issues_opened.toLocaleString("en-US")}</span>
          <p>agent-labeled issues</p>
        </div>
        <div>
          <span>{proof.summary.lines_added.toLocaleString("en-US")}</span>
          <p>lines added</p>
        </div>
      </div>
    </div>
  </Hero>

  <section class="m-section m-section--soft">
    <div class="m-container dogfood-proof">
      <div class="dogfood-proof__copy">
        <SectionHeader
          eyebrow="LUMINIK DOGFOOD SNAPSHOT"
          title="What Alfred has shipped in the product repos."
          lede={`Last ${dogfood.window.days} days across ${dogfood.summary.repos_scanned} Luminik repos. Counted from GitHub labels and Alfred branch prefixes, then published as aggregate numbers only.`}
          reveal={false}
        />
        <p class="dogfood-proof__note">
          No private repo names, PR titles, issue titles, branches, comments, prompts, or code are published here.
          The public GitHub board below is stricter and shows only inspectable links from the open-source repo.
        </p>
      </div>
      <div class="dogfood-proof__panel" aria-label="Luminik dogfood metrics">
        <div class="dogfood-proof__head">
          <span class="m-eyebrow">AGGREGATE ONLY</span>
          <span class="m-mono m-mute">updated {dogfoodGenerated}</span>
        </div>
        <div class="dogfood-proof__main">
          <span>{fmt(dogfood.summary.agent_prs_merged)}</span>
          <p>agent-identified PRs merged</p>
        </div>
        <div class="dogfood-proof__grid">
          <div>
            <span>{fmt(dogfood.summary.agent_issues_opened)}</span>
            <p>agent-labeled issues opened</p>
          </div>
          <div>
            <span>{fmt(dogfood.summary.agent_issues_closed)}</span>
            <p>agent-labeled issues closed</p>
          </div>
          <div>
            <span>{fmt(dogfood.summary.files_changed)}</span>
            <p>files changed</p>
          </div>
          <div>
            <span>+{fmt(dogfood.summary.lines_added)}</span>
            <p>lines added, -{fmt(dogfood.summary.lines_removed)} removed</p>
          </div>
        </div>
        <p class="dogfood-proof__foot">
          Filtered from {fmt(dogfood.summary.total_prs_merged)} merged PRs and {fmt(dogfood.summary.total_issues_opened)} opened issues in the same repos.
        </p>
      </div>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <ImpactProofBoard proof={proof} />
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="ANONYMOUS COMMUNITY COUNTER"
        title="Installs can add aggregate totals."
        lede="This counter counts aggregate PR activity from installs that choose to report. It does not send repo names, titles, branches, prompts, code, people, or hostnames."
      />
      <ImpactCounter threshold={1} />
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="WHAT GETS COUNTED"
        title="Only aggregate counts. Nothing from the work itself."
        lede="Anonymous telemetry is for community adoption, not for exposing an operator's work. Public proof with PR titles and URLs comes from repos the operator deliberately publishes."
      />
      <div class="proof-grid">
        <article class="m-card">
          <span class="m-mono proof-grid__num">01</span>
          <h3 class="m-h3">Pull requests opened</h3>
          <p>How many PRs opted-in installs created through the Alfred runner.</p>
        </article>
        <article class="m-card">
          <span class="m-mono proof-grid__num">02</span>
          <h3 class="m-h3">Terminal pull requests</h3>
          <p>How many Alfred-authored PRs reached merged or closed state.</p>
        </article>
        <article class="m-card">
          <span class="m-mono proof-grid__num">03</span>
          <h3 class="m-h3">Pull requests merged</h3>
          <p>How many PRs reached the shipped state after the operator's process.</p>
        </article>
        <article class="m-card">
          <span class="m-mono proof-grid__num">04</span>
          <h3 class="m-h3">Changed files</h3>
          <p>The current anonymous field is a file-touch proxy. Real GitHub line counts are shown only for public repos.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="m-section m-section--soft">
    <div class="m-container operator-grid">
      <div>
        <SectionHeader
          eyebrow="OPERATOR CONTROL"
          title="Off until you turn it on."
          lede="For an open-source developer tool, trust matters more than a larger counter. Alfred asks during setup and keeps telemetry disabled unless the operator opts in."
        />
        <div class="control-points">
          <p><strong>No repo names.</strong> Alfred does not send the repository, organization, branch, issue title, PR title, or source code.</p>
          <p><strong>No personal data.</strong> The install token is random and exists only to cap duplicate reports from the same install.</p>
          <p><strong>No hidden dependency.</strong> Alfred runs the same way with telemetry off.</p>
        </div>
      </div>
      <CodeBlock
        title="telemetry"
        lines={[
          "$ alfred telemetry status",
          "telemetry: off",
          "endpoint: (unset)",
          "token: unset",
          "scheduler row: absent (~/code/alfred-os/launchd/agents.conf)",
          "public page: https://alfred.luminik.io/impact/",
          "",
          "$ alfred telemetry on --url https://your-worker.example/ingest",
          "alfred: telemetry enabled",
          "alfred: wrote ~/.alfredrc",
          "alfred: scheduled alfred.proof-telemetry in ~/code/alfred-os/launchd/agents.conf",
          "alfred: run `bash ~/code/alfred-os/deploy.sh` to install the scheduler change",
          "",
          "$ alfred telemetry off",
          "alfred: telemetry disabled",
          "alfred: removed scheduler row at ~/code/alfred-os/launchd/agents.conf",
          "alfred: run `bash ~/code/alfred-os/deploy.sh` to install the scheduler change",
        ]}
      />
    </div>
  </section>
</MarketingLayout>

<style>
  .impact-panel {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .impact-panel__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--alfred-border);
  }
  .hero-proof {
    text-align: center;
    padding: 12px 0 4px;
  }
  .hero-proof span,
  .hero-proof__grid span {
    color: var(--alfred-accent);
    font-family: var(--font-display);
    font-size: clamp(42px, 7vw, 72px);
    font-weight: 700;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .hero-proof p,
  .hero-proof__grid p {
    margin-top: 8px;
    color: var(--alfred-mute);
    font-size: 13px;
  }
  .hero-proof__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  .hero-proof__grid div {
    border: 1px solid var(--alfred-border);
    border-radius: var(--radius);
    padding: 14px 12px;
    text-align: center;
  }
  .hero-proof__grid span {
    font-size: 24px;
  }
  .proof-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .dogfood-proof {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: 40px;
    align-items: center;
  }
  .dogfood-proof__copy :global(.m-section-header) {
    margin-bottom: 18px;
  }
  .dogfood-proof__note,
  .dogfood-proof__foot {
    color: var(--alfred-text);
    font-size: 15px;
    line-height: 1.6;
  }
  .dogfood-proof__panel {
    min-width: 0;
    padding: 22px;
    border: 1px solid var(--alfred-border-strong);
    border-radius: var(--radius);
    background: var(--alfred-black);
    box-shadow: 0 24px 90px rgba(0, 0, 0, 0.22);
  }
  .dogfood-proof__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--alfred-border);
  }
  .dogfood-proof__main {
    padding: 24px 0 18px;
    text-align: center;
  }
  .dogfood-proof__main span,
  .dogfood-proof__grid span {
    color: var(--alfred-accent);
    font-family: var(--font-display);
    font-weight: 700;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .dogfood-proof__main span {
    font-size: clamp(48px, 8vw, 86px);
  }
  .dogfood-proof__main p,
  .dogfood-proof__grid p {
    margin-top: 8px;
    color: var(--alfred-mute);
    font-size: 13px;
  }
  .dogfood-proof__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  .dogfood-proof__grid div {
    min-width: 0;
    padding: 16px 14px;
    border: 1px solid var(--alfred-border);
    border-radius: var(--radius);
    background: var(--alfred-surface);
  }
  .dogfood-proof__grid span {
    display: block;
    font-size: clamp(24px, 4vw, 34px);
  }
  .dogfood-proof__foot {
    margin-top: 16px;
    color: var(--alfred-mute);
  }
  .proof-grid__num {
    display: block;
    color: var(--alfred-accent);
    margin-bottom: 14px;
  }
  .proof-grid p,
  .control-points p {
    margin-top: 10px;
    color: var(--alfred-text);
    font-size: 15px;
    line-height: 1.6;
  }
  .operator-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 48px;
    align-items: start;
  }
  .control-points {
    display: grid;
    gap: 16px;
  }
  .control-points strong {
    color: var(--alfred-text-bright);
  }
  @media (max-width: 980px) {
    .proof-grid,
    .dogfood-proof,
    .operator-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 520px) {
    .impact-panel__head,
    .dogfood-proof__head {
      align-items: flex-start;
      flex-direction: column;
    }
    .dogfood-proof__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
