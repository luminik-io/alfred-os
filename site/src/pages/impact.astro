---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import Hero from "../components/marketing/Hero.astro";
import SectionHeader from "../components/marketing/SectionHeader.astro";
import ImpactCounter from "../components/marketing/ImpactCounter.astro";
import FleetProofCounter from "../components/marketing/FleetProofCounter.astro";
import CodeBlock from "../components/marketing/CodeBlock.astro";
---

<MarketingLayout
  title="Impact | Alfred"
  description="Real Alfred fleet activity from Luminik's local setup, plus the anonymous opt-in community counter."
  path="/impact/"
>
  <Hero
    eyebrow="REAL FLEET ACTIVITY"
    headline="The Alfred setup that builds Alfred and Luminik."
    sub="A snapshot from Prasad's local Alfred state, plus a community counter for operators who choose to share anonymous totals. No repo names, code, prompts, branches, hostnames, or people."
    headlineSize="lg"
    primaryCta={{ label: "Read telemetry docs", href: "/reference/telemetry/" }}
    secondaryCta={{ label: "Download Alfred", href: "/download/" }}
  >
    <div slot="panel" class="impact-panel">
      <div class="impact-panel__head">
        <span class="m-eyebrow">LOCAL SNAPSHOT</span>
        <span class="m-mono m-mute">last 30 days</span>
      </div>
      <FleetProofCounter
        days={30}
        updated="2026-06-19"
        agentRuns={2780}
        activeAgents={13}
        agentTurns={24357}
        codexRuns={129}
        toolCalls={5092}
        filesEdited={74}
      />
    </div>
  </Hero>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="COMMUNITY COUNTER"
        title="Operators can opt in to share public totals."
        lede="The public telemetry counter is separate from the Luminik snapshot above. It stays off unless an operator turns it on, and it sends only aggregate counts."
      />
      <ImpactCounter threshold={1} />
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="WHAT GETS COUNTED"
        title="Only counts. Nothing from the work itself."
        lede="When an operator opts in, Alfred can report a tiny payload that proves usage without exposing what the operator is building."
      />
      <div class="proof-grid">
        <article class="m-card">
          <span class="m-mono proof-grid__num">01</span>
          <h3 class="m-h3">Pull requests opened</h3>
          <p>How many PRs opted-in installs created through the Alfred runner.</p>
        </article>
        <article class="m-card">
          <span class="m-mono proof-grid__num">02</span>
          <h3 class="m-h3">Pull requests reviewed</h3>
          <p>How many PRs a review agent inspected and reported on.</p>
        </article>
        <article class="m-card">
          <span class="m-mono proof-grid__num">03</span>
          <h3 class="m-h3">Pull requests merged</h3>
          <p>How many PRs reached the shipped state after the operator's process.</p>
        </article>
        <article class="m-card">
          <span class="m-mono proof-grid__num">04</span>
          <h3 class="m-h3">Changed files</h3>
          <p>A coarse changed-file count, reported as an aggregate number only.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="m-section m-section--soft">
    <div class="m-container operator-grid">
      <div>
        <SectionHeader
          eyebrow="OPERATOR CONTROL"
          title="Off by default. One command to turn on."
          lede="The operator chooses the endpoint, can self-host the collector, and can turn reporting off without touching the rest of Alfred."
        />
        <div class="control-points">
          <p><strong>No repo names.</strong> Alfred does not send the repository, organization, branch, issue title, PR title, or source code.</p>
          <p><strong>No personal data.</strong> The install token is random and exists only to cap duplicate reports from the same install.</p>
          <p><strong>No hidden dependency.</strong> Alfred runs the same way with telemetry off.</p>
        </div>
      </div>
      <CodeBlock
        title="telemetry"
        lines={[
          "$ alfred telemetry status",
          "telemetry: off",
          "endpoint: (unset)",
          "token: unset",
          "scheduler row: absent (~/code/alfred-os/launchd/agents.conf)",
          "public page: https://alfred.luminik.io/impact/",
          "",
          "$ alfred telemetry on --url https://your-worker.example/ingest",
          "alfred: telemetry enabled",
          "alfred: wrote ~/.alfredrc",
          "alfred: scheduled alfred.proof-telemetry in ~/code/alfred-os/launchd/agents.conf",
          "alfred: run `bash ~/code/alfred-os/deploy.sh` to install the scheduler change",
          "",
          "$ alfred telemetry off",
          "alfred: telemetry disabled",
          "alfred: removed scheduler row at ~/code/alfred-os/launchd/agents.conf",
          "alfred: run `bash ~/code/alfred-os/deploy.sh` to install the scheduler change",
        ]}
      />
    </div>
  </section>
</MarketingLayout>

<style>
  .impact-panel {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .impact-panel__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--alfred-border);
  }
  .proof-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .proof-grid__num {
    display: block;
    color: var(--alfred-accent);
    margin-bottom: 14px;
  }
  .proof-grid p,
  .control-points p {
    margin-top: 10px;
    color: var(--alfred-text);
    font-size: 15px;
    line-height: 1.6;
  }
  .operator-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 48px;
    align-items: start;
  }
  .control-points {
    display: grid;
    gap: 16px;
  }
  .control-points strong {
    color: var(--alfred-text-bright);
  }
  @media (max-width: 980px) {
    .proof-grid,
    .operator-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 520px) {
    .impact-panel__head {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
