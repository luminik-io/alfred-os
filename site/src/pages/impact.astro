---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import Hero from "../components/marketing/Hero.astro";
import ImpactCounter from "../components/marketing/ImpactCounter.astro";
import ImpactProofBoard from "../components/marketing/ImpactProofBoard.astro";
import ImpactTrend from "../components/marketing/ImpactTrend.astro";
import proof from "../data/impact-proof.json";
import productProof from "../data/luminik-product-proof.json";

const productProofGenerated = productProof.generated_at.slice(0, 10);
const linesChanged = productProof.summary.lines_added + productProof.summary.lines_removed;
const productTrend = Array.isArray((productProof as { trend?: unknown }).trend)
  ? (productProof as { trend: Array<{ week: string; prs_merged: number }> }).trend
  : [];
const hasPublicActivity =
  proof.prs.length > 0 ||
  proof.issues.length > 0 ||
  proof.summary.prs_merged > 0 ||
  proof.summary.issues_opened > 0 ||
  proof.summary.issues_triaged > 0;
---

<MarketingLayout
  title="Impact | Alfred"
  description="A running record of what Alfred has shipped: merged PRs, issues opened and closed, files changed, lines changed, and public examples."
  path="/impact/"
>
  <Hero
    eyebrow="ALFRED IMPACT"
    headline="What Alfred shipped."
    sub="Last 30 days: PRs merged, issues opened and closed, and code changed across repos where Alfred is working. Updated daily from GitHub."
    headlineSize="lg"
    primaryCta={{ label: "View GitHub", href: "https://github.com/luminik-io/alfred-os" }}
    secondaryCta={{ label: "Telemetry details", href: "/reference/telemetry/" }}
  >
    <div slot="panel" class="impact-panel">
      <div class="impact-panel__head">
        <span class="impact-panel__window">Last {productProof.window.days} days</span>
        <span class="m-mono m-mute">updated {productProofGenerated}</span>
      </div>
      <ImpactCounter
        variant="plain"
        seed={{
          installs: 1,
          prs_merged: productProof.summary.agent_prs_merged,
          issues_opened: productProof.summary.agent_issues_opened,
          issues_closed: productProof.summary.agent_issues_closed,
          lines_added: productProof.summary.lines_added,
          lines_removed: productProof.summary.lines_removed,
          lines_changed: linesChanged,
          files_changed: productProof.summary.files_changed,
          updated_at: productProof.generated_at,
        }}
        live={false}
        showUpdated={false}
      />
    </div>
  </Hero>

  {productTrend.length > 0 ? (
    <section class="m-section impact-section">
      <div class="m-container">
        <ImpactTrend trend={productTrend} />
      </div>
    </section>
  ) : null}

  {hasPublicActivity ? (
    <section class="m-section">
      <div class="m-container">
        <ImpactProofBoard proof={proof} />
      </div>
    </section>
  ) : null}
</MarketingLayout>

<style>
  .impact-panel {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .impact-panel__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--alfred-border);
  }
  .impact-panel__window {
    color: var(--alfred-text-bright);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0;
  }
  .impact-section {
    padding-top: 72px;
  }
  @media (max-width: 520px) {
    .impact-panel__head {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
