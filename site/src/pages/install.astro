---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import Hero from "../components/marketing/Hero.astro";
import SectionHeader from "../components/marketing/SectionHeader.astro";
import CodeBlock from "../components/marketing/CodeBlock.astro";
---

<MarketingLayout
  title="Install Alfred | Existing setup or fresh machine"
  description="Install Alfred Desktop for the guided path, or use the terminal path for a headless host. Both paths configure the full local engineering fleet."
  path="/install/"
>
  <Hero
    eyebrow="INSTALL"
    headline="Install the full Alfred fleet."
    sub="Use Alfred Desktop for the guided setup, or use the terminal path for a headless Mac or Linux host. Either way, the default is the full engineering roster: planner, builders, reviewers, test coverage, review-fix, cleanup, reports, and cross-repo architecture."
    headlineSize="lg"
    primaryCta={{ label: "Download Desktop", href: "/download/" }}
    secondaryCta={{ label: "Terminal install", href: "/getting-started/install/" }}
  />

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="PICK YOUR STARTING POINT"
        title="Choose the path that matches your machine."
        lede="The desktop path is the default for most users because it can inspect an existing setup, start the local server, guide auth, and keep setup repairable. The terminal path is still there for headless hosts and people who want every command in front of them."
      />
      <div class="paths">
        <a class="m-card m-card--hover paths__card" href="/download/">
          <span class="m-eyebrow">PATH A &middot; RECOMMENDED</span>
          <h3 class="m-h3">Use Alfred Desktop.</h3>
          <ul class="paths__list">
            <li>Detects an existing Alfred runtime and repo checkout</li>
            <li>Guides GitHub, Claude Code, Codex, and local server checks</li>
            <li>Configures the full fleet without hand-editing prompts</li>
            <li>Lets you pick a roster theme or custom agent names</li>
          </ul>
          <span class="m-link" style="align-self:start;">Download the app -></span>
        </a>
        <a class="m-card m-card--hover paths__card" href="/getting-started/install/">
          <span class="m-eyebrow">PATH B &middot; HEADLESS</span>
          <h3 class="m-h3">Run the terminal install.</h3>
          <ul class="paths__list">
            <li>Best for Linux servers and scripted setup</li>
            <li>Installs dependencies and writes the local runtime</li>
            <li>Can be driven by Claude Code or Codex with the assisted guide</li>
            <li>Ends with doctor, dry-run, and scheduler checks</li>
          </ul>
          <span class="m-link" style="align-self:start;">Open terminal guide -></span>
        </a>
      </div>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="CHECK IT FIRST"
        title="Check the setup before real work starts."
        lede="The doctor command checks the local runtime. A dry run walks one agent through its startup path without touching GitHub, Slack, an engine, or your files."
      />
      <CodeBlock
        title="terminal"
        lines={[
          "$ alfred doctor",
          "ok    gh auth                  luminik-io",
          "ok    claude code              authed",
          "ok    codex                    authed (optional)",
          "ok    launchd                  full fleet loaded",
          "ok    spend cap                $20/day fleet",
          "",
          "$ alfred dry-run lucius",
          "alfred dry-run: lucius",
          "  role: feature dev",
          "  mode: safe simulation",
          "  would: resolve config, acquire the agent lock, run preflight, and enter the runner",
          "  would not: mutate GitHub, post Slack, invoke an engine, or edit files",
        ]}
      />
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="WHAT YOU END UP WITH"
        title="A full engineering team scheduled on your machine."
        lede="The default setup enables the whole local engineering loop. Drake plans, Batman coordinates cross-repo work, Lucius builds, Ra's al Ghul reviews, Bane adds tests, Nightwing handles high-priority review feedback, and the reliability/reporting agents keep the system inspectable."
      />
      <ol class="checks">
        <li class="m-card"><span class="m-mono m-dot m-dot--live">●</span><strong>Drake</strong> reads your plans and files small, clear tasks.</li>
        <li class="m-card"><span class="m-mono m-dot m-dot--live">●</span><strong>Batman</strong> coordinates approved cross-repo rollouts.</li>
        <li class="m-card"><span class="m-mono m-dot m-dot--live">●</span><strong>Lucius</strong> picks up those tasks and opens pull requests.</li>
        <li class="m-card"><span class="m-mono m-dot m-dot--warn">●</span><strong>Ra's al Ghul</strong> reviews pull requests and runs your tests.</li>
        <li class="m-card"><span class="m-mono m-dot m-dot--live">●</span><strong>Bane</strong> adds focused coverage where changes need tests.</li>
        <li class="m-card"><span class="m-mono m-dot m-dot--idle">●</span><strong>Nightwing</strong> fixes high-priority review comments on Alfred PRs.</li>
      </ol>
    </div>
  </section>
</MarketingLayout>

<style>
  .paths { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  @media (max-width: 720px) { .paths { grid-template-columns: 1fr; } }
  .paths__card { display: flex; flex-direction: column; gap: 14px; }
  .paths__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; color: var(--alfred-text); font-size: 15px; }
  .paths__list li { padding-left: 18px; position: relative; }
  .paths__list li::before { content: "●"; position: absolute; left: 0; color: var(--alfred-accent); font-size: 9px; top: 7px; }

  .checks { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  @media (max-width: 720px) { .checks { grid-template-columns: 1fr; } }
  .checks li { display: flex; align-items: center; gap: 14px; color: var(--alfred-text); font-size: 15px; }
  .checks li strong { color: var(--alfred-text-bright); margin-right: 4px; }
</style>
