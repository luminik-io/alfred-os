---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import Hero from "../components/marketing/Hero.astro";
import SectionHeader from "../components/marketing/SectionHeader.astro";
import CodeBlock from "../components/marketing/CodeBlock.astro";
---

<MarketingLayout
  title="Install Alfred | Existing setup or fresh machine"
  description="Use the fast path if GitHub CLI, Claude Code, a package manager, and Python are already ready. Use the guided path for a fresh machine."
  path="/install/"
>
  <Hero
    eyebrow="INSTALL"
    headline="Install Alfred from the setup you actually have."
    sub="Fast path for an already-provisioned dev machine. Guided path for a fresh laptop or dedicated agent box."
    headlineSize="lg"
    primaryCta={{ label: "Use existing setup", href: "/getting-started/install/" }}
    secondaryCta={{ label: "Set up a fresh machine", href: "/getting-started/ai-assisted-install/" }}
  />

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="PICK YOUR STARTING POINT"
        title="Choose the path that matches your machine."
        lede="The fast path assumes your developer tools are already authenticated. The guided path walks through prerequisites, auth, and the first Alfred run."
      />
      <div class="paths">
        <a class="m-card m-card--hover paths__card" href="/getting-started/install/">
          <span class="m-eyebrow">PATH A &middot; ~30 MIN</span>
          <h3 class="m-h3">Use an existing dev setup.</h3>
          <ul class="paths__list">
            <li>GitHub CLI is already authenticated</li>
            <li>Claude Code first run is complete</li>
            <li>Homebrew on macOS or apt on Linux</li>
            <li>Python 3.11+ on PATH</li>
          </ul>
          <span class="m-link" style="align-self:start;">Open the fast install →</span>
        </a>
        <a class="m-card m-card--hover paths__card" href="/getting-started/ai-assisted-install/">
          <span class="m-eyebrow">PATH B &middot; ~60 TO 120 MIN</span>
          <h3 class="m-h3">Set up a fresh machine.</h3>
          <ul class="paths__list">
            <li>Fresh laptop or dedicated box</li>
            <li>No GitHub auth, no CLIs installed</li>
            <li>Guided prompt for Claude Code</li>
            <li>Every repo and secret is confirmed explicitly</li>
          </ul>
          <span class="m-link" style="align-self:start;">Open the guided install →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="CHECK IT FIRST"
        title="Do a test run before you spend anything."
        lede="The doctor command checks that everything is set up right. A test run walks one agent through all its steps without calling Claude or Codex, so nothing is spent."
      />
      <CodeBlock
        title="terminal"
        lines={[
          "$ alfred doctor",
          "ok    gh auth                  luminik-io",
          "ok    claude code              authed",
          "ok    codex                    authed (optional)",
          "ok    launchd                  21 agents loaded",
          "ok    spend cap                $20/day fleet",
          "",
          "$ alfred fire lucius --dry-run",
          "ok    preflight passed",
          "ok    issue selection (would claim #247)",
          "skip  claude_invoke (dry-run)",
          "ok    runner lifecycle verified, no spend",
        ]}
      />
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="WHAT YOU END UP WITH"
        title="One repo, four agents, a run every 20 minutes."
        lede="The default setup gives you four agents to start: Drake, Lucius, Ra's al Ghul, and a cleanup agent. Add Batman, Bane, and Nightwing when you are ready for them."
      />
      <ol class="checks">
        <li class="m-card"><span class="m-mono m-dot m-dot--live">●</span><strong>Drake</strong> reads your plans and files small, clear tasks.</li>
        <li class="m-card"><span class="m-mono m-dot m-dot--live">●</span><strong>Lucius</strong> picks up those tasks and opens pull requests.</li>
        <li class="m-card"><span class="m-mono m-dot m-dot--warn">●</span><strong>Ra's al Ghul</strong> reviews pull requests and runs your tests.</li>
        <li class="m-card"><span class="m-mono m-dot m-dot--idle">●</span><strong>Cleanup</strong> tidies up leftover repo copies and branches.</li>
      </ol>
    </div>
  </section>
</MarketingLayout>

<style>
  .paths { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  @media (max-width: 720px) { .paths { grid-template-columns: 1fr; } }
  .paths__card { display: flex; flex-direction: column; gap: 14px; }
  .paths__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; color: var(--alfred-text); font-size: 15px; }
  .paths__list li { padding-left: 18px; position: relative; }
  .paths__list li::before { content: "●"; position: absolute; left: 0; color: var(--alfred-accent); font-size: 9px; top: 7px; }

  .checks { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  @media (max-width: 720px) { .checks { grid-template-columns: 1fr; } }
  .checks li { display: flex; align-items: center; gap: 14px; color: var(--alfred-text); font-size: 15px; }
  .checks li strong { color: var(--alfred-text-bright); margin-right: 4px; }
</style>
