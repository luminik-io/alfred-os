---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import Hero from "../components/marketing/Hero.astro";
import SectionHeader from "../components/marketing/SectionHeader.astro";
import CodeBlock from "../components/marketing/CodeBlock.astro";

const lifecycle = [
  {
    n: "01",
    title: "A timer starts the run",
    body: "A built-in scheduler (launchd on macOS, systemd on Linux) starts each agent on its configured cadence. Lucius checks for implementation work every 20 minutes by default, and the fleet keeps running across reboots.",
    log: "[12:00:00] launchd → ~/.alfred/bin/lucius.py",
  },
  {
    n: "02",
    title: "Safety checks run first",
    body: "Before any paid call, the agent checks that GitHub and the Claude Code or Codex command line are signed in, that you are under your spending limit, and that you are not rate-limited. If any check fails, the run stops cleanly.",
    log: "[12:00:01] preflight ok  spend=$3.21/$20.00",
  },
  {
    n: "03",
    title: "It picks up a task",
    body: "Lucius looks at the open tasks marked agent:implement, takes the oldest one, and marks it agent:in-flight. Other agents see that label and leave it alone.",
    log: "[12:00:03] lucius claimed your-backend#247  label=agent:in-flight",
  },
  {
    n: "04",
    title: "It makes its own copy of the repo",
    body: "A fresh copy of the repo opens in its own folder under ~/.alfred. Each run gets its own copy, so runs can happen at the same time and a crash never affects your working files.",
    log: "[12:00:05] worktree ~/.alfred/wt/12000305/  branch=agent/247-billing-v2",
  },
  {
    n: "05",
    title: "Claude Code or Codex writes the code",
    body: "The agent hands the task to Claude Code or Codex on the command line, with the full project in context. Everything it does is saved to a log file on your machine.",
    log: "[12:00:06] claude_invoke pid=84217  log=state/logs/12000305.log",
  },
  {
    n: "06",
    title: "It opens a pull request",
    body: "When the work is done, the agent pushes the branch and opens a pull request on GitHub. The task's label changes from agent:in-flight to agent:pr-open.",
    log: "[12:18:09] gh pr create  PR #1247  label=agent:pr-open",
  },
  {
    n: "07",
    title: "It tells you on Slack",
    body: "The agent posts a short summary to your Slack: what it did, what it opened, what failed, and what it cost. Anything that needs your attention is easy to spot.",
    log: "[12:18:11] slack_post severity=info  PR #1247 opened",
  },
];

const labels = [
  { label: "agent:implement", body: "You or Drake add this. It tells Lucius the task is small enough and clear enough to pick up." },
  { label: "agent:in-flight", body: "Lucius adds this when it takes the task. Other agents see it and skip the task." },
  { label: "agent:pr-open", body: "Added when the agent opens a pull request. Ra's al Ghul watches for this label to start a review." },
  { label: "agent:done", body: "Added when the pull request merges. The task is finished and drops out of the active list." },
  { label: "agent:needs-changes", body: "Ra's al Ghul adds this when a review asks for changes. Lucius picks it back up on its next run." },
];
---

<MarketingLayout
  title="How Alfred works | One run, from start to finish"
  description="What happens in a single Alfred run, from the timer that starts it to the Slack message at the end. Separate repo copies, GitHub labels that track each task, and spending limits, all explained plainly."
  path="/how-it-works/"
>
  <Hero
    eyebrow="HOW IT WORKS"
    headline="How Alfred works."
    sub="One run, from the timer that starts it to the Slack message at the end. Nothing running in the cloud, no service to sign up for."
    headlineSize="lg"
    primaryCta={{ label: "Read the architecture", href: "/concepts/architecture/" }}
	    secondaryCta={{ label: "Install", href: "/getting-started/install/" }}
  />

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="THE SEVEN STEPS"
        title="Seven steps, every time."
        lede="Every Alfred agent follows the same seven steps. If any step fails, the run stops cleanly and posts a note to Slack."
      />
      <ol class="lifecycle">
        {lifecycle.map((step) => (
          <li class="lifecycle__item m-card">
            <div class="lifecycle__num m-mono">{step.n}</div>
            <div class="lifecycle__body">
              <h3 class="m-h3">{step.title}</h3>
              <p class="lifecycle__copy">{step.body}</p>
              <pre class="lifecycle__log">{step.log}</pre>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="HOW AGENTS STAY OUT OF EACH OTHER'S WAY"
        title="GitHub labels track every task."
        lede="Agents coordinate through GitHub labels, not a database. The label on a task tells every agent what is happening and who is on it, so two agents never grab the same work."
      />
      <div class="labels">
        {labels.map((l) => (
          <div class="labels__row m-card m-card--hover">
            <code class="labels__tag m-mono">{l.label}</code>
            <p class="labels__body">{l.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="TRY IT ON YOUR MACHINE"
        title="Do a test run before you spend anything."
        lede="A test run walks through every step above without calling Claude or Codex, so nothing is spent. Run it once on every new setup."
      />
      <CodeBlock
        title="terminal"
        lines={[
	          "$ alfred dry-run lucius",
	          "alfred dry-run: lucius",
	          "  role: feature dev",
	          "  mode: safe simulation",
	          "  would: resolve config, acquire the agent lock, run preflight, and enter the runner",
	          "  would not: call the host scheduler, mutate GitHub, post Slack, invoke an LLM, or edit files",
	        ]}
	      />
    </div>
  </section>
</MarketingLayout>

<style>
  .lifecycle { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 16px; }
  .lifecycle__item { display: grid; grid-template-columns: 60px 1fr; gap: 20px; align-items: start; }
  .lifecycle__num { color: var(--alfred-accent); font-size: 20px; padding-top: 4px; }
  .lifecycle__copy { color: var(--alfred-text); font-size: 15px; margin: 8px 0 14px; line-height: 1.6; }
  .lifecycle__log {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.6;
    color: var(--alfred-mute);
    background: var(--alfred-black);
    border: 1px solid var(--alfred-border);
    border-radius: 6px;
    padding: 10px 12px;
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .labels { display: flex; flex-direction: column; gap: 14px; }
  .labels__row { display: grid; grid-template-columns: 220px 1fr; gap: 24px; align-items: center; }
  .labels__tag { color: var(--alfred-accent); font-size: 14px; }
  .labels__body { color: var(--alfred-text); font-size: 15px; line-height: 1.6; }
  @media (max-width: 720px) {
    .lifecycle__item, .labels__row { grid-template-columns: 1fr; gap: 12px; }
  }
</style>
