---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import Hero from "../components/marketing/Hero.astro";
import SectionHeader from "../components/marketing/SectionHeader.astro";
import CodeBlock from "../components/marketing/CodeBlock.astro";

const layouts = [
  {
    title: "Nx + pnpm",
    note: "Each task names one package to change. Lucius runs the tests for just that package with pnpm --filter @org/api test.",
    tree: [
      "monorepo/",
      "├── apps/",
      "│   ├── api/",
      "│   ├── web/",
      "│   └── docs/",
      "├── packages/",
      "│   ├── ui/",
      "│   ├── auth/",
      "│   └── db/",
      "├── nx.json",
      "├── pnpm-workspace.yaml",
      "└── package.json",
    ],
  },
  {
    title: "Turborepo",
    note: "Bane runs tests only for the packages that changed, using turbo run test --filter=...HEAD~1.",
    tree: [
      "monorepo/",
      "├── apps/",
      "│   ├── marketing/",
      "│   └── dashboard/",
      "├── packages/",
      "│   ├── design-system/",
      "│   ├── eslint-config/",
      "│   └── tsconfig/",
      "├── turbo.json",
      "└── pnpm-workspace.yaml",
    ],
  },
  {
    title: "Cargo workspaces",
    note: "Lucius makes its copy of the repo at the workspace root and tests one crate with cargo test -p service-auth.",
    tree: [
      "workspace/",
      "├── crates/",
      "│   ├── service-auth/",
      "│   ├── service-billing/",
      "│   └── shared-types/",
      "├── Cargo.toml",
      "└── Cargo.lock",
    ],
  },
];
---

<MarketingLayout
  title="Monorepo support | Alfred"
  description="Drake files tasks that each name one package, Lucius works on its own copy of the whole monorepo, and Bane runs the tests for just the package that changed."
  path="/monorepo/"
>
  <Hero
    eyebrow="MONOREPO"
    headline="Yes, Alfred works on a monorepo."
    sub="Drake files tasks that each name one package, Lucius works on its own copy of the whole monorepo, and Bane runs the tests for just the package that changed."
    headlineSize="lg"
    primaryCta={{ label: "Read the worked example", href: "/getting-started/workspace-patterns/" }}
	    secondaryCta={{ label: "Install", href: "/getting-started/install/" }}
  />

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="THREE LAYOUTS, SAME APPROACH"
        title="Each run gets its own copy of the whole repo."
        lede="Every run opens a fresh copy of the entire monorepo. The task says which package to change, and the test command says which package to test."
      />
      <div class="layouts">
        {layouts.map((l) => (
          <article class="m-card m-card--hover">
            <h3 class="m-h3">{l.title}</h3>
            <p class="layouts__note">{l.note}</p>
            <pre class="layouts__tree">{l.tree.join("\n")}</pre>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="THE TRADEOFFS"
        title="What works well, and what to watch."
        lede="A monorepo makes some things easier (one repo to work in) and some things harder (knowing what to test, and lockfiles that change a lot)."
      />
      <div class="tradeoffs">
        <article class="m-card">
          <h3 class="m-h3">Works well</h3>
          <ul class="tradeoffs__list">
            <li>Tasks that name one package and a single goal.</li>
            <li>Bane tests only the package that changed, not everything.</li>
            <li>Batman plans land in one repo, so there is less to coordinate.</li>
            <li>Costs stay predictable when each task tests just one package.</li>
          </ul>
        </article>
        <article class="m-card">
          <h3 class="m-h3">Watch out for</h3>
          <ul class="tradeoffs__list">
            <li>Lockfiles that change across packages. Let only two or three tasks run at once.</li>
            <li>Changes that span packages. Mark them agent:large-feature so Batman plans them, not Lucius.</li>
            <li>Slow tests at the repo root. Tell each task to test only its own package.</li>
            <li>Edits to a shared design system reach every package. Review those closely.</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="WHAT A TASK LOOKS LIKE"
        title="One task, one package."
      />
      <CodeBlock
        title="monorepo#412 (agent:implement)"
        lines={[
          "Target package: packages/auth",
          "",
          "Goal: rotate the session cookie name to alfred_session.",
          "Keep backward compatibility for one release.",
          "",
          "Test gate:",
          "  pnpm --filter @org/auth test",
          "",
          "Done when:",
          "  PR open, scoped tests green, no other package touched.",
        ]}
      />
    </div>
  </section>
</MarketingLayout>

<style>
  .layouts { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  @media (max-width: 980px) { .layouts { grid-template-columns: 1fr; } }
  .layouts__note { color: var(--alfred-text); font-size: 14px; line-height: 1.55; margin: 10px 0 14px; }
  .layouts__tree {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.6;
    color: var(--alfred-text);
    background: var(--alfred-black);
    border: 1px solid var(--alfred-border);
    border-radius: 6px;
    padding: 12px;
    overflow-x: auto;
    white-space: pre;
  }
  .tradeoffs { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  @media (max-width: 720px) { .tradeoffs { grid-template-columns: 1fr; } }
  .tradeoffs__list { list-style: none; padding: 0; margin: 10px 0 0; display: flex; flex-direction: column; gap: 10px; }
  .tradeoffs__list li { color: var(--alfred-text); font-size: 15px; line-height: 1.55; padding-left: 18px; position: relative; }
  .tradeoffs__list li::before {
    content: "●";
    position: absolute;
    left: 0;
    color: var(--alfred-accent);
    font-size: 10px;
    top: 6px;
  }
</style>
