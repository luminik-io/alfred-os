---
/**
 * Landing page for alfred.luminik.io.
 *
 * Routing decision (binding):
 * The previous landing was a Starlight `splash` template rendered from
 * src/content/docs/index.mdx (slug=""), which owned the root URL.
 *
 * To swap in a fully bespoke marketing landing without breaking the rest of
 * the Starlight docs (which still serve /concepts/, /guides/, /reference/,
 * /about/, /getting-started/), we rename that file to
 * `src/content/docs/docs.mdx` and update the sidebar entry in
 * astro.config.mjs (`slug: ""` → `slug: "docs"`).
 *
 * Astro then serves `src/pages/index.astro` at `/`, and Starlight serves the
 * docs hub at `/docs/`. Every other Starlight URL is unchanged.
 */

import MarketingLayout from "../layouts/MarketingLayout.astro";
import Hero from "../components/marketing/Hero.astro";
import SectionHeader from "../components/marketing/SectionHeader.astro";
import MetricRow from "../components/marketing/MetricRow.astro";
import JobCard from "../components/marketing/JobCard.astro";
import CodeBlock from "../components/marketing/CodeBlock.astro";
import SlackProof from "../components/marketing/SlackProof.astro";
import FiringLifecycle from "../components/marketing/FiringLifecycle.astro";
import FleetStatus from "../components/marketing/FleetStatus.astro";
import SpecsDrivenFlow from "../components/marketing/SpecsDrivenFlow.astro";
import BatmanFanOut from "../components/marketing/BatmanFanOut.astro";
import NativeClientShowcase from "../components/marketing/NativeClientShowcase.astro";
import DownloadTracker from "../components/marketing/DownloadTracker.astro";

type JobState = "live" | "warn" | "idle" | "info";

const jobs: { title: string; body: string; log: string[]; state: JobState }[] = [
  {
    title: "Drake turns requests into tasks",
    body: "Reads the plans you write in plain text, asks about the details you left out, then files small, well-defined tasks on GitHub that a coding agent can pick up on its own.",
    log: [
      "[09:02] drake  read /specs/billing-v2.md",
      "[09:02] drake  filed your-backend#247 agent:implement",
      "[09:02] drake  filed your-backend#248 agent:implement",
    ],
    state: "live",
  },
  {
    title: "Lucius writes the code",
    body: "Picks up one of those tasks, makes its own copy of the repo to work in, runs Claude Code or Codex with the full project in context, and opens a pull request with tests.",
    log: [
      "[12:04] lucius claimed your-backend#247",
      "[12:04] lucius worktree ~/.alfred/wt/12042118/",
      "[12:18] lucius PR #1247 opened",
    ],
    state: "live",
  },
  {
    title: "Ra's al Ghul reviews the pull request",
    body: "Reads the changes, runs your test suite in its own copy of the repo, leaves comments on the lines that need work, and marks the pull request ready or needs changes.",
    log: [
      "[12:18] ras-al reviewed PR#1247",
      "[12:18] ras-al filed 2 inline nits",
      "[12:19] ras-al labelled needs-changes",
    ],
    state: "warn",
  },
  {
    title: "Batman plans work that spans repos",
    body: "Reads a big feature request, drafts a plan that covers every repo it touches, and posts it to Slack for you to discuss and approve. Once you say yes, it splits the work into tasks and starts each one. Teammates you trust can refine the plan in the thread; only you can approve it.",
    log: [
      "[10:30] batman drafted bundle:billing-v2",
      "[10:31] batman posted plan to Slack for approval",
      "[10:34] operator approved with :white_check_mark:",
      "[10:34] batman filed 4 child issues, opened 4 worktrees",
    ],
    state: "info",
  },
];

const why = [
  {
    title: "Works while you are away",
    body: "On configured schedules, agents check approved GitHub tasks, write the code, open pull requests, and post a short summary to Slack. Use an awake host for overnight work.",
  },
  {
    title: "Runs on a machine you already own",
    body: "There is no cloud service to sign up for and no per-token API bill. Alfred runs on a Mac or Linux computer you already have, using the Claude Code and Codex subscriptions you already pay for.",
  },
  {
    title: "You plan and approve in Slack",
    body: "Planning happens in a Slack thread. Reply with what you want, what should change, or questions of your own, and Alfred turns the discussion into the next task. Nothing big runs until you approve it.",
  },
  {
    title: "Remembers what it learns, once you approve it",
    body: "Alfred keeps notes about each repo on your machine. New lessons wait for your approval before they shape future work, so a wrong guess never gets treated as fact.",
  },
  {
    title: "Works on one repo or many at once",
    body: "Alfred can plan a single feature across several repos at the same time. It works the same way inside a monorepo, whether you use Turborepo, Nx, or Cargo workspaces.",
  },
  {
    title: "Open source, MIT licensed",
    body: "Every line is on GitHub at github.com/luminik-io/alfred-os. Fork it, read it, run it offline, or audit the code. Product telemetry is off unless you opt in.",
  },
];

---

<MarketingLayout
  title="Alfred | Coding agents that work while you are away"
  description="Alfred runs Claude Code and Codex on approved GitHub work from a Mac or Linux host you control. It opens pull requests, routes review, and posts Slack updates while you are away."
  path="/"
>
  <Hero
    eyebrow="AUTONOMOUS CODING AGENTS"
    headline="Keep approved GitHub work moving while you are away."
    sub="You approve the plan. Alfred runs Claude Code and Codex from a machine you control, works in isolated repo copies, opens pull requests, routes review, and posts Slack updates."
    primaryCta={{ label: "Download", href: "/download/", data: { "data-download-os": "other", "data-download-source": "home-hero", "data-download-kind": "intent" } }}
    secondaryCta={{ label: "Install (30 min)", href: "/getting-started/install/" }}
    tertiaryCta={{ label: "GitHub", href: "https://github.com/luminik-io/alfred-os" }}
  >
    <div slot="panel" class="hero-panel">
      <div class="hero-panel__head">
        <span class="m-eyebrow">EXAMPLE STATUS</span>
        <span class="m-mono m-mute">your machine</span>
      </div>
      <MetricRow label="agents" value="21" countTo={21} state="live" />
      <MetricRow label="repos" value="9" countTo={9} state="live" />
      <MetricRow label="last run" value="recent" glyph="arrow" state="info" />
      <MetricRow label="open PRs" value="4" countTo={4} state="warn" />
      <MetricRow label="errors" value="0" state="live" />
    </div>
  </Hero>

  <section class="m-section m-section--soft" id="native-client">
    <div class="m-container">
      <SectionHeader
        eyebrow="THE DESKTOP APP"
        title="See and steer your agents from one desktop app."
        lede="Alfred comes with an optional desktop app. See every agent and what it is working on, check how much of your Claude and Codex usage is left, and start a new request in plain English. Slack is still where you discuss and approve plans."
      />
      <NativeClientShowcase />
      <p style="margin-top:24px;">
        <a class="m-link" href="/concepts/native-client/">How the desktop app works</a>
      </p>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="WHAT IT DOES FOR YOU"
        title="Four agents carry the work from request to merge."
        lede="Each agent has one job, named plainly below. You start with these four and add more, like Bane and Nightwing, when you need them."
      />
      <div class="job-grid">
        {jobs.map((j, i) => (
          <div class={`m-reveal m-reveal-delay-${(i % 4) + 1}`}>
            <JobCard title={j.title} body={j.body} log={j.log} state={j.state} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="WHY ALFRED IS DIFFERENT"
        title="Runs on its own after you approve the work."
        lede="Alfred checks approved GitHub tasks on a schedule, works in isolated repo copies, and comes back with pull requests and Slack summaries when it needs a decision."
      />
      <div class="why-grid">
        {why.map((w, i) => (
          <article class={`m-card m-card--hover m-reveal m-reveal-delay-${(i % 3) + 1}`}>
            <h3 class="m-h3">{w.title}</h3>
            <p style="margin-top:10px;color:var(--alfred-text);font-size:15px;line-height:1.6;">{w.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="m-section m-section--soft" id="memory">
    <div class="m-container">
      <SectionHeader
        eyebrow="LOCAL MEMORY"
        title="Your agents keep a record of each run."
        lede="Alfred keeps notes on your own machine: lessons you have approved, which files agents changed, what went wrong before, and what is in progress right now. You see and approve new lessons in Slack or the desktop app before they ever shape future work."
      />
      <div class="memory-grid">
        <div class="memory-copy">
          <div class="memory-point">
            <span class="memory-point__kicker m-mono">01</span>
            <h3 class="m-h3">Lessons wait for your approval.</h3>
            <p>Agents and trusted teammates can suggest a lesson worth keeping. A suggestion waits for approval before it changes future work. That keeps a wrong guess from becoming part of the system.</p>
          </div>
          <div class="memory-point">
            <span class="memory-point__kicker m-mono">02</span>
            <h3 class="m-h3">Past problems are easy to find.</h3>
            <p>Setup blockers, timeouts, and repeated test failures all land in one place. The next time something breaks, your agents start from what happened before instead of digging back through old Slack messages.</p>
          </div>
          <div class="memory-point">
            <span class="memory-point__kicker m-mono">03</span>
            <h3 class="m-h3">A shared memory server is optional.</h3>
            <p>If you already run the Redis Agent Memory Server, Alfred can connect to it and sync the lessons you have approved. The default setup keeps everything on your machine with nothing extra to install.</p>
          </div>
          <p class="memory-link">
            <a class="m-link" href="/concepts/fleet-brain/">How local memory works</a>
          </p>
        </div>
        <CodeBlock
          title="fleet-brain"
          lines={[
            "$ alfred brain status",
            "ok    lessons              18",
            "ok    memory candidates    4",
            "ok    github items         37",
            "ok    bundle items         6",
            "ok    stale workers        0",
            "",
            "$ alfred brain promotions",
            "12    lucius  owner/api  evidence: PR#248",
            "19    batman  bundle    evidence: issue#504",
            "",
            "$ alfred brain failures --codename huntress",
            "timeout  playwright browser missing  3x",
            "",
            "slack> memory harvest",
            "preview  huntress local setup lesson",
            "slack> memory harvest now",
            "queued   candidate 21",
            "",
            "$ alfred brain redis-sync --dry-run",
            "would sync 18 reviewed lessons",
            "",
            "slack> memory",
            "slack> remember owner/api: keep retry copy testable",
            "slack> memory promote 12",
          ]}
        />
      </div>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="WRITE THE PLAN ONCE"
        title="You write the plan. Alfred turns it into pull requests."
        lede="Write what you want once, in plain text. Drake reads it, asks for the missing details, and files small tasks in the right repos. Lucius picks them up while you work elsewhere."
      />
      <SpecsDrivenFlow />
      <p style="margin-top:24px;">
        <a class="m-link" href="/guides/specs-driven-development/">How writing the plan works</a>
      </p>
    </div>
  </section>

  <section class="m-section m-section--soft" id="batman">
    <div class="m-container">
      <SectionHeader
        eyebrow="THE BATMAN AGENT"
        title="One big feature, planned across every repo it touches."
        lede="Single-repo agents lose the edges of a cross-repo feature. Batman keeps the backend service, web page, mobile screen, and background job in one plan. It posts the plan to Slack for approval, then files one task per repo so Lucius can work in parallel."
      />
      <BatmanFanOut />
      <div class="batman-cta">
        <a class="m-btn" href="/multi-repo/">See planning across repos</a>
        <a class="m-btn m-btn--ghost" href="/guides/multi-repo-worked-example/">Read the worked example</a>
      </div>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="HOW IT WORKS"
        title="One run, from start to finish."
        lede="From the moment a run starts to the pull request it opens. The same five stages happen every time an agent fires."
      />
      <FiringLifecycle />
      <p style="margin-top:32px;">
        <a class="m-link" href="/how-it-works/">See every step in a run</a>
      </p>
    </div>
  </section>

  <section class="m-section m-section--soft" id="real-production">
    <div class="m-container">
      <SectionHeader
        eyebrow="REAL OUTPUT"
        title="What lands in Slack after each run."
        lede="The two Slack posts below are real, captured from one builder's own setup: a Batman plan waiting for approval, and a summary of a day's work. Your own numbers will depend on how many agents you run, how big your repos are, and how much you let the agents do on their own."
      />

      <div class="proof-grid">
        <SlackProof
          src="/proof/slack-batman-plan.png"
          alt="Slack message from the Alfred bot showing Batman drafting a plan for issue #504, with affected repos backend, frontend, mobile, and a rollout order. The plan is in draft, awaiting approval."
          tag="batman plan"
          meta="2026-05-12 11:44 UTC"
          caption="Batman reads one big feature request, drafts a plan across the backend, web, and mobile repos, and posts it to Slack for approval. Once you react with the agreed emoji, Batman files the tasks and starts the work."
        />
        <SlackProof
          src="/proof/slack-shipped-summary.png"
          alt="Slack message from the Alfred bot summarising one day of shipped work: 153 PRs merged, 44 issues opened, 144 issues closed, +44,351 lines added across your-frontend, your-agents, your-mobile, your-nango, your-backend, and your-data-acquisition."
          tag="daily summary"
          meta="2026-05-20 20:45 CET"
          caption="One solo builder's day across six repos. You read this summary in the morning. Every pull request still gets a human review before it merges; how much gets done depends on how many agents you run, how big your repos are, and how small you keep each task."
        />
      </div>

      <p style="margin-top:36px;">
        <a class="m-link" href="/reference/output-samples/">See more examples of what Alfred posts</a>
      </p>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="YOUR AGENTS, RIGHT NOW"
        title="What `alfred status` shows."
        lede="Real output from one builder's setup on 2026-05-23: twenty agents, three paused on purpose, one waiting on a Batman approval, and nothing extra spent on API calls."
      />
      <FleetStatus />
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="GET STARTED"
        title="Try a test run first. Nothing spent, nothing called."
        lede="Check that everything works on your machine with a test run, before any agent touches real work or makes a paid call."
      />
      <CodeBlock
        title="terminal"
        lines={[
          "$ alfred doctor",
          "ok    gh auth                  luminik-io",
          "ok    claude code              authed",
          "ok    codex                    authed (optional)",
          "ok    launchd                  21 agents loaded",
          "ok    spend cap                $20/day fleet",
          "",
          "$ alfred fire lucius --dry-run",
          "ok    preflight passed",
          "ok    worktree would open at ~/.alfred/wt/...",
          "skip  claude_invoke (dry-run)",
          "ok    no spend, no LLM call, runner lifecycle verified",
        ]}
      />
    </div>
  </section>

  <section class="m-section">
    <div class="m-container built-by">
      <SectionHeader
        eyebrow="BUILT BY LUMINIK"
        title="Used every day by the team that built it."
        lede="Luminik runs Alfred across nine repos with 21 agents. They open pull requests every day while the team is away from the keyboard."
      />
      <div class="built-by__panel m-card">
        <div class="built-by__metrics">
          <MetricRow label="agents" value="21" state="live" />
          <MetricRow label="repos" value="9" state="live" />
          <MetricRow label="runs" value="every 20 min" glyph="arrow" state="info" />
          <MetricRow label="people" value="1" state="live" />
        </div>
        <div class="built-by__cta">
          <a class="m-btn" href="/getting-started/install/">Install (30 min)</a>
          <a class="m-btn m-btn--ghost" href="/for-solo-founders/">For solo founders</a>
          <a class="m-btn m-btn--ghost" href="https://github.com/luminik-io/alfred-os">GitHub</a>
        </div>
      </div>
    </div>
  </section>

  <DownloadTracker />
</MarketingLayout>

<style>
  .hero-panel { display: flex; flex-direction: column; }
  .hero-panel__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 12px;
    margin-bottom: 6px;
    border-bottom: 1px solid var(--alfred-border);
  }

  .job-grid {
    display: grid;
    /* minmax(0, 1fr) overrides the default min-content min so cards
       cannot push the grid wider than the parent at 768px. */
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }
  /* Go single-column below 900px so the iPad-portrait (768) view
     stops looking like a half-baked desktop and the cards breathe.
     Keep minmax(0, 1fr) here too: bare 1fr is shorthand for
     minmax(auto, 1fr) which reintroduces min-content. */
  @media (max-width: 900px) { .job-grid { grid-template-columns: minmax(0, 1fr); } }
  /* The reveal wrapper is the actual grid item, so it (not JobCard) needs the
     min-width: 0 that lets the long <pre> log lines scroll inside the card
     instead of forcing min-content width and overflowing the page. */
  .job-grid > :global(.m-reveal) { min-width: 0; }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  @media (max-width: 720px) { .why-grid { grid-template-columns: 1fr; } }

  .memory-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 28px;
    align-items: start;
  }
  .memory-copy {
    display: grid;
    gap: 18px;
  }
  .memory-point {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    column-gap: 16px;
    row-gap: 6px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--alfred-border);
  }
  .memory-point:last-of-type { border-bottom: none; }
  .memory-point__kicker {
    grid-row: span 2;
    color: var(--alfred-accent);
    letter-spacing: 0.16em;
    padding-top: 3px;
  }
  .memory-point p {
    margin: 0;
    color: var(--alfred-text);
    font-size: 15px;
    line-height: 1.6;
  }
  .memory-link { margin: 4px 0 0; }
  @media (max-width: 880px) {
    .memory-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .memory-point {
      grid-template-columns: 1fr;
      row-gap: 8px;
    }
    .memory-point__kicker {
      grid-row: auto;
    }
  }

  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  @media (max-width: 980px) { .steps { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .steps { grid-template-columns: 1fr; } }

  .steps__item {
    background: var(--alfred-surface);
    border: 1px solid var(--alfred-border-strong);
    border-radius: var(--radius);
    padding: 22px;
    position: relative;
  }
  .steps__label {
    color: var(--alfred-accent);
    letter-spacing: 0.18em;
    font-size: 12px;
    margin-bottom: 10px;
  }
  .steps__log {
    margin: 14px 0 0;
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.5;
    color: var(--alfred-mute);
    background: var(--alfred-black);
    border: 1px solid var(--alfred-border);
    border-radius: 6px;
    padding: 10px 12px;
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .built-by__panel { padding: 28px; }
  .built-by__metrics { margin-bottom: 24px; }
  .built-by__cta { display: flex; gap: 14px; flex-wrap: wrap; padding-top: 8px; }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 12px;
  }
  @media (max-width: 880px) { .proof-grid { grid-template-columns: 1fr; } }

  .batman-cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 28px;
  }
</style>
