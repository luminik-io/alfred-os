---
/**
 * Landing page for alfred.luminik.io.
 *
 * Routing decision (binding):
 * The previous landing was a Starlight `splash` template rendered from
 * src/content/docs/index.mdx (slug=""), which owned the root URL.
 *
 * To swap in a fully bespoke marketing landing without breaking the rest of
 * the Starlight docs (which still serve /concepts/, /guides/, /reference/,
 * /about/, /getting-started/), we rename that file to
 * `src/content/docs/docs.mdx` and update the sidebar entry in
 * astro.config.mjs (`slug: ""` → `slug: "docs"`).
 *
 * Astro then serves `src/pages/index.astro` at `/`, and Starlight serves the
 * docs hub at `/docs/`. Every other Starlight URL is unchanged.
 */

import MarketingLayout from "../layouts/MarketingLayout.astro";
import Hero from "../components/marketing/Hero.astro";
import SectionHeader from "../components/marketing/SectionHeader.astro";
import MetricRow from "../components/marketing/MetricRow.astro";
import JobCard from "../components/marketing/JobCard.astro";
import CodeBlock from "../components/marketing/CodeBlock.astro";
import SlackProof from "../components/marketing/SlackProof.astro";
import FiringLifecycle from "../components/marketing/FiringLifecycle.astro";
import FleetStatus from "../components/marketing/FleetStatus.astro";
import SpecsDrivenFlow from "../components/marketing/SpecsDrivenFlow.astro";
import BatmanFanOut from "../components/marketing/BatmanFanOut.astro";
import NativeClientShowcase from "../components/marketing/NativeClientShowcase.astro";
import DownloadTracker from "../components/marketing/DownloadTracker.astro";
import productProof from "../data/luminik-product-proof.json";

type JobState = "live" | "warn" | "idle" | "info";

const jobs: { title: string; body: string; log: string[]; state: JobState }[] = [
  {
    title: "Architect: Batman drives cross-repo features",
    body: "Leads large work that touches more than one repo: reads the parent issue or Slack plan, checks the affected repos, gets approval, files the repo-level work, and keeps the bundle moving.",
    log: [
      "[10:30] batman drafted bundle:billing-v2",
      "[10:31] batman posted plan to Slack",
      "[10:34] scope approved",
      "[10:35] batman opened backend -> web -> mobile tasks",
    ],
    state: "info",
  },
  {
    title: "Senior dev: Lucius opens PRs",
    body: "Picks up a scoped task, makes its own copy of the repo, runs Claude Code or Codex with the full project in context, and opens a pull request with tests.",
    log: [
      "[12:04] lucius claimed your-backend#247",
      "[12:04] lucius worktree ~/.alfred/wt/12042118/",
      "[12:18] lucius PR #1247 opened",
    ],
    state: "live",
  },
  {
    title: "Planner: Drake shapes single-repo work",
    body: "Reads a Slack request, GitHub issue, or plain-text plan, asks for missing details, then files small tasks a coding agent can pick up on its own.",
    log: [
      "[09:02] drake refined settings plan",
      "[09:02] drake filed your-backend#248 agent:implement",
      "[09:03] drake linked acceptance checks",
    ],
    state: "live",
  },
  {
    title: "Reviewer: Ra's al Ghul checks PRs",
    body: "Reads the changes, runs your test suite in its own copy of the repo, leaves comments on the lines that need work, and marks the pull request ready or needs changes.",
    log: [
      "[12:18] ras-al reviewed PR#1247",
      "[12:18] ras-al filed 2 inline nits",
      "[12:19] ras-al labelled needs-changes",
    ],
    state: "warn",
  },
  {
    title: "QA: Bane adds missing tests",
    body: "Looks at recently changed files, finds the places that need coverage, and opens focused test PRs that stand on their own.",
    log: [
      "[15:10] bane found low coverage in billing",
      "[15:23] bane PR #1250 opened",
      "[15:24] bane labelled tests-only",
    ],
    state: "live",
  },
  {
    title: "Fixer: Nightwing handles review comments",
    body: "Finds Alfred PRs with unresolved high-priority review comments, applies the fix in a clean worktree, and pushes the update back to the PR branch.",
    log: [
      "[16:01] nightwing found P1 on PR#1247",
      "[16:08] nightwing pushed fix",
      "[16:09] nightwing asked for re-review",
    ],
    state: "idle",
  },
];

const why = [
  {
    title: "Removes prompt-by-prompt babysitting",
    body: "Alfred finds the next task, hands it to the right role, runs the work in an isolated repo copy, routes review, records memory, and comes back to Slack when a human decision is needed.",
  },
  {
    title: "Runs on a Mac or Linux box you choose",
    body: "A Mac mini, an old MacBook on a dock, or a small Linux box is enough. Alfred runs locally, using the Claude Code and Codex subscriptions you already pay for.",
  },
  {
    title: "You plan and approve in Slack",
    body: "Planning happens in a Slack thread. Reply with what you want, what should change, or questions of your own, and Alfred turns the discussion into the next task. Nothing big runs until you approve it.",
  },
  {
    title: "Remembers what it learns, once you approve it",
    body: "Alfred keeps notes about each repo on your machine. New lessons wait for your approval before they shape future work, so a wrong guess never gets treated as fact.",
  },
  {
    title: "Works on one repo or many at once",
    body: "Alfred can plan a single feature across several repos at the same time. It works the same way inside a monorepo, whether you use Turborepo, Nx, or Cargo workspaces.",
  },
  {
    title: "Open source, MIT licensed",
    body: "Every line is on GitHub at github.com/luminik-io/alfred-os. Fork it, read it, run it locally, or audit the code.",
  },
];

const heroImpactStats = [
  {
    label: "files changed",
    value: productProof.summary.files_changed.toLocaleString("en-US"),
  },
  {
    label: "issues closed",
    value: productProof.summary.agent_issues_closed.toLocaleString("en-US"),
  },
  {
    label: "lines changed",
    value: (productProof.summary.lines_added + productProof.summary.lines_removed).toLocaleString("en-US"),
  },
];

const heroFlow = ["Slack or spec", "Plan", "Build", "Review", "Merge"];

---

<MarketingLayout
  title="Alfred | Autonomous coding agents for lean engineering teams"
  description="Alfred runs Claude Code and Codex from a Mac or Linux box you choose. It turns Slack requests, plans, and GitHub issues into worktrees, pull requests, reviews, safe merges, and Slack updates."
  path="/"
>
  <Hero
    eyebrow="AUTONOMOUS CODING AGENTS"
    headline="Coding agents that keep shipping while you are away."
    sub="Start from a Slack message, GitHub issue, or rough plan. Alfred keeps Claude and Codex moving until there is a PR, review finding, or Slack decision."
    primaryCta={{ label: "Download", href: "/download/", data: { "data-download-os": "other", "data-download-source": "home-hero", "data-download-kind": "intent" } }}
    secondaryCta={{ label: "Install", href: "/getting-started/install/" }}
    tertiaryCta={{ label: "GitHub", href: "https://github.com/luminik-io/alfred-os" }}
  >
    <div
      slot="panel"
      class="hero-impact"
      aria-label={`Alfred impact in the last ${productProof.window.days} days`}
    >
      <div class="hero-impact__head">
        <span class="m-eyebrow">LAST {productProof.window.days} DAYS</span>
        <span class="m-mono m-mute">{productProof.summary.repos_scanned} repos</span>
      </div>

      <div class="hero-impact__primary">
        <strong>{productProof.summary.agent_prs_merged.toLocaleString("en-US")}</strong>
        <span>PRs merged by Alfred-driven work</span>
      </div>

      <div class="hero-impact__stats" role="list">
        {heroImpactStats.map((stat) => (
          <div class="hero-impact__stat" role="listitem">
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        ))}
      </div>

      <div class="hero-flow" aria-label="Alfred work loop">
        <div class="hero-flow__track" aria-hidden="true">
          <span class="hero-flow__pulse"></span>
        </div>
        <ol>
          {heroFlow.map((step) => (
            <li>{step}</li>
          ))}
        </ol>
      </div>

      <div class="hero-agents" aria-label="Primary Alfred agents">
        <span><strong>Batman</strong> Architect</span>
        <span><strong>Lucius</strong> Senior dev</span>
        <span><strong>Drake</strong> Planner</span>
      </div>
    </div>
  </Hero>

  <section class="m-section m-section--soft" id="native-client">
    <div class="m-container">
      <SectionHeader
        eyebrow="THE DESKTOP APP"
        title="See and steer your agents from one desktop app."
        lede="Alfred comes with an optional desktop app. See every agent and what it is working on, check how much of your Claude and Codex usage is left, and start a new request in plain English. Slack is still where you discuss and approve plans."
      />
      <NativeClientShowcase />
      <p style="margin-top:24px;">
        <a class="m-link" href="/concepts/native-client/">How the desktop app works</a>
      </p>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="WHAT IT DOES FOR YOU"
        title="Specialist agents carry work from request to reviewed PR."
        lede="Each agent has one plain job. You can start with planning, implementation, and review, then add test coverage, reviewer-comment fixes, and safe automerge when your process is ready."
      />
      <div class="job-grid">
        {jobs.map((j, i) => (
          <div class={`m-reveal m-reveal-delay-${(i % 4) + 1}`}>
            <JobCard title={j.title} body={j.body} log={j.log} state={j.state} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="WHY ALFRED IS DIFFERENT"
        title="It runs the engineering loop without babysitting."
        lede="Alfred checks the Slack drafts, plans, and GitHub issues you marked for it, works in isolated repo copies, opens pull requests, routes review, and comes back to Slack when it needs a decision."
      />
      <div class="why-grid">
        {why.map((w, i) => (
          <article class={`m-card m-card--hover m-reveal m-reveal-delay-${(i % 3) + 1}`}>
            <h3 class="m-h3">{w.title}</h3>
            <p style="margin-top:10px;color:var(--alfred-text);font-size:15px;line-height:1.6;">{w.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="m-section m-section--soft" id="memory">
    <div class="m-container">
      <SectionHeader
        eyebrow="LOCAL MEMORY"
        title="Your agents keep a record of each run."
        lede="Alfred keeps notes on your own machine: lessons you have approved, which files agents changed, what went wrong before, and what is in progress right now. You see and approve new lessons in Slack or the desktop app before they ever shape future work."
      />
      <div class="memory-grid">
        <div class="memory-copy">
          <div class="memory-point">
            <span class="memory-point__kicker m-mono">01</span>
            <h3 class="m-h3">Lessons wait for your approval.</h3>
            <p>Agents and trusted teammates can suggest a lesson worth keeping. A suggestion waits for approval before it changes future work. That keeps a wrong guess from becoming part of the system.</p>
          </div>
          <div class="memory-point">
            <span class="memory-point__kicker m-mono">02</span>
            <h3 class="m-h3">Past problems are easy to find.</h3>
            <p>Setup blockers, timeouts, and repeated test failures all land in one place. The next time something breaks, your agents start from what happened before instead of digging back through old Slack messages.</p>
          </div>
          <div class="memory-point">
            <span class="memory-point__kicker m-mono">03</span>
            <h3 class="m-h3">Redis memory runs locally.</h3>
            <p>Alfred starts a local Redis Agent Memory Server for recalled lessons, then keeps FleetBrain as the review queue and reliability ledger. The memory loop stays on your machine.</p>
          </div>
          <p class="memory-link">
            <a class="m-link" href="/concepts/fleet-brain/">How local memory works</a>
          </p>
        </div>
        <CodeBlock
          title="fleet-brain"
          lines={[
            "$ alfred brain status",
            "ok    lessons              18",
            "ok    memory candidates    4",
            "ok    github items         37",
            "ok    bundle items         6",
            "ok    stale workers        0",
            "",
            "$ alfred brain promotions",
            "12    lucius  owner/api  evidence: PR#248",
            "19    batman  bundle    evidence: issue#504",
            "",
            "$ alfred brain failures --codename huntress",
            "timeout  playwright browser missing  3x",
            "",
            "slack> memory harvest",
            "preview  huntress local setup lesson",
            "slack> memory harvest now",
            "queued   candidate 21",
            "",
            "$ alfred brain redis-sync --dry-run",
            "would sync 18 reviewed lessons",
            "",
            "slack> memory",
            "slack> remember owner/api: keep retry copy testable",
            "slack> memory promote 12",
          ]}
        />
      </div>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="FROM ROUGH REQUEST TO SCOPED WORK"
        title="Batman architects the rollout. Lucius ships the PRs. Drake keeps smaller work scoped."
        lede="Start with a Slack thread, a GitHub issue, or a plain-text plan. Batman leads multi-repo features, Lucius handles repo-local implementation, and Drake turns smaller requests into clear tasks."
      />
      <SpecsDrivenFlow />
      <p style="margin-top:24px;">
        <a class="m-link" href="/guides/specs-driven-development/">How Alfred helps structure the plan</a>
      </p>
    </div>
  </section>

  <section class="m-section m-section--soft" id="batman">
    <div class="m-container">
      <SectionHeader
        eyebrow="THE ARCHITECT AGENT"
        title="Batman drives cross-repo features end to end."
        lede="Batman is the accountable lead for work that spans repos. It reads the parent issue, checks the affected repos, plans the rollout, gets approval in Slack, opens the repo-level work, and keeps the bundle visible until the implementation fleet can finish it."
      />
      <BatmanFanOut />
      <div class="batman-cta">
        <a class="m-btn" href="/multi-repo/">See planning across repos</a>
        <a class="m-btn m-btn--ghost" href="/guides/multi-repo-worked-example/">Read the worked example</a>
      </div>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="HOW IT WORKS"
        title="One run, from start to finish."
        lede="From the moment a run starts to the pull request it opens. The same five stages happen every time an agent fires."
      />
      <FiringLifecycle />
      <p style="margin-top:32px;">
        <a class="m-link" href="/how-it-works/">See every step in a run</a>
      </p>
    </div>
  </section>

  <section class="m-section m-section--soft" id="real-production">
    <div class="m-container">
      <SectionHeader
        eyebrow="SLACK-NATIVE PLANNING"
        title="Talk to Alfred where your team already talks."
        lede="Slack is the planning and control surface. Trusted users can start requests, refine plans in a thread, approve big work, ask for status, pause agents, and keep context attached to the work. Slack never bypasses the approval gates."
      />

      <div class="proof-grid">
        <SlackProof
          src="/proof/slack-batman-plan.png"
          alt="Slack message from the Alfred bot showing Batman drafting a plan for issue #504, with affected repos backend, frontend, mobile, and a rollout order. The plan is in draft, awaiting approval."
          tag="batman plan"
          meta="2026-05-12 11:44 UTC"
          caption="Batman reads one big feature request, plans the backend, web, and mobile rollout, gets approval in Slack, then opens scoped tasks for the implementation fleet."
        />
        <SlackProof
          src="/proof/slack-shipped-summary.png"
          alt="Slack message from the Alfred bot summarising one private Luminik setup: 153 PRs merged, 44 issues opened, 144 issues closed, and 44,351 lines added across six repos."
          tag="daily summary"
          meta="2026-05-20 20:45 CET"
          caption="A real Luminik setup summary across six repos. The impact page keeps the current totals up to date."
        />
      </div>

      <p style="margin-top:36px;">
        <a class="m-link" href="/reference/output-samples/">See more examples of what Alfred posts</a>
      </p>
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="YOUR AGENTS, RIGHT NOW"
        title="What `alfred status` shows."
        lede="Real output from one builder's setup on 2026-05-23: twenty agents, three paused on purpose, and one waiting on a Batman approval."
      />
      <FleetStatus />
    </div>
  </section>

  <section class="m-section">
    <div class="m-container">
      <SectionHeader
        eyebrow="GET STARTED"
        title="Check the wiring before real work starts."
        lede="Run doctor for setup health, then dry-run one agent to see the path it would take without touching GitHub, Slack, an engine, or your files."
      />
      <CodeBlock
        title="terminal"
        lines={[
          "$ alfred doctor",
          "ok    gh auth                  luminik-io",
          "ok    claude code              authed",
          "ok    codex                    authed (optional)",
          "ok    launchd                  21 agents loaded",
          "ok    spend cap                $20/day fleet",
          "",
          "$ alfred dry-run lucius",
          "alfred dry-run: lucius",
          "  role: feature dev",
          "  mode: safe simulation",
          "  would: resolve config, acquire the agent lock, run preflight, and enter the runner",
          "  would not: mutate GitHub, post Slack, invoke an engine, or edit files",
        ]}
      />
    </div>
  </section>

  <section class="m-section">
    <div class="m-container built-by">
      <SectionHeader
        eyebrow="BUILT BY LUMINIK"
        title="Used every day by Luminik."
        lede={`In the last ${productProof.window.days} days, Alfred helped merge ${productProof.summary.agent_prs_merged.toLocaleString("en-US")} PRs across ${productProof.summary.repos_scanned} Luminik repos. The impact page shows aggregate product totals and public examples.`}
      />
      <div class="built-by__panel m-card">
        <div class="built-by__metrics">
          <MetricRow label="Alfred PRs" value={productProof.summary.agent_prs_merged.toLocaleString("en-US")} state="live" />
          <MetricRow label="Alfred issues" value={productProof.summary.agent_issues_opened.toLocaleString("en-US")} state="live" />
          <MetricRow label="files changed" value={productProof.summary.files_changed.toLocaleString("en-US")} state="info" />
          <MetricRow label="repos" value={productProof.summary.repos_scanned.toLocaleString("en-US")} state="live" />
        </div>
        <div class="built-by__cta">
          <a class="m-btn" href="/install/">Pick an install path</a>
          <a class="m-btn m-btn--ghost" href="/impact/">See what shipped</a>
          <a class="m-btn m-btn--ghost" href="/for-solo-founders/">For solo founders</a>
          <a class="m-btn m-btn--ghost" href="https://github.com/luminik-io/alfred-os">GitHub</a>
        </div>
      </div>
    </div>
  </section>

  <DownloadTracker />
</MarketingLayout>

<style>
  .hero-impact {
    display: grid;
    gap: 18px;
  }
  .hero-impact__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--alfred-border);
    gap: 16px;
  }
  .hero-impact__primary {
    display: grid;
    gap: 8px;
  }
  .hero-impact__primary strong {
    display: block;
    color: var(--alfred-accent);
    font-size: clamp(56px, 8vw, 86px);
    line-height: 0.92;
    letter-spacing: 0;
    font-weight: 750;
  }
  .hero-impact__primary span {
    color: var(--alfred-text-bright);
    font-size: 18px;
    line-height: 1.35;
    font-weight: 600;
  }
  .hero-impact__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    border-block: 1px solid var(--alfred-border);
  }
  .hero-impact__stat {
    min-width: 0;
    padding: 14px 12px;
    border-right: 1px solid var(--alfred-border);
  }
  .hero-impact__stat:last-child { border-right: none; }
  .hero-impact__stat strong {
    display: block;
    color: var(--alfred-text-bright);
    font-size: 21px;
    line-height: 1.1;
    letter-spacing: 0;
    white-space: nowrap;
  }
  .hero-impact__stat span {
    display: block;
    margin-top: 6px;
    color: var(--alfred-mute);
    font-size: 12px;
    line-height: 1.35;
    text-transform: lowercase;
  }
  .hero-flow {
    position: relative;
    padding-top: 12px;
  }
  .hero-flow__track {
    position: absolute;
    top: 23px;
    left: 10px;
    right: 10px;
    height: 2px;
    background: linear-gradient(90deg, rgba(0,229,199,0.18), rgba(87,137,255,0.28), rgba(0,229,199,0.18));
    overflow: hidden;
  }
  .hero-flow__pulse {
    position: absolute;
    inset-block: -1px;
    width: 34%;
    background: linear-gradient(90deg, transparent, var(--alfred-accent), transparent);
    animation: hero-flow-pulse 4.5s ease-in-out infinite;
  }
  .hero-flow ol {
    position: relative;
    z-index: 1;
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 8px;
  }
  .hero-flow li {
    display: grid;
    justify-items: center;
    gap: 8px;
    min-width: 0;
    color: var(--alfred-text);
    font-size: 12px;
    line-height: 1.25;
    text-align: center;
  }
  .hero-flow li::before {
    content: "";
    width: 12px;
    height: 12px;
    border-radius: 999px;
    background: var(--alfred-surface);
    border: 2px solid var(--alfred-accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--alfred-accent) 12%, transparent);
  }
  .hero-agents {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .hero-agents span {
    display: inline-flex;
    gap: 6px;
    align-items: center;
    min-height: 32px;
    padding: 6px 10px;
    border: 1px solid var(--alfred-border);
    border-radius: 999px;
    color: var(--alfred-text);
    font-size: 12px;
    line-height: 1.2;
  }
  .hero-agents strong {
    color: var(--alfred-text-bright);
    font-weight: 700;
  }
  @keyframes hero-flow-pulse {
    0% { transform: translateX(-110%); opacity: 0; }
    12% { opacity: 1; }
    88% { opacity: 1; }
    100% { transform: translateX(310%); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-flow__pulse { animation: none; opacity: 0; }
  }
  @media (max-width: 480px) {
    .hero-impact__head {
      align-items: flex-start;
      flex-direction: column;
      gap: 6px;
    }
    .hero-impact__stats {
      grid-template-columns: 1fr;
    }
    .hero-impact__stat {
      border-right: none;
      border-bottom: 1px solid var(--alfred-border);
    }
    .hero-impact__stat:last-child { border-bottom: none; }
    .hero-flow ol {
      grid-template-columns: repeat(5, minmax(42px, 1fr));
      overflow-x: auto;
      padding-bottom: 4px;
    }
  }

  .job-grid {
    display: grid;
    /* minmax(0, 1fr) overrides the default min-content min so cards
       cannot push the grid wider than the parent at 768px. */
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }
  /* Go single-column below 900px so the iPad-portrait (768) view
     stops looking like a half-baked desktop and the cards breathe.
     Keep minmax(0, 1fr) here too: bare 1fr is shorthand for
     minmax(auto, 1fr) which reintroduces min-content. */
  @media (max-width: 900px) { .job-grid { grid-template-columns: minmax(0, 1fr); } }
  /* The reveal wrapper is the actual grid item, so it (not JobCard) needs the
     min-width: 0 that lets the long <pre> log lines scroll inside the card
     instead of forcing min-content width and overflowing the page. */
  .job-grid > :global(.m-reveal) { min-width: 0; }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
