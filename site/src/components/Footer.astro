---
// Wraps Starlight's default page footer (last-updated, pagination, edit link)
// and adds a slim copyright bar after the page content so it never covers the
// docs text on any viewport.
// Copyright holder matches the repo LICENSE file: DataRavel Inc.
// Styling lives in src/styles/custom.css (.alfred-copyright-bar) so it is
// reliably applied globally rather than depending on component-scoped CSS.
import Default from "@astrojs/starlight/components/Footer.astro";
---

<Default />
<div class="alfred-copyright-bar">
