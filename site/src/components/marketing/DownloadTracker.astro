---
/**
 * DownloadTracker.astro
 *
 * Drop this once on any page that has download buttons or links that lead to
 * a download. It wires a click handler to every element carrying a
 * data-download-os attribute and sends one GA4 event per click, reading os
 * and source from the button's data- attributes:
 *
 *   <a href="..." data-download-os="macos" data-download-source="download-page">
 *
 * Two kinds of click are tracked, set by data-download-kind:
 *
 *   - "asset"  (the default): a button that points at a release/download.
 *               Fires the GA4 "download" event, which feeds the download count.
 *   - "intent": a link that only routes to the download page (e.g. the home
 *               page "Download" CTA). Fires "select_content" instead, so a
 *               navigation click is never counted as a real download.
 *
 * The split keeps the download number honest: only buttons on the download
 * page that actually point at a release fire "download". A homepage CTA that
 * just sends the visitor to /download/ fires "select_content".
 *
 * It mirrors how the rest of the site calls analytics (window.gtag, which
 * MarketingLayout defines and pushes onto dataLayer) and respects the same
 * cookie-consent gate. With Google Consent Mode v2 sitting in default-denied,
 * any event sent before the visitor accepts is dropped anyway; the explicit
 * consent check keeps the intent obvious and sends nothing for a visitor who
 * declined.
 *
 * No download count or number is ever read or shown. This is click tracking
 * only.
 */
---

<script is:inline>
  (function () {
    if (typeof document === "undefined") return;

    function consentGranted() {
      try {
        return localStorage.getItem("alfred-cookie-consent") === "allow";
      } catch (e) {
        return false;
      }
    }

    document.querySelectorAll("[data-download-os]").forEach(function (el) {
      el.addEventListener("click", function () {
        if (!consentGranted()) return;
        if (typeof window.gtag !== "function") return;

        var kind = el.getAttribute("data-download-kind") || "asset";
        var os = el.getAttribute("data-download-os") || "other";
        var source = el.getAttribute("data-download-source") || "unknown";

        if (kind === "intent") {
          // A link that only routes to the download page. Record the click
          // as content selection so it never inflates the download count.
          window.gtag("event", "select_content", {
            content_type: "download_intent",
            os: os,
            source: source,
          });
          return;
        }

        // A real release/download button.
        window.gtag("event", "download", { os: os, source: source });
      });
    });
  })();
</script>
