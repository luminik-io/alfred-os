---
interface ProofPr {
  number: number;
  title: string;
  url: string;
  merged_at: string;
  lines_added: number;
  lines_removed: number;
  files_changed: number;
  agent_authored?: boolean;
}

interface ProofIssue {
  number: number;
  title: string;
  url: string;
  state: string;
  created_at: string;
  closed_at?: string | null;
}

interface ProofData {
  generated_at: string;
  source: { repo: string; url: string; note: string };
  window: { days: number; from: string; to: string };
  summary: {
    prs_merged: number;
    issues_opened: number;
    issues_closed: number;
    issues_triaged: number;
    lines_added: number;
    lines_removed: number;
    files_changed: number;
    repo_activity?: {
      prs_merged: number;
      issues_opened: number;
      issues_closed: number;
      lines_added: number;
      lines_removed: number;
      files_changed: number;
    };
  };
  trend: Array<{ week: string; prs_merged: number }>;
  prs: ProofPr[];
  issues: ProofIssue[];
}

interface Props {
  proof: ProofData;
}

const { proof } = Astro.props;
const fmt = (n: number) => n.toLocaleString("en-US");
const maxTrend = Math.max(...proof.trend.map((item) => item.prs_merged), 1);
const windowLabel = `Last ${proof.window.days} days`;
const hasAlfredRows =
  proof.prs.length > 0 ||
  proof.issues.length > 0 ||
  proof.summary.prs_merged > 0 ||
  proof.summary.issues_opened > 0 ||
  proof.summary.issues_triaged > 0;
const activity = hasAlfredRows || !proof.summary.repo_activity
  ? proof.summary
  : proof.summary.repo_activity;
const metricDetail = hasAlfredRows ? windowLabel : "repo activity";
const codeDetail = hasAlfredRows ? "listed PRs" : "repo activity";
const sectionLabel = hasAlfredRows ? "Public Alfred shipping record" : "Public repo activity";
const heading = hasAlfredRows ? "Open-source Alfred work." : "Open-source repo activity.";

const metrics = [
  {
    label: "PRs merged",
    value: fmt(activity.prs_merged),
    detail: metricDetail,
  },
  {
    label: "Issues opened",
    value: fmt(activity.issues_opened),
    detail: metricDetail,
  },
  {
    label: "Lines added",
    value: fmt(activity.lines_added),
    detail: codeDetail,
  },
  {
    label: "Files changed",
    value: fmt(activity.files_changed),
    detail: codeDetail,
  },
];
---

<section class="proof-board" aria-label={sectionLabel}>
  <div class="proof-board__meta">
    <div>
      <span class="m-eyebrow">OPEN-SOURCE REPO</span>
      <h2 class="m-display-md">{heading}</h2>
    </div>
    <p>
      {hasAlfredRows ? "Recent public Alfred work from " : "Recent activity in "}
      <a href={proof.source.url} rel="noopener noreferrer">{proof.source.repo}</a>.
      {!hasAlfredRows ? " Alfred examples appear here once public PRs or issues carry Alfred labels." : ""}
    </p>
  </div>

  <div class="proof-metrics" role="list">
    {metrics.map((metric) => (
      <article class="proof-metric" role="listitem">
        <span class="proof-metric__value">{metric.value}</span>
        <span class="proof-metric__label">{metric.label}</span>
        <span class="proof-metric__detail">{metric.detail}</span>
      </article>
    ))}
  </div>

  {hasAlfredRows ? (
    <>
      <div class="proof-layout">
        <section class="proof-panel" aria-label="Weekly merged pull requests">
          <div class="proof-panel__head">
            <h3 class="m-h3">Weekly PRs merged</h3>
            <span class="m-mono m-mute">Last {proof.window.days} days</span>
          </div>
          <div class="trend" role="list">
            {proof.trend.length > 0 ? (
              proof.trend.map((item) => (
                <div class="trend__row" role="listitem">
                  <span class="trend__week m-mono">{item.week}</span>
                  <span class="trend__bar" style={`--w:${Math.max(8, Math.round((item.prs_merged / maxTrend) * 100))}%`}>
                    <span></span>
                  </span>
                  <span class="trend__count">{fmt(item.prs_merged)}</span>
                </div>
              ))
            ) : (
              <p class="proof-empty">No public PRs in the last {proof.window.days} days.</p>
            )}
          </div>
        </section>

        <section class="proof-panel" aria-label="Recently opened issues">
          <div class="proof-panel__head">
            <h3 class="m-h3">Recent Alfred issues</h3>
            <span class="m-mono m-mute">{fmt(proof.summary.issues_triaged)} triaged</span>
          </div>
          <div class="issue-list">
            {proof.issues.length > 0 ? (
              proof.issues.slice(0, 5).map((issue) => (
                <a class="issue-row" href={issue.url} rel="noopener noreferrer">
                  <span class="issue-row__num m-mono">#{issue.number}</span>
                  <span class="issue-row__title">{issue.title}</span>
                </a>
              ))
            ) : (
              <p class="proof-empty">No public issues in the last {proof.window.days} days.</p>
            )}
          </div>
        </section>
      </div>

      <section class="proof-panel proof-panel--wide" aria-label="Recent merged pull requests">
        <div class="proof-panel__head">
          <h3 class="m-h3">Recent merged PRs</h3>
          <span class="m-mono m-mute">GitHub links</span>
        </div>
        <div class="pr-list">
          {proof.prs.length > 0 ? (
            proof.prs.map((pr) => (
              <a class="pr-row" href={pr.url} rel="noopener noreferrer">
                <span class="pr-row__num m-mono">#{pr.number}</span>
                <span class="pr-row__title">{pr.title}</span>
                <span class="pr-row__stats m-mono">
                  +{fmt(pr.lines_added)} / -{fmt(pr.lines_removed)}, {fmt(pr.files_changed)} files
                </span>
              </a>
            ))
          ) : (
            <p class="proof-empty">No public PRs in the last {proof.window.days} days.</p>
          )}
        </div>
      </section>
    </>
  ) : null}

  <p class="proof-note">
    Line counts come from GitHub additions and deletions.
  </p>
</section>

<style>
  .proof-board {
    display: grid;
    gap: 24px;
  }

  .proof-board__meta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.55fr);
    gap: 24px;
    align-items: end;
  }

  .proof-board__meta h2 {
    margin-top: 12px;
  }

  .proof-board__meta p,
  .proof-note {
    color: var(--alfred-text);
    font-size: 15px;
    line-height: 1.6;
  }

  .proof-metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  .proof-metric,
  .proof-panel {
    background: var(--alfred-surface);
    border: 1px solid var(--alfred-border-strong);
    border-radius: var(--radius);
  }

  .proof-metric {
    min-width: 0;
    padding: 18px;
    display: grid;
    gap: 4px;
  }

  .proof-metric__value {
    color: var(--alfred-text-bright);
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 700;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .proof-metric__label {
    color: var(--alfred-text-bright);
    font-weight: 700;
  }

  .proof-metric__detail {
    color: var(--alfred-mute);
    font-size: 13px;
  }

  .proof-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.9fr);
    gap: 18px;
  }

  .proof-panel {
    min-width: 0;
    padding: 20px;
  }

  .proof-panel__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--alfred-border);
  }

  .trend,
  .issue-list,
  .pr-list {
    display: grid;
    gap: 10px;
    margin-top: 16px;
  }

  .trend__row {
    display: grid;
    grid-template-columns: 84px minmax(0, 1fr) 44px;
    gap: 12px;
    align-items: center;
  }

  .trend__week,
  .trend__count {
    color: var(--alfred-mute);
    font-size: 12px;
  }

  .trend__count {
    text-align: right;
    color: var(--alfred-text);
    font-variant-numeric: tabular-nums;
  }

  .trend__bar {
    height: 10px;
    border-radius: 999px;
    background: var(--alfred-surface-2);
    overflow: hidden;
  }

  .trend__bar span {
    display: block;
    width: var(--w);
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--alfred-accent), var(--alfred-blue));
  }

  .issue-row,
  .pr-row {
    min-width: 0;
    display: grid;
    align-items: center;
    gap: 12px;
    color: var(--alfred-text);
    border: 1px solid var(--alfred-border);
    border-radius: var(--radius);
    padding: 12px;
  }

  .issue-row {
    grid-template-columns: 56px minmax(0, 1fr);
  }

  .pr-row {
    grid-template-columns: 64px minmax(0, 1fr) max-content;
  }

  .issue-row:hover,
  .pr-row:hover {
    text-decoration: none;
    border-color: var(--alfred-border-strong);
    background: var(--alfred-surface-2);
  }

  .issue-row__num,
  .pr-row__num {
    color: var(--alfred-accent);
    font-size: 12px;
  }

  .issue-row__title,
  .pr-row__title {
    min-width: 0;
    color: var(--alfred-text-bright);
    font-size: 14px;
    line-height: 1.4;
    overflow-wrap: anywhere;
  }

  .pr-row__stats {
    color: var(--alfred-mute);
    font-size: 12px;
    white-space: nowrap;
  }

  .proof-note {
    color: var(--alfred-mute);
    margin: 0;
    max-width: 76ch;
  }

  .proof-empty {
    color: var(--alfred-mute);
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 980px) {
    .proof-board__meta,
    .proof-layout {
      grid-template-columns: 1fr;
    }

    .proof-metrics {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .pr-row {
      grid-template-columns: 56px minmax(0, 1fr);
    }

    .pr-row__stats {
      grid-column: 2;
    }
  }

  @media (max-width: 560px) {
    .proof-metrics {
      grid-template-columns: 1fr;
    }

    .proof-panel__head {
      align-items: flex-start;
      flex-direction: column;
    }

    .trend__row {
      grid-template-columns: 72px minmax(0, 1fr) 34px;
      gap: 8px;
    }
  }
</style>
