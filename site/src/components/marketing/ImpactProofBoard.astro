---
interface ProofPr {
  number: number;
  title: string;
  url: string;
  merged_at: string;
  lines_added: number;
  lines_removed: number;
  files_changed: number;
  agent_authored?: boolean;
}

interface ProofIssue {
  number: number;
  title: string;
  url: string;
  state: string;
  created_at: string;
  closed_at?: string | null;
}

interface ProofData {
  generated_at: string;
  source: { repo: string; url: string; note: string };
  window: { days: number; from: string; to: string };
  summary: {
    prs_merged: number;
    issues_opened: number;
    issues_closed: number;
    issues_triaged: number;
    lines_added: number;
    lines_removed: number;
    files_changed: number;
    repo_activity?: {
      prs_merged: number;
      issues_opened: number;
      issues_closed: number;
      lines_added: number;
      lines_removed: number;
      files_changed: number;
    };
  };
  trend: Array<{ week: string; prs_merged: number }>;
  prs: ProofPr[];
  issues: ProofIssue[];
}

interface Props {
  proof: ProofData;
}

const { proof } = Astro.props;
const fmt = (n: number) => n.toLocaleString("en-US");
const day = (raw: string) => new Date(raw).toISOString().slice(0, 10);
const generated = day(proof.generated_at);
const maxTrend = Math.max(...proof.trend.map((item) => item.prs_merged), 1);
const hasRuntimeProof =
  proof.summary.prs_merged > 0 ||
  proof.summary.issues_opened > 0 ||
  proof.summary.issues_triaged > 0;

const metrics = [
  {
    label: "Alfred runtime PRs merged",
    value: fmt(proof.summary.prs_merged),
    detail: "Runtime branch or shipped label",
  },
  {
    label: "Agent-labeled issues opened",
    value: fmt(proof.summary.issues_opened),
    detail: "Alfred agent labels only",
  },
  {
    label: "Lines added",
    value: fmt(proof.summary.lines_added),
    detail: `${fmt(proof.summary.lines_removed)} removed`,
  },
  {
    label: "Files changed",
    value: fmt(proof.summary.files_changed),
    detail: "GitHub diff stats",
  },
];
---

<section class="proof-board" aria-label="Public Alfred OS shipping proof">
  <div class="proof-board__meta">
    <div>
      <span class="m-eyebrow">PUBLIC GITHUB PROOF</span>
      <h2 class="m-display-md">Public PRs Alfred can prove.</h2>
    </div>
    <p>
      Rolling {proof.window.days}-day window from{" "}
      <a href={proof.source.url} rel="noopener noreferrer">{proof.source.repo}</a>.
      PRs need an Alfred branch prefix or shipped label, and Dependabot is excluded.
      Issues need an Alfred agent label.
      Updated {generated}.
    </p>
  </div>

  {!hasRuntimeProof && proof.summary.repo_activity ? (
    <div class="proof-callout" role="note">
      <span class="m-eyebrow">STRICT FILTER EMPTY</span>
      <p>
        No public PR or issue matched the Alfred runtime filter in this window.
        The whole public repo still merged {fmt(proof.summary.repo_activity.prs_merged)} PRs.
        Alfred keeps those numbers separate until the GitHub evidence is visible.
      </p>
    </div>
  ) : null}

  <div class="proof-metrics" role="list">
    {metrics.map((metric) => (
      <article class="proof-metric" role="listitem">
        <span class="proof-metric__value">{metric.value}</span>
        <span class="proof-metric__label">{metric.label}</span>
        <span class="proof-metric__detail">{metric.detail}</span>
      </article>
    ))}
  </div>

  <div class="proof-layout">
    <section class="proof-panel" aria-label="Weekly merged pull requests">
      <div class="proof-panel__head">
        <h3 class="m-h3">Weekly Alfred runtime PRs merged</h3>
        <span class="m-mono m-mute">{day(proof.window.from)} to {day(proof.window.to)}</span>
      </div>
      <div class="trend" role="list">
        {proof.trend.length > 0 ? (
          proof.trend.map((item) => (
            <div class="trend__row" role="listitem">
              <span class="trend__week m-mono">{item.week}</span>
              <span class="trend__bar" style={`--w:${Math.max(8, Math.round((item.prs_merged / maxTrend) * 100))}%`}>
                <span></span>
              </span>
              <span class="trend__count">{fmt(item.prs_merged)}</span>
            </div>
          ))
        ) : (
          <p class="proof-empty">No merged PRs matched Alfred runtime evidence in this window.</p>
        )}
      </div>
    </section>

    <section class="proof-panel" aria-label="Recently opened issues">
      <div class="proof-panel__head">
        <h3 class="m-h3">Recent agent-labeled issues</h3>
        <span class="m-mono m-mute">{fmt(proof.summary.issues_triaged)} triaged</span>
      </div>
      <div class="issue-list">
        {proof.issues.length > 0 ? (
          proof.issues.slice(0, 5).map((issue) => (
            <a class="issue-row" href={issue.url} rel="noopener noreferrer">
              <span class="issue-row__num m-mono">#{issue.number}</span>
              <span class="issue-row__title">{issue.title}</span>
            </a>
          ))
        ) : (
          <p class="proof-empty">No Alfred-labeled issues in this public window yet.</p>
        )}
      </div>
    </section>
  </div>

  <section class="proof-panel proof-panel--wide" aria-label="Recent merged pull requests">
    <div class="proof-panel__head">
      <h3 class="m-h3">Recent merged Alfred runtime PRs</h3>
      <span class="m-mono m-mute">filtered list</span>
    </div>
    <div class="pr-list">
      {proof.prs.length > 0 ? (
        proof.prs.map((pr) => (
          <a class="pr-row" href={pr.url} rel="noopener noreferrer">
            <span class="pr-row__num m-mono">#{pr.number}</span>
            <span class="pr-row__title">{pr.title}</span>
            <span class="pr-row__stats m-mono">
              +{fmt(pr.lines_added)} / -{fmt(pr.lines_removed)}, {fmt(pr.files_changed)} files
            </span>
          </a>
        ))
      ) : (
        <p class="proof-empty">No public PR links matched the Alfred runtime filter in this window.</p>
      )}
    </div>
  </section>

  <p class="proof-note">
    Lines are GitHub additions and deletions on filtered Alfred runtime PRs.
    Generated files and lockfiles are included because GitHub counts them in PR stats.
    {proof.summary.repo_activity ? (
      <>
        {" "}The whole public repo merged {fmt(proof.summary.repo_activity.prs_merged)} PRs in the same window; those broader numbers stay separate from Alfred runtime proof.
      </>
    ) : null}
  </p>
</section>

<style>
  .proof-board {
    display: grid;
    gap: 24px;
  }

  .proof-board__meta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.55fr);
    gap: 24px;
    align-items: end;
  }

  .proof-board__meta h2 {
    margin-top: 12px;
  }

  .proof-board__meta p,
  .proof-note {
    color: var(--alfred-text);
    font-size: 15px;
    line-height: 1.6;
  }

  .proof-metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  .proof-callout,
  .proof-metric,
  .proof-panel {
    background: var(--alfred-surface);
    border: 1px solid var(--alfred-border-strong);
    border-radius: var(--radius);
  }

  .proof-callout {
    padding: 18px 20px;
  }

  .proof-callout p {
    margin: 8px 0 0;
    color: var(--alfred-text);
    font-size: 15px;
    line-height: 1.6;
  }

  .proof-metric {
    min-width: 0;
    padding: 18px;
    display: grid;
    gap: 4px;
  }

  .proof-metric__value {
    color: var(--alfred-text-bright);
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 700;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .proof-metric__label {
    color: var(--alfred-text-bright);
    font-weight: 700;
  }

  .proof-metric__detail {
    color: var(--alfred-mute);
    font-size: 13px;
  }

  .proof-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.9fr);
    gap: 18px;
  }

  .proof-panel {
    min-width: 0;
    padding: 20px;
  }

  .proof-panel__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--alfred-border);
  }

  .trend,
  .issue-list,
  .pr-list {
    display: grid;
    gap: 10px;
    margin-top: 16px;
  }

  .trend__row {
    display: grid;
    grid-template-columns: 84px minmax(0, 1fr) 44px;
    gap: 12px;
    align-items: center;
  }

  .trend__week,
  .trend__count {
    color: var(--alfred-mute);
    font-size: 12px;
  }

  .trend__count {
    text-align: right;
    color: var(--alfred-text);
    font-variant-numeric: tabular-nums;
  }

  .trend__bar {
    height: 10px;
    border-radius: 999px;
    background: var(--alfred-surface-2);
    overflow: hidden;
  }

  .trend__bar span {
    display: block;
    width: var(--w);
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--alfred-accent), var(--alfred-blue));
  }

  .issue-row,
  .pr-row {
    min-width: 0;
    display: grid;
    align-items: center;
    gap: 12px;
    color: var(--alfred-text);
    border: 1px solid var(--alfred-border);
    border-radius: var(--radius);
    padding: 12px;
  }

  .issue-row {
    grid-template-columns: 56px minmax(0, 1fr);
  }

  .pr-row {
    grid-template-columns: 64px minmax(0, 1fr) max-content;
  }

  .issue-row:hover,
  .pr-row:hover {
    text-decoration: none;
    border-color: var(--alfred-border-strong);
    background: var(--alfred-surface-2);
  }

  .issue-row__num,
  .pr-row__num {
    color: var(--alfred-accent);
    font-size: 12px;
  }

  .issue-row__title,
  .pr-row__title {
    min-width: 0;
    color: var(--alfred-text-bright);
    font-size: 14px;
    line-height: 1.4;
    overflow-wrap: anywhere;
  }

  .pr-row__stats {
    color: var(--alfred-mute);
    font-size: 12px;
    white-space: nowrap;
  }

  .proof-note {
    color: var(--alfred-mute);
    margin: 0;
    max-width: 76ch;
  }

  .proof-empty {
    color: var(--alfred-mute);
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 980px) {
    .proof-board__meta,
    .proof-layout {
      grid-template-columns: 1fr;
    }

    .proof-metrics {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .pr-row {
      grid-template-columns: 56px minmax(0, 1fr);
    }

    .pr-row__stats {
      grid-column: 2;
    }
  }

  @media (max-width: 560px) {
    .proof-metrics {
      grid-template-columns: 1fr;
    }

    .proof-panel__head {
      align-items: flex-start;
      flex-direction: column;
    }

    .trend__row {
      grid-template-columns: 72px minmax(0, 1fr) 34px;
      gap: 8px;
    }
  }
</style>
