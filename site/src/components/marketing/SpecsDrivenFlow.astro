---
/**
 * SpecsDrivenFlow.astro
 *
 * Inline SVG illustration: a rough request or plan becomes scoped
 * agent:implement issues, then PRs. Mirrors the Operations Room aesthetic
 * (themed cards, log lines, soft accent pulse). Used on the landing page
 * specs-driven section and on /docs/guides/specs-driven-development/.
 *
 * No JS. Pure SVG + CSS animation. Reduced-motion safe.
 * Theme-aware via .svg-* classes defined in marketing.css.
 */
---

<figure class="m-spec m-figure m-reveal" aria-label="One request becomes scoped issues and PRs">
  <div class="m-spec__head">
    <span class="m-mono m-spec__tag">PLAN-TO-PR FLOW</span>
    <span class="m-mono m-spec__meta">request &nbsp;→&nbsp; drake &nbsp;→&nbsp; agent:implement &nbsp;→&nbsp; PR</span>
  </div>

  <svg viewBox="0 0 1180 380" role="img" aria-hidden="false" class="m-spec__svg" preserveAspectRatio="xMidYMid meet">
    <defs>
      <linearGradient id="specLine" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%"   stop-color="#00E5C7" stop-opacity="0.0" />
        <stop offset="50%"  stop-color="#00E5C7" stop-opacity="0.9" />
        <stop offset="100%" stop-color="#00E5C7" stop-opacity="0.0" />
      </linearGradient>
      <filter id="specShadow" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="0" dy="6" stdDeviation="8" flood-color="#000" flood-opacity="0.45" />
      </filter>
    </defs>

    <!-- Request / plan card -->
    <g transform="translate(40 70)" filter="url(#specShadow)">
      <rect width="280" height="240" rx="8" ry="8" class="svg-card svg-card-stroke" />
      <text x="22" y="34" font-family="'Fragment Mono', monospace" font-size="11" class="svg-warn" letter-spacing="2">slack thread or plan.md</text>
      <text x="22" y="64" font-family="'Quicksand Variable', sans-serif" font-size="16" font-weight="700" class="svg-text-bright">## What</text>
      <text x="22" y="84" font-family="'Fragment Mono', monospace" font-size="12" class="svg-text">Org-scoped billing v2.</text>
      <text x="22" y="120" font-family="'Quicksand Variable', sans-serif" font-size="16" font-weight="700" class="svg-text-bright">## Acceptance</text>
      <text x="22" y="140" font-family="'Fragment Mono', monospace" font-size="12" class="svg-text">- /api/v1/invoices by org</text>
      <text x="22" y="158" font-family="'Fragment Mono', monospace" font-size="12" class="svg-text">- Cost page rewrite</text>
      <text x="22" y="176" font-family="'Fragment Mono', monospace" font-size="12" class="svg-text">- Mobile settings v2</text>
      <text x="22" y="210" font-family="'Fragment Mono', monospace" font-size="11" class="svg-mute">human starts, Alfred scopes</text>
    </g>

    <!-- Drake step -->
    <g transform="translate(440 145)" filter="url(#specShadow)">
      <rect width="180" height="90" rx="8" ry="8" class="svg-card svg-card-stroke" />
      <text x="20" y="32" font-family="'Fragment Mono', monospace" font-size="11" class="svg-accent" letter-spacing="2">DRAKE SCOPES</text>
      <text x="20" y="58" font-family="'Quicksand Variable', sans-serif" font-size="15" font-weight="700" class="svg-text-bright">files clear issues</text>
      <text x="20" y="78" font-family="'Fragment Mono', monospace" font-size="11" class="svg-mute">every 20 min</text>
    </g>

    <!-- 3 scoped child issues -->
    <g transform="translate(720 60)" filter="url(#specShadow)">
      <rect width="420" height="78" rx="8" ry="8" class="svg-card svg-card-stroke" />
      <text x="20" y="30" font-family="'Fragment Mono', monospace" font-size="11" class="svg-accent" letter-spacing="2">agent:implement · backend</text>
      <text x="20" y="54" font-family="'Quicksand Variable', sans-serif" font-size="14" class="svg-text-bright">Introduce BillingV2Service</text>
      <text x="20" y="70" font-family="'Fragment Mono', monospace" font-size="11" class="svg-mute">your-backend#247</text>
      <circle cx="400" cy="58" r="4" class="svg-accent-fill" />
    </g>
    <g transform="translate(720 160)" filter="url(#specShadow)">
      <rect width="420" height="78" rx="8" ry="8" class="svg-card svg-card-stroke" />
      <text x="20" y="30" font-family="'Fragment Mono', monospace" font-size="11" class="svg-accent" letter-spacing="2">agent:implement · frontend</text>
      <text x="20" y="54" font-family="'Quicksand Variable', sans-serif" font-size="14" class="svg-text-bright">Cost page rewrite</text>
      <text x="20" y="70" font-family="'Fragment Mono', monospace" font-size="11" class="svg-mute">your-frontend#572</text>
      <circle cx="400" cy="58" r="4" class="svg-accent-fill" />
    </g>
    <g transform="translate(720 260)" filter="url(#specShadow)">
      <rect width="420" height="78" rx="8" ry="8" class="svg-card svg-card-stroke" />
      <text x="20" y="30" font-family="'Fragment Mono', monospace" font-size="11" class="svg-warn" letter-spacing="2">agent:implement · mobile</text>
      <text x="20" y="54" font-family="'Quicksand Variable', sans-serif" font-size="14" class="svg-text-bright">Settings screen v2</text>
      <text x="20" y="70" font-family="'Fragment Mono', monospace" font-size="11" class="svg-mute">your-mobile#188 · queued</text>
      <circle cx="400" cy="58" r="4" class="svg-warn-fill" />
    </g>

    <!-- connectors with pulse -->
    <line x1="320" y1="190" x2="440" y2="190" class="svg-line" stroke-width="2" />
    <line x1="320" y1="190" x2="440" y2="190" stroke="url(#specLine)" stroke-width="3" class="m-spec__pulse" />

    <line x1="620" y1="190" x2="720" y2="99"  class="svg-line" stroke-width="2" />
    <line x1="620" y1="190" x2="720" y2="199" class="svg-line" stroke-width="2" />
    <line x1="620" y1="190" x2="720" y2="299" class="svg-line" stroke-width="2" />

    <line x1="620" y1="190" x2="720" y2="99"  stroke="url(#specLine)" stroke-width="3" class="m-spec__pulse m-spec__pulse--a" />
    <line x1="620" y1="190" x2="720" y2="199" stroke="url(#specLine)" stroke-width="3" class="m-spec__pulse m-spec__pulse--b" />
    <line x1="620" y1="190" x2="720" y2="299" stroke="url(#specLine)" stroke-width="3" class="m-spec__pulse m-spec__pulse--c" />
  </svg>
</figure>

<style>
  .m-spec__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
    color: var(--alfred-mute);
    font-size: 13px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .m-spec__tag {
    color: var(--alfred-accent);
    letter-spacing: 0.16em;
  }
  .m-spec__svg { width: 100%; height: auto; display: block; }
  .m-spec__pulse {
    stroke-dasharray: 30 220;
    animation: m-spec-pulse 3s linear infinite;
  }
  .m-spec__pulse--a { animation-delay: 0s; }
  .m-spec__pulse--b { animation-delay: 0.4s; }
  .m-spec__pulse--c { animation-delay: 0.8s; }
  @keyframes m-spec-pulse {
    from { stroke-dashoffset: 220; }
    to   { stroke-dashoffset: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .m-spec__pulse { animation: none; opacity: 0.5; }
  }
  @media (max-width: 720px) {
    .m-spec {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .m-spec__head {
      position: sticky;
      left: 0;
      width: calc(100vw - 72px);
    }
    .m-spec__svg {
      width: 760px;
      max-width: none;
    }
  }
</style>
