---
/**
 * GitHubBadge.astro
 *
 * Nav-positioned link to the alfred-os repo. Shows the GitHub mark and a
 * star count. The star count is fetched at build time from the GitHub
 * REST API (unauthenticated) and inlined, so the page does not make a
 * client-side request and there is no spinner. Falls back to a dash if
 * the build-time fetch fails (no network, rate-limited, repo not yet
 * created in CI, etc.). This keeps the static output deterministic.
 */

const REPO = "luminik-io/alfred-os";

async function fetchStars(): Promise<string> {
  try {
    const res = await fetch(`https://api.github.com/repos/${REPO}`, {
      headers: { "User-Agent": "alfred-os-site-build", "Accept": "application/vnd.github+json" },
    });
    if (!res.ok) return "—";
    const data = (await res.json()) as { stargazers_count?: number };
    const n = data.stargazers_count ?? 0;
    if (n >= 1000) return `${(n / 1000).toFixed(1)}k`;
    return n.toString();
  } catch {
    return "—";
  }
}

const stars = await fetchStars();
---

<a class="ghb" href={`https://github.com/${REPO}`} rel="noopener" aria-label={`Alfred on GitHub, ${stars} stars`}>
  <svg class="ghb__icon" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
    <path
      fill="currentColor"
      d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.18c-3.2.69-3.88-1.37-3.88-1.37-.52-1.34-1.28-1.7-1.28-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.67 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.45.11-3.03 0 0 .96-.31 3.16 1.18a10.98 10.98 0 0 1 5.74 0c2.2-1.49 3.16-1.18 3.16-1.18.62 1.58.23 2.74.11 3.03.74.8 1.18 1.82 1.18 3.07 0 4.4-2.69 5.37-5.25 5.66.41.35.78 1.05.78 2.12v3.14c0 .31.21.66.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"
    />
  </svg>
  <span class="ghb__star" aria-hidden="true">
    <svg width="11" height="11" viewBox="0 0 24 24" aria-hidden="true">
      <path
        fill="currentColor"
        d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21l1.18-6.88-5-4.87 6.91-1.01L12 2Z"
      />
    </svg>
    <span>{stars}</span>
  </span>
</a>

<style>
  .ghb {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border: 1px solid var(--alfred-border-strong);
    background: var(--alfred-surface);
    border-radius: var(--radius);
    color: var(--alfred-text-bright);
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1;
    transition: border-color 160ms ease, background 160ms ease;
  }
  .ghb:hover {
    text-decoration: none;
    background: var(--alfred-surface-2);
    border-color: var(--alfred-accent);
  }
  .ghb__icon {
    color: var(--alfred-text-bright);
    flex: none;
  }
  .ghb__star {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--alfred-warn);
    padding-left: 8px;
    border-left: 1px solid var(--alfred-border);
  }
  .ghb__star svg { display: block; }
</style>
