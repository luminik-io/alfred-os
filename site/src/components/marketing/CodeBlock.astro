---
/**
 * CodeBlock.astro
 *
 * A monospace code or terminal-output block. Lines are passed as an array;
 * each line is rendered as its own block child. Lines starting with `$ `
 * are treated as prompts and the `$` is colored in the accent.
 *
 * Implementation note: we deliberately use <div class="codeblock__body">
 * NOT <pre>, because <pre> preserves the whitespace between JSX <div>
 * children and inserts a forced newline per child, doubling the line
 * height. Using <div> as the wrapper keeps each line on its own row
 * without the extra spacing.
 */

interface Props {
  title?: string;
  lines: string[];
}

const { title, lines } = Astro.props;
---

<div class="codeblock m-figure">
  {title && (
    <header class="codeblock__head">
      <span class="m-mono codeblock__title">{title}</span>
      <span class="m-mono m-mute">copy</span>
    </header>
  )}
  <div class="codeblock__body">
    {lines.map((line) => {
      const isPrompt = line.startsWith("$ ");
      const rest = isPrompt ? line.slice(2) : line;
      const isBlank = line.trim() === "";
      if (isBlank) {
        return <div class="codeblock__line codeblock__line--blank" aria-hidden="true">&nbsp;</div>;
      }
      return (
        <div class="codeblock__line">
          {isPrompt ? (
            <>
              <span class="codeblock__prompt">$</span>
              <span class="codeblock__cmd"> {rest}</span>
            </>
          ) : (
            <span class="codeblock__out">{line}</span>
          )}
        </div>
      );
    })}
  </div>
</div>

<style>
  .codeblock {
    /* Outer sizing/background comes from .m-figure. We zero the padding
       so the header bar and body sit edge-to-edge within the panel and
       own their own inner padding. */
    padding: 0;
    overflow: hidden;
    /* Allow the figure to shrink below its intrinsic line width inside
       a CSS Grid track so .codeblock__body's overflow-x: auto actually
       kicks in instead of the figure pushing the viewport wider. */
    min-width: 0;
  }
  .codeblock__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    background: var(--alfred-surface-2);
    border-bottom: 1px solid var(--alfred-border);
    /* Allow the head children to shrink below their intrinsic min-content
       so a long unbreakable title (e.g. "your-platform#812
       (agent:large-feature)") truncates instead of stretching the figure
       past the viewport on mobile. */
    min-width: 0;
  }
  .codeblock__title {
    color: var(--alfred-mute);
    /* Truncate with ellipsis rather than push the figure wider than
       its grid track on narrow viewports. */
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .codeblock__body {
    margin: 0;
    padding: 16px 18px;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.6;
    color: var(--alfred-text);
  }
  .codeblock__line {
    white-space: pre;
    display: block;
  }
  .codeblock__line--blank { height: 1.6em; }
  .codeblock__prompt { color: var(--alfred-accent); font-weight: 600; margin-right: 0; }
  .codeblock__cmd { color: var(--alfred-text-bright); }
  .codeblock__out { color: var(--alfred-mute); }
</style>
