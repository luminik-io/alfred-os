---
/**
 * Hero.astro
 *
 * Reusable hero for marketing pages. Slot accepts a right-side control surface
 * (typically a list of MetricRows in a panel). If no slot is provided, the
 * hero renders single-column.
 */

interface Cta {
  label: string;
  href: string;
  /** Optional data- attributes (e.g. GA4 download tracking hooks). */
  data?: Record<string, string>;
}

interface Props {
  eyebrow: string;
  headline: string;
  sub: string;
  primaryCta?: Cta;
  secondaryCta?: Cta;
  /** Optional third CTA, rendered as a ghost button after the secondary. */
  tertiaryCta?: Cta;
  headlineSize?: "xl" | "lg";
}

const { eyebrow, headline, sub, primaryCta, secondaryCta, tertiaryCta, headlineSize = "xl" } = Astro.props;
const hasPanel = Astro.slots.has("panel");
---

<section class={`hero ${hasPanel ? "hero--split" : "hero--solo"}`}>
  <div class="m-ambient" aria-hidden="true"></div>
  {/* Cinematic fleet layer: a calm horizon sweep plus a few drifting
      status pings. Pure CSS, no JS, reduced-motion safe. Reads as "the
      fleet is working in the background" without competing with
      the headline. */}
  <div class="hero-fleet" aria-hidden="true">
    <span class="hero-fleet__sweep"></span>
    <span class="hero-fleet__ping hero-fleet__ping--1"></span>
    <span class="hero-fleet__ping hero-fleet__ping--2"></span>
    <span class="hero-fleet__ping hero-fleet__ping--3"></span>
  </div>
  <div class="m-container hero__inner">
    <div class="hero__copy">
      <div class="m-eyebrow">{eyebrow}</div>
      <h1 class={headlineSize === "xl" ? "m-display-xl" : "m-display-lg"}>{headline}</h1>
      <p class="m-body-lg hero__sub">{sub}</p>
      {(primaryCta || secondaryCta || tertiaryCta) && (
        <div class="hero__ctas">
          {primaryCta && <a class="m-btn" href={primaryCta.href} rel="noopener" {...primaryCta.data}>{primaryCta.label}</a>}
          {secondaryCta && (
            <a class="m-btn m-btn--ghost" href={secondaryCta.href} rel="noopener" {...secondaryCta.data}>{secondaryCta.label}</a>
          )}
          {tertiaryCta && (
            <a class="m-btn m-btn--ghost" href={tertiaryCta.href} rel="noopener" {...tertiaryCta.data}>{tertiaryCta.label}</a>
          )}
        </div>
      )}
    </div>
    {hasPanel && (
      <aside class="hero__panel">
        <slot name="panel" />
      </aside>
    )}
  </div>
</section>

<style>
  .hero {
    padding: 96px 0 64px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 600px 280px at 20% 0%, rgba(0, 229, 199, 0.10), transparent 60%),
      radial-gradient(ellipse 700px 320px at 80% 10%, rgba(87, 137, 255, 0.06), transparent 60%);
    pointer-events: none;
  }

  :global([data-theme="light"]) .hero::before {
    background:
      radial-gradient(ellipse 600px 280px at 20% 0%, rgba(15, 138, 120, 0.10), transparent 60%),
      radial-gradient(ellipse 700px 320px at 80% 10%, rgba(46, 93, 219, 0.06), transparent 60%);
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 56px;
    align-items: center;
  }

  .hero--split .hero__inner {
    grid-template-columns: 1.35fr 0.9fr;
  }

  .hero__copy h1 {
    margin-top: 18px;
    color: var(--alfred-text-bright);
  }

  .hero__copy,
  .hero__panel {
    min-width: 0;
  }

  .hero__sub {
    margin-top: 24px;
    color: var(--alfred-text);
    max-width: 58ch;
    overflow-wrap: anywhere;
  }

  .hero__ctas {
    margin-top: 32px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .hero__panel {
    background: var(--alfred-surface);
    border: 1px solid var(--alfred-border-strong);
    border-radius: var(--radius);
    padding: 22px;
    box-shadow: 0 30px 60px -30px rgba(0, 0, 0, 0.6);
  }

  :global([data-theme="light"]) .hero__panel {
    box-shadow: 0 20px 50px -28px rgba(20, 30, 60, 0.25);
  }

  @media (max-width: 980px) {
    .hero { padding: 64px 0 48px; }
    .hero--split .hero__inner {
      grid-template-columns: 1fr;
    }
  }

  /* ───────────────────────────────────────────────────────────────
     Cinematic fleet layer. Sits above .m-ambient (the drifting grid)
     and below the hero copy. A faint horizon sweep crosses the hero on
     a long loop, and three accent pings breathe at fixed points, like
     agents reporting in. Everything is decorative, low-opacity, and
     no-ops under prefers-reduced-motion.
     ─────────────────────────────────────────────────────────────── */
  .hero-fleet {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .hero-fleet__sweep {
    position: absolute;
    top: 0;
    bottom: 0;
    left: -30%;
    width: 30%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(0, 229, 199, 0.05) 45%,
      rgba(0, 229, 199, 0.09) 50%,
      rgba(0, 229, 199, 0.05) 55%,
      transparent 100%
    );
    filter: blur(2px);
    animation: hero-sweep 11s ease-in-out infinite;
  }
  :global([data-theme="light"]) .hero-fleet__sweep {
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(15, 138, 120, 0.05) 45%,
      rgba(15, 138, 120, 0.08) 50%,
      rgba(15, 138, 120, 0.05) 55%,
      transparent 100%
    );
  }
  @keyframes hero-sweep {
    0%   { transform: translateX(0); opacity: 0; }
    12%  { opacity: 1; }
    88%  { opacity: 1; }
    100% { transform: translateX(440%); opacity: 0; }
  }

  .hero-fleet__ping {
    position: absolute;
    width: 7px;
    height: 7px;
    border-radius: 999px;
    /* Per-ping ring colour: the keyframes read this triplet via rgba(), so
       each ping's expanding ring matches its own dot instead of a hard-coded
       cyan that overrode the blue dot's ring. */
    --ping-ring: 0, 229, 199;
    background: var(--alfred-accent);
    box-shadow: 0 0 0 0 rgba(var(--ping-ring), 0.55);
    opacity: 0.5;
    animation: hero-ping 4.4s ease-out infinite;
  }
  .hero-fleet__ping--1 { top: 22%; left: 64%; animation-delay: 0s; }
  .hero-fleet__ping--2 { top: 58%; left: 78%; animation-delay: 1.5s; background: var(--alfred-blue); --ping-ring: 87, 137, 255; }
  .hero-fleet__ping--3 { top: 40%; left: 88%; animation-delay: 2.9s; }
  @keyframes hero-ping {
    0%   { box-shadow: 0 0 0 0 rgba(var(--ping-ring), 0.5); opacity: 0.6; }
    70%  { box-shadow: 0 0 0 16px rgba(var(--ping-ring), 0); opacity: 0.2; }
    100% { box-shadow: 0 0 0 0 rgba(var(--ping-ring), 0); opacity: 0.6; }
  }

  /* Calm staged entrance for the hero copy + panel. Each lifts in once on
     load. Tiny, single-shot, and disabled under reduced motion. */
  .hero__copy > * {
    animation: hero-rise 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .hero__copy .m-eyebrow { animation-delay: 0.02s; }
  .hero__copy h1 { animation-delay: 0.1s; }
  .hero__sub { animation-delay: 0.2s; }
  .hero__ctas { animation-delay: 0.3s; }
  .hero__panel { animation: hero-rise 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.34s both; }
  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fleet__sweep,
    .hero-fleet__ping { animation: none; }
    .hero-fleet__sweep { opacity: 0; }
    .hero__copy > *,
    .hero__panel { animation: none; }
  }
</style>
