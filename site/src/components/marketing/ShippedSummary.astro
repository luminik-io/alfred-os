---
/**
 * ShippedSummary.astro
 *
 * Headline numbers card for /shipped/. Five mono-aligned metric rows in
 * the Operations Room style: status dot motif on the value, JetBrains
 * Mono, sharp panel.
 *
 * Consumes the `summary` object from site/src/data/shipped/weekly.json
 * via the parent page. Pure render component, no data fetching of its
 * own.
 */

import MetricRow from "./MetricRow.astro";

interface Summary {
  prs_merged: number;
  prs_reverted: number;
  issues_closed: number;
  agents_active: number;
  repos_touched: number;
  spend_cents: number;
  merge_clean_pct: number;
}

interface Props {
  summary: Summary;
  operator: string;
  windowFrom: string;
  windowTo: string;
}

const { summary, operator, windowFrom, windowTo } = Astro.props;

const fmtDate = (iso: string): string => {
  const d = new Date(iso);
  return d.toISOString().slice(0, 10);
};

const spendUsd = (cents: number): string => {
  if (cents === 0) return "$0";
  const dollars = cents / 100;
  return dollars >= 100
    ? `$${dollars.toFixed(0)}`
    : `$${dollars.toFixed(2)}`;
};

const mergeCleanState: "live" | "warn" | "error" =
  summary.merge_clean_pct >= 90
    ? "live"
    : summary.merge_clean_pct >= 75
      ? "warn"
      : "error";
---

<figure class="shipped-summary m-figure">
  <figcaption class="shipped-summary__head">
    <span class="m-eyebrow">SHIPPED, {fmtDate(windowFrom)} TO {fmtDate(windowTo)}</span>
    <span class="m-mono m-mute">operator: {operator}</span>
  </figcaption>

  <div class="shipped-summary__grid">
    <MetricRow label="PRs merged"    value={String(summary.prs_merged)}    countTo={summary.prs_merged}    state="live" />
    <MetricRow label="PRs reverted"  value={String(summary.prs_reverted)}  countTo={summary.prs_reverted}  state={summary.prs_reverted === 0 ? "live" : "warn"} />
    <MetricRow label="issues closed" value={String(summary.issues_closed)} countTo={summary.issues_closed} state="live" />
    <MetricRow label="agents active" value={String(summary.agents_active)} countTo={summary.agents_active} state="live" />
    <MetricRow label="repos touched" value={String(summary.repos_touched)} countTo={summary.repos_touched} state="live" />
    <MetricRow label="LLM spend"     value={spendUsd(summary.spend_cents)} state={summary.spend_cents === 0 ? "live" : "info"} glyph={summary.spend_cents === 0 ? "dot" : "arrow"} />
    <MetricRow label="merge clean"   value={`${summary.merge_clean_pct}%`} state={mergeCleanState} />
  </div>
</figure>

<style>
  .shipped-summary {
    /* Outer sizing comes from .m-figure. The grid below sits inside its
       padding without a per-component override. */
  }
  .shipped-summary__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    padding-bottom: 14px;
    margin-bottom: 8px;
    border-bottom: 1px solid var(--alfred-border);
  }
  .shipped-summary__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 32px;
  }
  @media (max-width: 720px) {
    .shipped-summary__grid { grid-template-columns: 1fr; }
  }
</style>
