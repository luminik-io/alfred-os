---
/**
 * FiringLifecycle.astro
 *
 * Inline SVG diagram of one Alfred firing end to end. Visual replacement
 * for the mermaid graph on the docs homepage, themed to the marketing
 * design system. Animates with a slow "pulse" travelling along the flow
 * line so the diagram feels alive, like a control surface. Respects
 * prefers-reduced-motion.
 *
 * No JS dependency. Pure SVG + CSS.
 * Theme-aware via .svg-* classes defined in marketing.css.
 */
---

<figure class="m-flow m-figure m-reveal" aria-label="One Alfred firing, end to end">
  <div class="m-flow__head">
    <span class="m-mono m-flow__tag">FIRING LIFECYCLE</span>
    <span class="m-mono m-flow__meta">scheduler → role runner → engine → slack</span>
  </div>

  <svg viewBox="0 0 1180 360" role="img" aria-hidden="false" class="m-flow__svg" preserveAspectRatio="xMidYMid meet">
    <defs>
      <linearGradient id="flowLine" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%"   stop-color="#00E5C7" stop-opacity="0.0" />
        <stop offset="50%"  stop-color="#00E5C7" stop-opacity="0.9" />
        <stop offset="100%" stop-color="#00E5C7" stop-opacity="0.0" />
      </linearGradient>
      <filter id="cardShadow" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="0" dy="6" stdDeviation="8" flood-color="#000" flood-opacity="0.45" />
      </filter>
    </defs>

    <!-- Flow track. 5 cards × 200 wide, 25 gap, starts at x=40, ends at x=1140. -->
    <line x1="90" y1="180" x2="1090" y2="180" class="svg-line" stroke-width="2" stroke-dasharray="2 6" />
    <line x1="90" y1="180" x2="1090" y2="180" stroke="url(#flowLine)" stroke-width="3" class="m-flow__pulse" />

    <!-- Stage cards: all equal width (200px) for vertical-column alignment.
         Eyebrows kept short so they fit without truncation. -->
    <g class="m-flow__stage" transform="translate(40 80)">
      <rect width="200" height="200" rx="8" ry="8" class="svg-card svg-card-stroke" filter="url(#cardShadow)" />
      <text x="20" y="34" font-family="JetBrains Mono, monospace" font-size="11" class="svg-mute" letter-spacing="2">01 · SCHEDULER</text>
      <text x="20" y="78" font-family="Quicksand, sans-serif" font-size="20" font-weight="700" class="svg-text-bright">launchd</text>
      <text x="20" y="100" font-family="Quicksand, sans-serif" font-size="14" class="svg-text">fires lucius</text>
      <text x="20" y="138" font-family="JetBrains Mono, monospace" font-size="12" class="svg-mute">every 1200s</text>
      <text x="20" y="158" font-family="JetBrains Mono, monospace" font-size="12" class="svg-mute">survives reboot</text>
      <circle cx="180" cy="178" r="4" class="svg-accent-fill" />
    </g>

    <g class="m-flow__stage" transform="translate(265 80)">
      <rect width="200" height="200" rx="8" ry="8" class="svg-card svg-card-stroke" filter="url(#cardShadow)" />
      <text x="20" y="34" font-family="JetBrains Mono, monospace" font-size="11" class="svg-mute" letter-spacing="2">02 · ROLE RUNNER</text>
      <text x="20" y="78" font-family="Quicksand, sans-serif" font-size="20" font-weight="700" class="svg-text-bright">lucius.py</text>
      <text x="20" y="100" font-family="Quicksand, sans-serif" font-size="14" class="svg-text">preflight, claim</text>
      <text x="20" y="138" font-family="JetBrains Mono, monospace" font-size="12" class="svg-mute">picks oldest open</text>
      <text x="20" y="158" font-family="JetBrains Mono, monospace" font-size="12" class="svg-mute">agent:implement</text>
      <circle cx="180" cy="178" r="4" class="svg-accent-fill" />
    </g>

    <g class="m-flow__stage" transform="translate(490 80)">
      <rect width="200" height="200" rx="8" ry="8" class="svg-card svg-card-stroke" filter="url(#cardShadow)" />
      <text x="20" y="34" font-family="JetBrains Mono, monospace" font-size="11" class="svg-mute" letter-spacing="2">03 · WORKTREE</text>
      <text x="20" y="78" font-family="Quicksand, sans-serif" font-size="20" font-weight="700" class="svg-text-bright">git worktree</text>
      <text x="20" y="100" font-family="Quicksand, sans-serif" font-size="14" class="svg-text">isolated workspace</text>
      <text x="20" y="138" font-family="JetBrains Mono, monospace" font-size="12" class="svg-mute">~/.alfred/wt/...</text>
      <text x="20" y="158" font-family="JetBrains Mono, monospace" font-size="12" class="svg-mute">safe to crash</text>
      <circle cx="180" cy="178" r="4" class="svg-accent-fill" />
    </g>

    <g class="m-flow__stage" transform="translate(715 80)">
      <rect width="200" height="200" rx="8" ry="8" class="svg-card svg-card-stroke" filter="url(#cardShadow)" />
      <text x="20" y="34" font-family="JetBrains Mono, monospace" font-size="11" class="svg-mute" letter-spacing="2">04 · ENGINE</text>
      <text x="20" y="78" font-family="Quicksand, sans-serif" font-size="20" font-weight="700" class="svg-text-bright">claude -p</text>
      <text x="20" y="100" font-family="Quicksand, sans-serif" font-size="14" class="svg-text">or codex exec</text>
      <text x="20" y="138" font-family="JetBrains Mono, monospace" font-size="12" class="svg-mute">your subscription</text>
      <text x="20" y="158" font-family="JetBrains Mono, monospace" font-size="12" class="svg-mute">no API key</text>
      <circle cx="180" cy="178" r="4" class="svg-accent-fill" />
    </g>

    <g class="m-flow__stage" transform="translate(940 80)">
      <rect width="200" height="200" rx="8" ry="8" class="svg-card svg-card-stroke" filter="url(#cardShadow)" />
      <text x="20" y="34" font-family="JetBrains Mono, monospace" font-size="11" class="svg-mute" letter-spacing="2">05 · OUTPUT</text>
      <text x="20" y="78" font-family="Quicksand, sans-serif" font-size="20" font-weight="700" class="svg-text-bright">PR + report</text>
      <text x="20" y="100" font-family="Quicksand, sans-serif" font-size="14" class="svg-text">label flip, slack post</text>
      <text x="20" y="138" font-family="JetBrains Mono, monospace" font-size="12" class="svg-mute">agent:pr-open</text>
      <text x="20" y="158" font-family="JetBrains Mono, monospace" font-size="12" class="svg-mute">severity=info</text>
      <circle cx="180" cy="178" r="4" class="svg-accent-fill" />
    </g>

    <!-- caption -->
    <text x="40" y="332" font-family="JetBrains Mono, monospace" font-size="12" class="svg-mute">
      one firing = one role run, one issue claim, one worktree, one engine invocation, one slack post
    </text>
  </svg>
</figure>

<style>
  .m-flow__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    color: var(--alfred-mute);
    font-size: 13px;
  }
  .m-flow__tag {
    color: var(--alfred-accent);
    letter-spacing: 0.16em;
  }
  .m-flow__svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .m-flow__pulse {
    stroke-dasharray: 60 940;
    animation: m-flow-pulse 3.4s linear infinite;
  }
  @keyframes m-flow-pulse {
    from { stroke-dashoffset: 1000; }
    to   { stroke-dashoffset: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .m-flow__pulse { animation: none; opacity: 0.55; }
  }
  @media (max-width: 880px) {
    .m-flow {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .m-flow__head {
      position: sticky;
      left: 0;
      width: calc(100vw - 72px);
    }
    .m-flow__svg {
      width: 780px;
      max-width: none;
    }
  }
</style>
