---
/**
 * ShippedTable.astro
 *
 * Row-by-row table of merged PRs in the window. Mono, dense, terminal
 * aesthetic. Mirrors the FleetStatus.astro pattern but on PR metadata.
 *
 * Pure render component. Consumes the `prs` array from weekly.json. PR
 * diffs and issue bodies are NEVER included in this feed; the emitter
 * scrubs them at write time.
 */

interface Pr {
  repo: string;
  number: number;
  title: string;
  codename: string;
  merged_at: string;
  lines_added: number;
  lines_removed: number;
  files_changed: number;
  reviewed_by?: string[];
  url: string;
}

interface Props {
  prs: Pr[];
}

const { prs } = Astro.props;

const codenameState = (cn: string): "live" | "warn" | "info" | "idle" => {
  // Visual hint only. Agent codenames render accent; human and unknown render mute.
  const known = new Set([
    "lucius",
    "batman",
    "drake",
    "robin",
    "ras-al-ghul",
    "bane",
    "nightwing",
    "huntress",
    "damian",
    "gordon",
  ]);
  if (cn === "human") return "idle";
  return known.has(cn) ? "live" : "info";
};

const fmtMerged = (iso: string): string => {
  const d = new Date(iso);
  // 2026-05-22 18:23 UTC
  const date = d.toISOString().slice(0, 10);
  const time = d.toISOString().slice(11, 16);
  return `${date} ${time}`;
};

const linesCell = (added: number, removed: number): string =>
  `+${added}/-${removed}`;
---

<figure class="shipped-table m-figure" aria-label="Merged pull requests in this week's window">
  <div class="shipped-table__head">
    <span class="m-mono shipped-table__cmd"><span class="shipped-table__prompt">$</span> alfred shipped --weekly</span>
    <span class="m-mono m-mute">{prs.length} merged PRs</span>
  </div>

  <div class="shipped-table__body" role="table">
    <div class="shipped-table__row shipped-table__row--head" role="row" aria-hidden="true">
      <span role="columnheader">repo</span>
      <span role="columnheader">title</span>
      <span role="columnheader">codename</span>
      <span role="columnheader">merged</span>
      <span role="columnheader" class="num">lines</span>
      <span role="columnheader" class="num">files</span>
    </div>
    {prs.map((pr) => (
      <a class="shipped-table__row shipped-table__row--link" role="row" href={pr.url} rel="noopener noreferrer">
        <span class="shipped-table__repo" role="cell">{pr.repo}<span class="shipped-table__num">#{pr.number}</span></span>
        <span class="shipped-table__title" role="cell">{pr.title}</span>
        <span class={`shipped-table__codename m-dot--${codenameState(pr.codename)}`} role="cell">
          <span class="m-dot">●</span>{pr.codename}
        </span>
        <span class="shipped-table__merged" role="cell">{fmtMerged(pr.merged_at)}</span>
        <span class="shipped-table__lines num" role="cell">{linesCell(pr.lines_added, pr.lines_removed)}</span>
        <span class="shipped-table__files num" role="cell">{pr.files_changed}</span>
      </a>
    ))}
  </div>
</figure>

<style>
  .shipped-table {
    /* Outer sizing/background comes from .m-figure. The head and body
       rows render flush-left at panel width, so we zero the figure
       padding here. */
    padding: 0;
    overflow: hidden;
  }
  .shipped-table__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 18px;
    border-bottom: 1px solid var(--alfred-border-strong);
    background: var(--alfred-black);
  }
  .shipped-table__prompt { color: var(--alfred-accent); margin-right: 6px; }
  .shipped-table__body { display: flex; flex-direction: column; }

  .shipped-table__row {
    display: grid;
    grid-template-columns: 1.4fr 2.6fr 1fr 1.3fr 0.9fr 0.5fr;
    gap: 16px;
    padding: 10px 18px;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.45;
    color: var(--alfred-text);
    border-bottom: 1px dashed var(--alfred-border);
    text-decoration: none;
  }
  .shipped-table__row:last-child { border-bottom: none; }
  .shipped-table__row--head {
    color: var(--alfred-mute);
    text-transform: lowercase;
    letter-spacing: 0.06em;
    font-size: 12px;
    background: var(--alfred-black);
  }
  .shipped-table__row--link:hover {
    background: var(--alfred-surface-2);
  }
  .shipped-table__row--link:focus-visible {
    outline: 2px solid var(--alfred-accent);
    outline-offset: -2px;
  }
  .shipped-table__repo { color: var(--alfred-text-bright); }
  .shipped-table__num { color: var(--alfred-mute); margin-left: 4px; }
  .shipped-table__title { color: var(--alfred-text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .shipped-table__codename { color: var(--alfred-text); display: inline-flex; align-items: center; gap: 6px; }
  .shipped-table__codename .m-dot { font-size: 10px; }
  .shipped-table__merged { color: var(--alfred-mute); }
  .shipped-table__lines, .shipped-table__files { color: var(--alfred-text-bright); }
  .num { text-align: right; }

  @media (max-width: 880px) {
    .shipped-table__row {
      grid-template-columns: 1fr 1fr;
      gap: 6px 16px;
    }
    .shipped-table__row--head { display: none; }
    .shipped-table__title { white-space: normal; grid-column: 1 / -1; color: var(--alfred-text-bright); }
    .shipped-table__merged { grid-column: 1 / -1; }
  }
</style>
