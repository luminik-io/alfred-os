---
/**
 * ImpactCounter.astro
 *
 * Shows aggregate Alfred usage totals. The page can pass a seed from the first
 * reporter, then the browser replaces it with live Worker /stats data when a
 * PUBLIC_ALFRED_TELEMETRY_STATS_URL is configured.
 */

interface CounterTotals {
  installs?: number;
  prs_opened?: number;
  prs_merged?: number;
  prs_reviewed?: number;
  loc_added?: number;
  files_changed?: number;
  issues_opened?: number;
  lines_changed?: number;
  updated_at?: string | null;
}

interface Props {
  /** Keep showing the seed/fallback until a live payload clears this floor. */
  threshold?: number;
  /** Render without card chrome when placed inside an existing panel. */
  variant?: "card" | "plain";
  /** Static first-reporter totals used before a live endpoint responds. */
  seed?: CounterTotals;
}

const { threshold = 0, variant = "card", seed = {} } = Astro.props;
const numberOrZero = (value: unknown) => {
  const n = Number(value ?? 0);
  return Number.isFinite(n) && n > 0 ? n : 0;
};
const seedTotals = {
  installs: numberOrZero(seed.installs),
  prs_opened: numberOrZero(seed.prs_opened),
  prs_merged: numberOrZero(seed.prs_merged),
  prs_reviewed: numberOrZero(seed.prs_reviewed),
  files_changed: numberOrZero(seed.files_changed ?? seed.loc_added),
  issues_opened: numberOrZero(seed.issues_opened),
  lines_changed: numberOrZero(seed.lines_changed),
  updated_at: seed.updated_at ?? null,
};
const hasSeed =
  seedTotals.installs > 0 ||
  seedTotals.prs_opened > 0 ||
  seedTotals.prs_merged > 0 ||
  seedTotals.prs_reviewed > 0 ||
  seedTotals.files_changed > 0 ||
  seedTotals.issues_opened > 0 ||
  seedTotals.lines_changed > 0;
const fmt = (n: number) => n.toLocaleString("en-US");

// Build-time public env var. Empty default keeps forks offline.
const statsUrl = (import.meta.env.PUBLIC_ALFRED_TELEMETRY_STATS_URL ?? "").trim();
---

<section
  class:list={["impact", variant === "plain" && "impact--plain", "m-reveal"]}
  data-stats-url={statsUrl}
  data-threshold={String(threshold)}
  data-seed={JSON.stringify(seedTotals)}
  aria-label="Aggregate Alfred usage totals"
>
  <div class="impact__fallback" data-impact-fallback hidden={hasSeed}>
    <p class="impact__warming m-mono">No reporting machines yet.</p>
    <p class="impact__sub">
      Aggregate totals appear here when Alfred has a telemetry endpoint to read from.
    </p>
  </div>

  <div class="impact__live" data-impact-live hidden={!hasSeed}>
    <div class="impact__main">
      <span class="impact__num impact__num--main" data-field="prs_merged">{fmt(seedTotals.prs_merged)}</span>
      <p>PRs merged by Alfred</p>
    </div>
    <div class="impact__grid" role="list">
      <div class="impact__cell" role="listitem">
        <span class="impact__cellnum" data-field="installs">{fmt(seedTotals.installs)}</span>
        <span class="impact__celllbl">machines reporting</span>
      </div>
      <div class="impact__cell" role="listitem">
        <span class="impact__cellnum" data-field="lines_changed">{fmt(seedTotals.lines_changed)}</span>
        <span class="impact__celllbl">lines changed</span>
      </div>
      <div class="impact__cell" role="listitem">
        <span class="impact__cellnum" data-field="issues_opened">{fmt(seedTotals.issues_opened)}</span>
        <span class="impact__celllbl">issues opened</span>
      </div>
      <div class="impact__cell" role="listitem">
        <span class="impact__cellnum" data-field="files_changed">{fmt(seedTotals.files_changed)}</span>
        <span class="impact__celllbl">files changed</span>
      </div>
    </div>
    <p class="impact__foot m-mono m-mute" data-impact-updated>
      {seedTotals.updated_at ? `Updated ${seedTotals.updated_at.slice(0, 10)}` : ""}
    </p>
  </div>
</section>

<script>
  function initImpactCounter() {
    document
      .querySelectorAll<HTMLElement>(".impact")
      .forEach((root) => initImpactCounterRoot(root));
  }

  function initImpactCounterRoot(root: HTMLElement) {
    const url = (root.dataset.statsUrl || "").trim();
    if (!url) return;

    const threshold = Number(root.dataset.threshold || "0");
    const fallback = root.querySelector<HTMLElement>("[data-impact-fallback]");
    const live = root.querySelector<HTMLElement>("[data-impact-live]");
    if (!fallback || !live) return;

    const fmt = (n: number) => n.toLocaleString("en-US");
    const setField = (field: string, value: number) => {
      root.querySelectorAll<HTMLElement>(`[data-field="${field}"]`).forEach((el) => {
        el.textContent = fmt(Number.isFinite(value) && value > 0 ? value : 0);
      });
    };

    const controller = new AbortController();
    const timer = window.setTimeout(() => controller.abort(), 5000);

    fetch(url, { headers: { Accept: "application/json" }, signal: controller.signal })
      .then((res) => (res.ok ? res.json() : Promise.reject(new Error(String(res.status)))))
      .then((data) => {
        const merged = Number(data?.prs_merged ?? 0);
        const opened = Number(data?.prs_opened ?? 0);
        const installs = Number(data?.installs ?? 0);
        const proofFloor = Math.max(merged, opened, installs);
        if (!Number.isFinite(proofFloor) || proofFloor < threshold) return;

        setField("prs_opened", opened);
        setField("prs_merged", merged);
        setField("prs_reviewed", Number(data?.prs_reviewed ?? 0));
        setField("installs", installs);
        setField("files_changed", Number(data?.files_changed ?? data?.loc_added ?? 0));
        setField("issues_opened", Number(data?.issues_opened ?? 0));
        setField("lines_changed", Number(data?.lines_changed ?? 0));

        const updated = root.querySelector<HTMLElement>("[data-impact-updated]");
        if (updated && typeof data?.updated_at === "string") {
          const when = new Date(data.updated_at);
          if (!Number.isNaN(when.getTime())) {
            updated.textContent = `Updated ${when.toISOString().slice(0, 10)}`;
          }
        }
        fallback.hidden = true;
        live.hidden = false;
      })
      .catch(() => {
        // Keep the seeded numbers or the fallback.
      })
      .finally(() => {
        window.clearTimeout(timer);
      });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initImpactCounter);
  } else {
    initImpactCounter();
  }
</script>

<style>
  .impact {
    border: 1px solid var(--alfred-border);
    border-radius: var(--radius);
    background: var(--alfred-surface);
    padding: 28px;
  }
  .impact--plain {
    border: 0;
    border-radius: 0;
    background: transparent;
    padding: 0;
  }
  .impact__warming {
    color: var(--alfred-text);
    font-size: 15px;
    margin: 0 0 8px;
  }
  .impact__sub,
  .impact__foot {
    color: var(--alfred-mute);
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
  }
  .impact__main {
    text-align: center;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--alfred-border);
    margin-bottom: 18px;
  }
  .impact__main p {
    margin: 8px 0 0;
    color: var(--alfred-mute);
    font-size: 14px;
  }
  .impact__num {
    color: var(--alfred-accent);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  .impact__num--main {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(48px, 8vw, 84px);
    line-height: 1;
  }
  .impact__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }
  .impact__cell {
    min-width: 0;
    border: 1px solid var(--alfred-border);
    border-radius: var(--radius);
    padding: 16px 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .impact__cellnum {
    color: var(--alfred-text-bright);
    font-size: 24px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  .impact__celllbl {
    color: var(--alfred-mute);
    font-size: 13px;
  }
  .impact__foot {
    margin-top: 14px;
    font-size: 12px;
  }
  @media (max-width: 760px) {
    .impact__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 460px) {
    .impact {
      padding: 22px;
    }
    .impact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
