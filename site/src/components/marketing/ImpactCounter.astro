---
/**
 * ImpactCounter.astro
 *
 * Shows aggregate Alfred usage totals. The page can pass build-time seed
 * totals, then the browser replaces them with live Worker /stats data when a
 * PUBLIC_ALFRED_TELEMETRY_STATS_URL is configured.
 */

interface CounterTotals {
  installs?: number;
  prs_opened?: number;
  prs_merged?: number;
  prs_reviewed?: number;
  loc_added?: number;
  files_changed?: number;
  issues_opened?: number;
  issues_closed?: number;
  lines_added?: number;
  lines_removed?: number;
  lines_changed?: number;
  updated_at?: string | null;
}

interface Props {
  /** Keep showing the seed/fallback until a live payload clears this floor. */
  threshold?: number;
  /** Render without card chrome when placed inside an existing panel. */
  variant?: "card" | "plain";
  /** Static totals used before a live endpoint responds. */
  seed?: CounterTotals;
  /** Fetch the public telemetry endpoint when configured. */
  live?: boolean;
  /** Show the updated date in the counter footer. */
  showUpdated?: boolean;
  /** Show the active install count in the counter footer. */
  showInstalls?: boolean;
}

const {
  threshold = 0,
  variant = "card",
  seed = {},
  live = true,
  showUpdated = true,
  showInstalls = true,
} = Astro.props;
const numberOrZero = (value: unknown) => {
  const n = Number(value ?? 0);
  return Number.isFinite(n) && n > 0 ? n : 0;
};
const seedTotals = {
  installs: numberOrZero(seed.installs),
  prs_opened: numberOrZero(seed.prs_opened),
  prs_merged: numberOrZero(seed.prs_merged),
  prs_reviewed: numberOrZero(seed.prs_reviewed),
  files_changed: numberOrZero(seed.files_changed ?? seed.loc_added),
  issues_opened: numberOrZero(seed.issues_opened),
  issues_closed: numberOrZero(seed.issues_closed),
  lines_added: numberOrZero(seed.lines_added),
  lines_removed: numberOrZero(seed.lines_removed),
  lines_changed: numberOrZero(seed.lines_changed),
  updated_at: seed.updated_at ?? null,
};
const hasSeedLineDelta = seed.lines_added !== undefined || seed.lines_removed !== undefined;
const showFooter = showInstalls || showUpdated;
const hasSeed =
  seedTotals.installs > 0 ||
  seedTotals.prs_opened > 0 ||
  seedTotals.prs_merged > 0 ||
  seedTotals.prs_reviewed > 0 ||
  seedTotals.files_changed > 0 ||
  seedTotals.issues_opened > 0 ||
  seedTotals.issues_closed > 0 ||
  seedTotals.lines_added > 0 ||
  seedTotals.lines_removed > 0 ||
  seedTotals.lines_changed > 0;
const fmt = (n: number) => n.toLocaleString("en-US");

// Official site default, with a build-time override for forks or previews.
const defaultStatsUrl = "https://alfred-proof-telemetry.luminik.workers.dev/stats";
const statsUrl = live
  ? (import.meta.env.PUBLIC_ALFRED_TELEMETRY_STATS_URL ?? defaultStatsUrl).trim()
  : "";
---

<section
  class:list={["impact", variant === "plain" && "impact--plain", "m-reveal"]}
  data-stats-url={statsUrl}
  data-threshold={String(threshold)}
  data-seed={JSON.stringify(seedTotals)}
  aria-label="Alfred impact totals"
>
  <div class="impact__fallback" data-impact-fallback hidden={hasSeed}>
    <p class="impact__warming m-mono">No active Alfred installs yet.</p>
    <p class="impact__sub">
      Totals appear after the first active install reports.
    </p>
  </div>

  <div class="impact__live" data-impact-live hidden={!hasSeed}>
    <div class="impact__main">
      <span class="impact__num impact__num--main" data-field="prs_merged">{fmt(seedTotals.prs_merged)}</span>
      <p>PRs merged</p>
    </div>
    <div class="impact__stack" role="list">
      <div class="impact__cell" role="listitem">
        <span class="impact__cellnum impact__pair">
          <span data-field="issues_opened">{fmt(seedTotals.issues_opened)}</span>
          <span class="impact__slash">/</span>
          <span data-field="issues_closed">{fmt(seedTotals.issues_closed)}</span>
        </span>
        <span class="impact__celllbl">issues opened / closed</span>
      </div>
      <div class="impact__cell" role="listitem">
        <span class="impact__cellnum" data-field="lines_changed">{fmt(seedTotals.lines_changed)}</span>
        <span class="impact__celllbl">lines changed</span>
      </div>
      <div class="impact__cell" role="listitem">
        <span class="impact__cellnum" data-field="files_changed">{fmt(seedTotals.files_changed)}</span>
        <span class="impact__celllbl">files changed</span>
      </div>
      <div
        class="impact__cell"
        role="listitem"
        data-impact-pr-lifecycle
        hidden={hasSeedLineDelta}
      >
        <span class="impact__cellnum impact__pair">
          <span data-field="prs_opened">{fmt(seedTotals.prs_opened)}</span>
          <span class="impact__slash">/</span>
          <span data-field="prs_reviewed">{fmt(seedTotals.prs_reviewed)}</span>
        </span>
        <span class="impact__celllbl">PRs opened / reviewed</span>
      </div>
      <div
        class="impact__cell impact__cell--muted"
        role="listitem"
        data-impact-line-delta
        hidden={!hasSeedLineDelta}
      >
        <span class="impact__cellnum impact__pair impact__pair--small">
          <span>+<span data-field="lines_added">{fmt(seedTotals.lines_added)}</span></span>
          <span class="impact__slash">/</span>
          <span>-<span data-field="lines_removed">{fmt(seedTotals.lines_removed)}</span></span>
        </span>
        <span class="impact__celllbl">added / removed</span>
      </div>
    </div>
    {showFooter ? (
      <div class="impact__foot">
        {showInstalls ? (
          <span data-impact-installs>
            <strong data-field="installs">{fmt(seedTotals.installs)}</strong>
            <span data-impact-install-label>
              {seedTotals.installs === 1 ? " active Alfred install" : " active Alfred installs"}
            </span>
          </span>
        ) : null}
        {showUpdated ? (
          <span class="m-mono m-mute" data-impact-updated>
            {seedTotals.updated_at ? `Updated ${seedTotals.updated_at.slice(0, 10)}` : ""}
          </span>
        ) : null}
      </div>
    ) : null}
  </div>
</section>

<script>
  function initImpactCounter() {
    document
      .querySelectorAll<HTMLElement>(".impact")
      .forEach((root) => initImpactCounterRoot(root));
  }

  function initImpactCounterRoot(root: HTMLElement) {
    const url = (root.dataset.statsUrl || "").trim();
    if (!url) return;

    const threshold = Number(root.dataset.threshold || "0");
    const fallback = root.querySelector<HTMLElement>("[data-impact-fallback]");
    const live = root.querySelector<HTMLElement>("[data-impact-live]");
    if (!fallback || !live) return;

    const fmt = (n: number) => n.toLocaleString("en-US");
    const setField = (field: string, value: number) => {
      root.querySelectorAll<HTMLElement>(`[data-field="${field}"]`).forEach((el) => {
        el.textContent = fmt(Number.isFinite(value) && value > 0 ? value : 0);
      });
    };

    const controller = new AbortController();
    const timer = window.setTimeout(() => controller.abort(), 5000);

    fetch(url, { headers: { Accept: "application/json" }, signal: controller.signal })
      .then((res) => (res.ok ? res.json() : Promise.reject(new Error(String(res.status)))))
      .then((data) => {
        const merged = Number(data?.prs_merged ?? 0);
        const installs = Number(data?.installs ?? 0);
        const filesChanged = Number(data?.files_changed ?? data?.loc_added ?? 0);
        const issuesOpened = Number(data?.issues_opened ?? 0);
        const proofFloor = Math.max(merged, installs, filesChanged, issuesOpened);
        if (!Number.isFinite(proofFloor) || proofFloor <= 0 || proofFloor < threshold) return;

        setField("prs_merged", merged);
        setField("installs", installs);
        setField("files_changed", filesChanged);
        setField("prs_opened", Number(data?.prs_opened ?? 0));
        setField("prs_reviewed", Number(data?.prs_reviewed ?? 0));
        setField("issues_opened", issuesOpened);
        setField("lines_changed", Number(data?.lines_changed ?? 0));
        if (data?.issues_closed !== undefined) setField("issues_closed", Number(data.issues_closed ?? 0));
        const lineDelta = root.querySelector<HTMLElement>("[data-impact-line-delta]");
        const prLifecycle = root.querySelector<HTMLElement>("[data-impact-pr-lifecycle]");
        const hasLineDelta = data?.lines_added !== undefined || data?.lines_removed !== undefined;
        if (lineDelta) lineDelta.hidden = !hasLineDelta;
        if (prLifecycle) prLifecycle.hidden = hasLineDelta;
        if (data?.lines_added !== undefined) setField("lines_added", Number(data.lines_added ?? 0));
        if (data?.lines_removed !== undefined) setField("lines_removed", Number(data.lines_removed ?? 0));

        const installLabel = root.querySelector<HTMLElement>("[data-impact-install-label]");
        if (installLabel) {
          installLabel.textContent = installs === 1 ? " active Alfred install" : " active Alfred installs";
        }

        const updated = root.querySelector<HTMLElement>("[data-impact-updated]");
        if (updated && typeof data?.updated_at === "string") {
          const when = new Date(data.updated_at);
          if (!Number.isNaN(when.getTime())) {
            updated.textContent = `Updated ${when.toISOString().slice(0, 10)}`;
          }
        }
        fallback.hidden = true;
        live.hidden = false;
      })
      .catch(() => {
        // Keep the seeded numbers or the fallback.
      })
      .finally(() => {
        window.clearTimeout(timer);
      });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initImpactCounter);
  } else {
    initImpactCounter();
  }
</script>

<style>
  .impact {
    border: 1px solid var(--alfred-border);
    border-radius: var(--radius);
    background: var(--alfred-surface);
    padding: 28px;
  }
  .impact--plain {
    border: 0;
    border-radius: 0;
    background: transparent;
    padding: 0;
  }
  .impact__warming {
    color: var(--alfred-text);
    font-size: 15px;
    margin: 0 0 8px;
  }
  .impact__sub,
  .impact__foot {
    color: var(--alfred-mute);
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
  }
  .impact__main {
    text-align: center;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--alfred-border);
    margin-bottom: 16px;
  }
  .impact__main p {
    margin: 8px 0 0;
    color: var(--alfred-mute);
    font-size: 14px;
  }
  .impact__num {
    color: var(--alfred-accent);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  .impact__num--main {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(54px, 8vw, 86px);
    line-height: 1;
  }
  .impact__stack {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  .impact__cell {
    min-width: 0;
    border: 1px solid var(--alfred-border);
    border-radius: var(--radius);
    padding: 16px 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .impact__cell[hidden] {
    display: none;
  }
  .impact__cell--muted {
    background: color-mix(in srgb, var(--alfred-surface) 82%, transparent);
  }
  .impact__cellnum {
    color: var(--alfred-text-bright);
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1.08;
  }
  .impact__celllbl {
    color: var(--alfred-mute);
    font-size: 13px;
  }
  .impact__pair {
    display: flex;
    align-items: baseline;
    gap: 8px;
    white-space: nowrap;
  }
  .impact__pair--small {
    font-size: clamp(18px, 2vw, 22px);
  }
  .impact__slash {
    color: var(--alfred-mute);
    font-weight: 500;
  }
  .impact__foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .impact__foot {
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--alfred-border);
    color: var(--alfred-mute);
    font-size: 12px;
  }
  .impact__foot strong {
    color: var(--alfred-text-bright);
    font-weight: 700;
  }
  @media (max-width: 640px) {
    .impact {
      padding: 22px;
    }
    .impact__stack {
      grid-template-columns: 1fr;
    }
    .impact__pair {
      flex-wrap: wrap;
      white-space: normal;
    }
    .impact__foot {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
