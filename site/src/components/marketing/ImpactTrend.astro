---
interface TrendItem {
  week: string;
  prs_merged: number;
}

interface Props {
  trend: TrendItem[];
  windowDays?: number;
}

const { trend, windowDays } = Astro.props;
const numberOrZero = (value: unknown) => {
  const n = Number(value ?? 0);
  return Number.isFinite(n) && n > 0 ? n : 0;
};
const safeTrend = trend
  .map((item) => ({ week: item.week, prs_merged: numberOrZero(item.prs_merged) }))
  .filter((item) => item.week);
const maxTrend = Math.max(...safeTrend.map((item) => item.prs_merged), 1);
const trendColumns = Math.max(safeTrend.length, 1);
const windowLabel = windowDays ? `Last ${windowDays} days` : "Recent weeks";
const fmt = (n: number) => n.toLocaleString("en-US");
---

<section class="trend-panel" aria-label={`Weekly merged pull requests for ${windowLabel.toLowerCase()}`}>
  <div class="trend-panel__head">
    <div>
      <span class="m-eyebrow">{windowLabel}</span>
      <h2 class="m-display-md">PRs merged by week.</h2>
    </div>
    <p>
      It shows when the merged PRs above landed.
    </p>
  </div>

  <div class="trend-chart" role="list" style={`--trend-columns:${trendColumns};`}>
    {safeTrend.map((item, index) => (
      <div
        class="trend-chart__item"
        role="listitem"
        tabindex="0"
        aria-label={`${fmt(item.prs_merged)} PRs merged in the week starting ${item.week}`}
        style={`--h:${Math.max(8, Math.round((item.prs_merged / maxTrend) * 100))}%;--i:${index};`}
      >
        <span class="trend-chart__plot">
          <span class="trend-chart__count">{fmt(item.prs_merged)}</span>
          <span class="trend-chart__bar"></span>
        </span>
        <span class="trend-chart__week m-mono">{item.week}</span>
        <span class="trend-chart__tip" aria-hidden="true">
          <strong>{fmt(item.prs_merged)}</strong> PRs merged<br />
          Week of {item.week}
        </span>
      </div>
    ))}
  </div>
</section>

<style>
  .trend-panel {
    display: grid;
    gap: 28px;
    padding: 28px;
    border: 1px solid var(--alfred-border-strong);
    border-radius: var(--radius);
    background: var(--alfred-surface);
  }
  .trend-panel__head {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(280px, 0.7fr);
    gap: 24px;
    align-items: end;
  }
  .trend-panel__head h2 {
    margin-top: 12px;
  }
  .trend-panel__head p {
    color: var(--alfred-text);
    font-size: 16px;
    line-height: 1.65;
  }
  .trend-chart {
    height: 260px;
    display: grid;
    grid-template-columns: repeat(var(--trend-columns), minmax(54px, 1fr));
    gap: 18px;
    align-items: stretch;
    overflow-x: auto;
    padding-top: 8px;
    padding-bottom: 4px;
  }
  .trend-chart__item {
    position: relative;
    min-width: 0;
    height: 100%;
    display: grid;
    grid-template-rows: minmax(0, 1fr) 20px;
    gap: 12px;
    border-radius: var(--radius);
    outline: none;
    transform: translateY(0);
    transition: transform 180ms ease;
  }
  .trend-chart__plot {
    position: relative;
    display: flex;
    min-height: 0;
    flex-direction: column;
    justify-content: flex-end;
    gap: 10px;
  }
  .trend-chart__count {
    color: var(--alfred-text-bright);
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 700;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .trend-chart__bar {
    display: block;
    min-height: 10px;
    height: var(--h);
    flex: 0 0 auto;
    border-radius: 8px 8px 3px 3px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.18), transparent 35%),
      linear-gradient(180deg, var(--alfred-accent), rgba(0, 229, 199, 0.24));
    box-shadow: 0 20px 40px -24px rgba(0, 229, 199, 0.7);
    transform: scaleY(0);
    transform-origin: bottom;
    animation: trend-grow 680ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(var(--i) * 70ms);
    transition: filter 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }
  .trend-chart__week {
    color: var(--alfred-mute);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    align-self: end;
    min-height: 20px;
    transition: color 180ms ease;
  }
  .trend-chart__tip {
    position: absolute;
    left: 50%;
    bottom: calc(var(--h) + 56px);
    z-index: 2;
    min-width: max-content;
    padding: 9px 10px;
    border: 1px solid var(--alfred-border-strong);
    border-radius: 6px;
    background: color-mix(in oklab, var(--alfred-surface-2) 92%, transparent);
    color: var(--alfred-text);
    font-size: 12px;
    line-height: 1.4;
    box-shadow: 0 18px 50px -26px rgba(0, 0, 0, 0.8);
    opacity: 0;
    pointer-events: none;
    transform: translateX(-50%) translateY(6px);
    transition: opacity 160ms ease, transform 160ms ease;
  }
  .trend-chart__tip strong {
    color: var(--alfred-text-bright);
    font-weight: 700;
  }
  .trend-chart__item:hover,
  .trend-chart__item:focus-visible {
    transform: translateY(-4px);
  }
  .trend-chart__item:hover .trend-chart__bar,
  .trend-chart__item:focus-visible .trend-chart__bar {
    filter: saturate(1.2) brightness(1.08);
    box-shadow: 0 26px 54px -24px rgba(0, 229, 199, 0.92);
  }
  .trend-chart__item:hover .trend-chart__week,
  .trend-chart__item:focus-visible .trend-chart__week {
    color: var(--alfred-text-bright);
  }
  .trend-chart__item:hover .trend-chart__tip,
  .trend-chart__item:focus-visible .trend-chart__tip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .trend-chart__item:focus-visible {
    outline: 2px solid var(--alfred-accent);
    outline-offset: 8px;
  }
  @keyframes trend-grow {
    from {
      opacity: 0.3;
      transform: scaleY(0);
    }
    to {
      opacity: 1;
      transform: scaleY(1);
    }
  }
  @media (max-width: 760px) {
    .trend-panel {
      padding: 22px;
    }
    .trend-panel__head {
      grid-template-columns: 1fr;
    }
    .trend-chart {
      height: 220px;
      gap: 12px;
    }
  }
  @media (max-width: 480px) {
    .trend-chart {
      height: 190px;
      gap: 8px;
    }
    .trend-chart__week {
      font-size: 10px;
    }
    .trend-chart__tip {
      display: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .trend-chart__item,
    .trend-chart__bar,
    .trend-chart__week,
    .trend-chart__tip {
      animation: none;
      transition: none;
    }
    .trend-chart__bar {
      transform: none;
    }
    .trend-chart__item:hover,
    .trend-chart__item:focus-visible {
      transform: none;
    }
  }
</style>
