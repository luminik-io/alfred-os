---
/**
 * FleetStatus.astro
 *
 * A render of real `alfred status` terminal output. This is a static
 * representation taken from a real production fleet, used as
 * proof on the landing page. The columns and values mirror what the
 * actual `alfred status` command prints in a terminal: agent name, load
 * state, engine, last-fired time, fire counts, cost, and current state.
 *
 * The table is intentionally dense (small font, mono, terminal aesthetic)
 * because the goal is to communicate "this is what running Alfred
 * looks like" - not to be a marketing summary.
 *
 * Source: live `alfred status` output, captured 2026-06-30 from a
 * local OSS full-fleet install. Cost is $0.00 because Alfred uses CLI
 * subscriptions, not metered API spend.
 */

type Load = "live" | "off";
type State = "ok" | "warn" | "paused" | "info";

interface Row {
  agent: string;
  load: Load;
  engine: string;
  fired: string;
  fires: number;
  ok: number;
  fail: number;
  streak: number;
  turns: number;
  cost: string;
  state: State;
  note?: string;
}

const rows: Row[] = [
  { agent: "lucius",                load: "live", engine: "hybrid", fired: "2m",    fires: 8, ok: 8, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok" },
  { agent: "drake",                 load: "live", engine: "hybrid", fired: "2h33m", fires: 0, ok: 0, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok" },
  { agent: "bane",                  load: "live", engine: "hybrid", fired: "4h17m", fires: 0, ok: 0, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok" },
  { agent: "rasalghul",             load: "live", engine: "hybrid", fired: "6m",    fires: 1, ok: 1, fail: 0, streak: 0, turns: 1, cost: "$0.00", state: "ok" },
  { agent: "nightwing",             load: "live", engine: "hybrid", fired: "1h32m", fires: 6, ok: 6, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok" },
  { agent: "robin",                 load: "live", engine: "hybrid", fired: "1h32m", fires: 2, ok: 2, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok" },
  { agent: "batman",                load: "live", engine: "hybrid", fired: "1h34m", fires: 0, ok: 0, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok" },
  { agent: "huntress",              load: "live", engine: "-",      fired: "never", fires: 0, ok: 0, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok", note: "idle until target URL exists" },
  { agent: "gordon",                load: "live", engine: "-",      fired: "never", fires: 0, ok: 0, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok", note: "idle until ECS cluster exists" },
  { agent: "automerge",             load: "live", engine: "-",      fired: "12m",   fires: 0, ok: 0, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok" },
  { agent: "agent-cleanup",         load: "live", engine: "-",      fired: "6h06m", fires: 0, ok: 0, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok" },
  { agent: "memory-harvest",        load: "live", engine: "-",      fired: "1h01m", fires: 0, ok: 0, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok" },
  { agent: "memory-auto-promote",   load: "live", engine: "-",      fired: "46m",   fires: 0, ok: 0, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok" },
  { agent: "code-map-refresh",      load: "live", engine: "-",      fired: "4h25m", fires: 0, ok: 0, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok" },
  { agent: "agent-morning-brief",   load: "live", engine: "-",      fired: "2h05m", fires: 0, ok: 0, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok" },
  { agent: "fleet-doctor",          load: "live", engine: "-",      fired: "1h36m", fires: 0, ok: 0, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok" },
  { agent: "fleet-recap-morning",   load: "live", engine: "-",      fired: "1h21m", fires: 0, ok: 0, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok" },
  { agent: "fleet-recap-evening",   load: "live", engine: "-",      fired: "1h21m", fires: 0, ok: 0, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok" },
  { agent: "shipped-summary-daily", load: "live", engine: "-",      fired: "1h30m", fires: 0, ok: 0, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok" },
  { agent: "shipped-summary-weekly",load: "live", engine: "-",      fired: "1h30m", fires: 0, ok: 0, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "ok" },
  { agent: "proof-telemetry",       load: "live", engine: "-",      fired: "1h34m", fires: 0, ok: 0, fail: 0, streak: 0, turns: 0, cost: "$0.00", state: "info", note: "anonymous aggregate usage" },
];

const loaded = rows.filter((r) => r.load === "live").length;
const total = rows.length;
---

<figure class="fleet m-figure m-reveal" aria-label="Live alfred status output from real Alfred agents">
  <div class="fleet__head">
    <span class="m-mono fleet__cmd"><span class="fleet__prompt">$</span> alfred status</span>
    <span class="m-mono m-mute">{loaded}/{total} loaded &middot; live output</span>
  </div>

  <div class="fleet__body">
    <div class="fleet__row fleet__row--head" aria-hidden="true">
      <span>agent</span>
      <span>load</span>
      <span>eng</span>
      <span>fired</span>
      <span class="num">fires</span>
      <span class="num">ok</span>
      <span class="num">fail</span>
      <span class="num">streak</span>
      <span class="num">turns</span>
      <span class="num">cost</span>
      <span>state</span>
    </div>
    <div class="fleet__rule" aria-hidden="true"></div>

    {rows.map((r) => (
      <div class={`fleet__row fleet__row--state-${r.state}`}>
        <span class="fleet__agent">{r.agent}</span>
        <span class="fleet__load">{r.load === "live" ? "●" : "○"}</span>
        <span class="fleet__eng">{r.engine}</span>
        <span class="fleet__fired">{r.fired}</span>
        <span class="num">{r.fires}</span>
        <span class="num">{r.ok}</span>
        <span class="num">{r.fail}</span>
        <span class="num">{r.streak}</span>
        <span class="num">{r.turns}</span>
        <span class="num">{r.cost}</span>
        <span class="fleet__state">
          <span class={`fleet__dot fleet__dot--${r.state}`}>●</span>
          <span class="fleet__statetext">{r.note ?? r.state}</span>
        </span>
      </div>
    ))}
  </div>

  <figcaption class="fleet__cap">
    Live <code>alfred status</code> output from a real Mac, captured 2026-06-30 after the OSS full-fleet install. Cost is <code>$0.00</code> because Alfred runs on your own Claude and Codex subscriptions, not pay-per-token API bills. Batman, Huntress, Gordon, Bane, Nightwing, and the support jobs are loaded from the first install.
  </figcaption>
</figure>

<style>
  .fleet {
    /* Outer sizing/background comes from .m-figure. We zero its padding
       here because the head and body rows render full-width inside this
       panel and own their own inner padding. */
    padding: 0;
    overflow: hidden;
    /* The terminal-style row has fixed ch widths (~109ch). Without
       min-width: 0 the figure's intrinsic min-content sets the parent
       grid track's min, pushing the .fleet__state span past the
       viewport at 375px. min-width: 0 lets .fleet__body's overflow-x
       scroll instead. */
    min-width: 0;
  }
  .fleet__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 18px;
    background: var(--alfred-surface-2);
    border-bottom: 1px solid var(--alfred-border);
    font-size: 13px;
  }
  .fleet__cmd { color: var(--alfred-text); }
  .fleet__prompt { color: var(--alfred-accent); font-weight: 600; margin-right: 6px; }
  .fleet__body {
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.6;
    padding: 14px 18px 18px;
    overflow-x: auto;
  }
  /* Fixed-width columns in `ch` so every row aligns the same way every
     terminal does. Numeric columns right-align so 47 and 0 share a tail. */
  .fleet__row {
    display: grid;
    grid-template-columns:
      26ch    /* agent name */
      4ch     /* load dot */
      8ch     /* engine */
      9ch     /* fired (e.g. 18h26m) */
      7ch     /* fires */
      6ch     /* ok */
      6ch     /* fail */
      8ch     /* streak */
      7ch     /* turns */
      8ch     /* cost */
      minmax(14ch, 1fr); /* state, takes remaining */
    align-items: center;
    gap: 10px;
    padding: 2px 0;
    white-space: nowrap;
  }
  .fleet__row--head { color: var(--alfred-mute); padding-bottom: 4px; }
  .fleet__rule {
    height: 1px;
    background: var(--alfred-border);
    margin: 4px 0 6px;
  }
  .fleet__agent { color: var(--alfred-text-bright); }
  .fleet__load {
    color: var(--alfred-accent);
    text-align: center;
    font-variant-numeric: tabular-nums;
    /* Both load glyphs occupy the same visual slot. */
    letter-spacing: 0;
  }
  .fleet__row--state-paused .fleet__load { color: var(--alfred-mute); }
  .fleet__row--state-warn .fleet__load { color: var(--alfred-accent); }
  .fleet__eng { color: var(--alfred-mute); }
  .fleet__fired { color: var(--alfred-mute); text-align: left; }
  .num {
    color: var(--alfred-text);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .fleet__row--head .num { text-align: right; }
  .fleet__state {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--alfred-text);
  }
  .fleet__dot { font-size: 10px; line-height: 1; }
  .fleet__dot--ok     { color: var(--alfred-accent); }
  .fleet__dot--warn   { color: var(--alfred-warn); }
  .fleet__dot--paused { color: var(--alfred-mute); }
  .fleet__dot--info   { color: var(--alfred-blue); }
  .fleet__statetext { color: var(--alfred-mute); overflow: hidden; text-overflow: ellipsis; }
  .fleet__row--state-warn .fleet__statetext { color: var(--alfred-warn); }

  .fleet__cap {
    padding: 14px 18px 18px;
    color: var(--alfred-mute);
    font-size: 13px;
    line-height: 1.55;
    border-top: 1px solid var(--alfred-border);
  }
  .fleet__cap code {
    color: var(--alfred-text-bright);
    background: var(--alfred-black);
    padding: 1px 6px;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 12px;
  }

  @media (max-width: 980px) {
    .fleet__body { font-size: 11.5px; }
    .fleet__row { gap: 10px; }
  }
</style>
