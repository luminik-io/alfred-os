---
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  align?: "left" | "center";
  /** Adds the scroll-in fade-up to the whole header. Defaults to true. */
  reveal?: boolean;
}

const { eyebrow, title, lede, align = "left", reveal = true } = Astro.props;
---

<header class:list={["m-section-header", `section-header--${align}`, reveal && "m-reveal"]}>
  {eyebrow && <div class="m-eyebrow">{eyebrow}</div>}
  <h2 class="m-display-md">{title}</h2>
  {lede && <p>{lede}</p>}
</header>

<style>
  .section-header--center {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }
</style>
