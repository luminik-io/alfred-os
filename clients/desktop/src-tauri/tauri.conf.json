{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Alfred",
  "version": "../package.json",
  "identifier": "io.luminik.alfred",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Alfred",
        "width": 1120,
        "height": 760,
        "minWidth": 860,
        "minHeight": 640,
        "transparent": true,
        "backgroundColor": "#00000000",
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 16
        },
        "windowEffects": {
          "effects": ["sidebar", "headerView"],
          "state": "followsWindowActiveState",
          "radius": 14
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost",
      "devCsp": "default-src 'self'; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1421"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "appimage", "deb"],
    "category": "DeveloperTool",
    "shortDescription": "Local control center for Alfred",
    "longDescription": "Alfred Desktop is the optional native control plane for a local Alfred install. It surfaces what needs attention, which plans are waiting, which runs failed, and the fleet/auth/agent actions that are safe to run next, over a locally running `alfred serve`.",
    "copyright": "Copyright (c) DataRavel Inc.",
    "publisher": "DataRavel Inc.",
    "homepage": "https://github.com/luminik-io/alfred-os",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  }
}
