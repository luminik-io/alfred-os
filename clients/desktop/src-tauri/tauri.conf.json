{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Alfred",
  "version": "../package.json",
  "identifier": "io.luminik.alfred",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Alfred",
        "width": 1120,
        "height": 760,
        "minWidth": 860,
        "minHeight": 640,
        "transparent": true,
        "backgroundColor": "#00000000",
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 16
        },
        "windowEffects": {
          "effects": ["sidebar", "headerView"],
          "state": "followsWindowActiveState",
          "radius": 14
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost",
      "devCsp": "default-src 'self'; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1421"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "appimage", "deb"],
    "category": "DeveloperTool",
    "shortDescription": "Full local installer and control center for Alfred",
    "longDescription": "Alfred Desktop is the native full-install path for a local Alfred fleet. It bundles the open-source core runtime, can install or repair the local Alfred CLI/agents, starts `alfred serve`, and surfaces setup, plans, runs, memory, and safe fleet actions.",
    "resources": {
      "../../../.env.example": "alfred-core/.env.example",
      "../../../bin": "alfred-core/bin",
      "../../../deploy.sh": "alfred-core/deploy.sh",
      "../../../install.sh": "alfred-core/install.sh",
      "../../../launchd/_template.plist": "alfred-core/launchd/_template.plist",
      "../../../launchd/agents.conf.example": "alfred-core/launchd/agents.conf.example",
      "../../../launchd/render.sh": "alfred-core/launchd/render.sh",
      "../../../lib": "alfred-core/lib",
      "../../../prompts": "alfred-core/prompts",
      "../../../systemd/_template.service": "alfred-core/systemd/_template.service",
      "../../../systemd/_template.timer": "alfred-core/systemd/_template.timer",
      "../../../systemd/render.sh": "alfred-core/systemd/render.sh"
    },
    "copyright": "Copyright (c) DataRavel Inc.",
    "publisher": "DataRavel Inc.",
    "homepage": "https://github.com/luminik-io/alfred-os",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  }
}
