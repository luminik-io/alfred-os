#!/usr/bin/env bash
# Runtime wrapper for scheduler-spawned alfred-os agents.
#
# Host schedulers do not source shell rc files. This wrapper loads config at
# firing time, exports its KEY=VALUE entries, then execs the requested agent
# script from ${ALFRED_HOME}/bin. That keeps secrets and per-agent env outside
# scheduler unit files while still making scheduled jobs see the same config as
# the operator shell.
#
# Config lives in ${ALFRED_HOME}/.env, the canonical runtime store. This is
# the same file the Set up surface, alfred-setup-token, config_value(), and
# ams-launch.sh read and write (dotenv KEY=value, no `export`). Loading it
# here keeps the token tooling and runtime loader pointed at one source of
# truth: a token written by `alfred setup-token` reaches every scheduled
# firing instead of silently 401ing.
#
# Already-exported variables (real environment, or set by an earlier file) are
# not clobbered, so a value from the scheduler/process environment still wins
# over the same key in .env. Memory auto-promote stop controls are the
# exception: an emergency opt-out or kill switch in .env must override stale
# enables.

set -euo pipefail

if [ "$#" -lt 1 ]; then
  echo "usage: agent-launch <script> [args...]" >&2
  exit 64
fi

SCRIPT="$1"
shift

if [ -n "${ALFRED_HOME+x}" ] && [ -z "${ALFRED_HOME:-}" ]; then
  unset ALFRED_HOME
fi
unset ALFREDRC

strip_inline_comment() {
  local value="$1" ch quote="" escaped=0 i previous=""
  for ((i = 0; i < ${#value}; i++)); do
    ch="${value:i:1}"
    if [ "$escaped" -eq 1 ]; then
      escaped=0
      previous="$ch"
      continue
    fi
    if [ "$ch" = "\\" ] && [ "$quote" != "'" ]; then
      escaped=1
      previous="$ch"
      continue
    fi
    if [ -n "$quote" ]; then
      if [ "$ch" = "$quote" ]; then
        quote=""
      fi
      previous="$ch"
      continue
    fi
    if [ "$ch" = "'" ] || [ "$ch" = '"' ]; then
      quote="$ch"
      previous="$ch"
      continue
    fi
    if [ "$ch" = "#" ] && [ -n "$previous" ] && [[ "$previous" =~ [[:space:]] ]]; then
      printf '%s' "${value:0:i}"
      return
    fi
    previous="$ch"
  done
  printf '%s' "$value"
}

trim_env_value() {
  printf '%s' "$1" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//'
}

memory_auto_promote_value_is_enabled() {
  case "$1" in
    1|true|yes|on|enabled) return 0 ;;
    *) return 1 ;;
  esac
}

memory_auto_promote_value_is_disabled() {
  case "$1" in
    0|false|no|off|disabled) return 0 ;;
    *) return 1 ;;
  esac
}

memory_auto_promote_stop_control_active() {
  local key="$1" token
  token="$(trim_env_value "$(strip_inline_comment "$2")" | tr '[:upper:]' '[:lower:]')"
  [ -n "$token" ] || return 1
  # All fail-closed auto-promote controls live here. In particular, malformed
  # nonblank ALFRED_AUTO_PROMOTE_LLM_JUDGE values must override stale truthy
  # values from process env so the LLM judge gate cannot be
  # bypassed by a typo in the canonical runtime .env.
  case "$key" in
    ALFRED_AUTO_PROMOTE|ALFRED_AUTO_PROMOTE_LLM_JUDGE)
      memory_auto_promote_value_is_enabled "$token" && return 1
      return 0
      ;;
    ALFRED_AUTO_PROMOTE_KILL)
      memory_auto_promote_value_is_disabled "$token" && return 1
      return 0
      ;;
  esac
  return 1
}

ORIGINAL_ENV_KEYS=":$(env | sed 's/=.*//' | tr '\n' ':')"

original_env_has_key() {
  case "$ORIGINAL_ENV_KEYS" in
    *:"$1":*) return 0 ;;
    *) return 1 ;;
  esac
}

setup_runtime_config_key() {
  case "$1" in
    ALFRED_QUEUE_REPOS|ALFRED_SHIPPED_REPOS|ALFRED_BRIDGE_REPOS|ALFRED_CODE_MEMORY_*|ALFRED_CODE_MAP_REPOS)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

expand_user_path() {
  local path="$1" expanded=""
  case "$path" in
    "~") printf '%s' "$HOME" ;;
    "~"/*) printf '%s/%s' "$HOME" "${path#\~/}" ;;
    "~"*)
      expanded="$(python3 - "$path" <<'PY' 2>/dev/null || true
import os
import sys

print(os.path.expanduser(sys.argv[1]))
PY
)"
      if [ -n "$expanded" ]; then
        printf '%s' "$expanded"
      else
        printf '%s' "$path"
      fi
      ;;
    *) printf '%s' "$path" ;;
  esac
}

load_env_file() {
  local file="$1" no_clobber="${2:-}" file_overrides_existing="${3:-}" file_overrides_process_runtime="${4:-}" setup_runtime_overrides="${5:-}" line key value quote_style existing_value
  [ -f "$file" ] || return 0
  env_value_quote_style() {
    case "$1" in
      \'*\') printf '%s' single ;;
      \"*\") printf '%s' double ;;
      *) printf '%s' none ;;
    esac
  }
  # Keep in lockstep with `decode_env_value` in lib/agent_runner/paths.py,
  # which the Python .env readers share. Changing the unquoting rules here
  # means changing them there too, or the two will disagree on a token value.
  decode_env_value() {
    local value="$1" sq="'" dq='"' splice
    splice="${sq}${dq}${sq}${dq}${sq}"
    case "$value" in
      \'*\')
        value="${value#\'}"
        value="${value%\'}"
        value="${value//$splice/$sq}"
        ;;
      \"*\")
        value="${value#\"}"
        value="${value%\"}"
        ;;
    esac
    printf '%s' "$value"
  }
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      ''|\#*) continue ;;
    esac
    case "$line" in
      export\ *) line="${line#export }" ;;
    esac
    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      ''|[0-9]*|*[!A-Za-z0-9_]*)
        continue
        ;;
    esac
    value="$(trim_env_value "$(strip_inline_comment "$value")")"
    quote_style="$(env_value_quote_style "$value")"
    value="$(decode_env_value "$value")"
    if [ "$quote_style" != "single" ]; then
      value="${value//\$\{HOME\}/$HOME}"
      value="${value//\$HOME/$HOME}"
    fi
    # In no-clobber mode, an already-exported value (real environment or an
    # earlier-loaded file) wins. Keeps .env a gap-filler, not an override,
    # except for fail-closed memory stop controls.
    if [ -n "$no_clobber" ] && [ -n "${!key+x}" ]; then
      existing_value="${!key}"
      if memory_auto_promote_stop_control_active "$key" "$existing_value"; then
        continue
      fi
      if ! memory_auto_promote_stop_control_active "$key" "$value"; then
        if [ "$setup_runtime_overrides" = "setup_runtime_overrides" ] &&
          setup_runtime_config_key "$key" &&
          ! original_env_has_key "$key"; then
          export "$key=$value"
          continue
        fi
        if [ "$file_overrides_existing" = "file_overrides_existing" ] && {
          ! original_env_has_key "$key" || {
            [ "$file_overrides_process_runtime" = "file_overrides_process_runtime" ] &&
              { [ "$key" = "ALFRED_HOME" ] || [ "$key" = "ALFRED_FLEET_BRAIN_DB" ]; }
          }
        }; then
          export "$key=$value"
          continue
        fi
        continue
      fi
    fi
    export "$key=$value"
  done < "$file"
}

: "${ALFRED_HOME:=$HOME/.alfred}"
ALFRED_HOME="$(expand_user_path "$ALFRED_HOME")"

# Load the canonical runtime store once ALFRED_HOME is known. no-clobber so
# anything already set by the scheduler/process environment takes precedence.
load_env_file "$ALFRED_HOME/.env" no_clobber "" "" setup_runtime_overrides

: "${WORKSPACE_ROOT:=$HOME/code}"
WORKSPACE_ROOT="$(expand_user_path "$WORKSPACE_ROOT")"

export ALFRED_HOME WORKSPACE_ROOT

case "$SCRIPT" in
  */*) TARGET="$SCRIPT" ;;
  *) TARGET="$ALFRED_HOME/bin/$SCRIPT" ;;
esac

if [ ! -x "$TARGET" ]; then
  echo "agent-launch: target not executable: $TARGET" >&2
  exit 127
fi

# Python interpreter resolution (Python targets only):
#   1. ${ALFRED_PYTHON}              - explicit operator override
#   2. ${ALFRED_HOME}/venv/bin/python - install.sh-managed runtime venv
#   3. agent shebang                 - preserves source-checkout / dev paths
#
# Non-Python targets (shell scripts, etc.) always execute via their own
# shebang so the venv-python path never tries to parse `.sh` files as
# Python source. Detection: `.py` extension first, then the shebang line.
is_python_target() {
  case "$TARGET" in
    *.py) return 0 ;;
  esac
  local shebang=""
  IFS= read -r shebang < "$TARGET" 2>/dev/null || true
  case "$shebang" in
    "#!"*python*) return 0 ;;
    *)            return 1 ;;
  esac
}

if is_python_target; then
  if [ -n "${ALFRED_PYTHON:-}" ] && [ -x "$ALFRED_PYTHON" ]; then
    exec "$ALFRED_PYTHON" "$TARGET" "$@"
  fi
  if [ -x "$ALFRED_HOME/venv/bin/python" ]; then
    exec "$ALFRED_HOME/venv/bin/python" "$TARGET" "$@"
  fi
fi

exec "$TARGET" "$@"
