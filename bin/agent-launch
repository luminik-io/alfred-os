#!/usr/bin/env bash
# Runtime wrapper for scheduler-spawned alfred-os agents.
#
# Host schedulers do not source shell rc files. This wrapper loads ~/.alfredrc
# at firing time, exports its KEY=VALUE entries, then execs the requested agent
# script from ${ALFRED_HOME}/bin. That keeps secrets and per-agent env outside
# scheduler unit files while still making scheduled jobs see the same config as
# the operator shell.

set -euo pipefail

if [ "$#" -lt 1 ]; then
  echo "usage: agent-launch <script> [args...]" >&2
  exit 64
fi

SCRIPT="$1"
shift

load_env_file() {
  local file="$1" line key value
  [ -f "$file" ] || return 0
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      ''|\#*) continue ;;
    esac
    case "$line" in
      export\ *) line="${line#export }" ;;
    esac
    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      ''|[0-9]*|*[!A-Za-z0-9_]*)
        continue
        ;;
    esac
    case "$value" in
      \"*\") value="${value#\"}"; value="${value%\"}" ;;
      \'*\') value="${value#\'}"; value="${value%\'}" ;;
    esac
    value="${value//\$\{HOME\}/$HOME}"
    value="${value//\$HOME/$HOME}"
    export "$key=$value"
  done < "$file"
}

load_env_file "$HOME/.alfredrc"

: "${ALFRED_HOME:=$HOME/.alfred}"
: "${WORKSPACE_ROOT:=$HOME/code}"

export ALFRED_HOME WORKSPACE_ROOT

case "$SCRIPT" in
  */*) TARGET="$SCRIPT" ;;
  *) TARGET="$ALFRED_HOME/bin/$SCRIPT" ;;
esac

if [ ! -x "$TARGET" ]; then
  echo "agent-launch: target not executable: $TARGET" >&2
  exit 127
fi

# Python interpreter resolution order (first match wins):
#   1. ${ALFRED_PYTHON}              - explicit operator override
#   2. ${ALFRED_HOME}/venv/bin/python - install.sh-managed venv (has
#                                       slack-sdk + boto3 baked in)
#   3. agent shebang                 - preserves source-checkout / dev paths
#
# The launchd / systemd-spawned process tree gets the venv when it
# exists, so base deps like slack_sdk and boto3 (promoted to required
# in v0.4.0) are importable without needing pip on the system python.
if [ -n "${ALFRED_PYTHON:-}" ] && [ -x "$ALFRED_PYTHON" ]; then
  exec "$ALFRED_PYTHON" "$TARGET" "$@"
fi
if [ -x "$ALFRED_HOME/venv/bin/python" ]; then
  exec "$ALFRED_HOME/venv/bin/python" "$TARGET" "$@"
fi

exec "$TARGET" "$@"
