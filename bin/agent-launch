#!/usr/bin/env bash
# Runtime wrapper for scheduler-spawned alfred-os agents.
#
# Host schedulers do not source shell rc files. This wrapper loads config at
# firing time, exports its KEY=VALUE entries, then execs the requested agent
# script from ${ALFRED_HOME}/bin. That keeps secrets and per-agent env outside
# scheduler unit files while still making scheduled jobs see the same config as
# the operator shell.
#
# Config lives in two files, loaded in this order:
#
#   1. ${ALFREDRC:-~/.alfredrc}
#                           - optional shell rc the operator may also source
#                             interactively (export KEY=value).
#   2. ${ALFRED_HOME}/.env  - the canonical runtime store. This is the same
#                             file the Set up surface, alfred-setup-token,
#                             config_value(), and ams-launch.sh read and write
#                             (dotenv KEY=value, no `export`). Loading it here
#                             is what keeps the token tooling and the runtime
#                             loader pointed at one source of truth: a token
#                             written by `alfred setup-token` reaches every
#                             scheduled firing instead of silently 401ing.
#
# Already-exported variables (real environment, or set by an earlier file) are
# not clobbered, so a value in .alfredrc or the scheduler unit still wins over
# the same key in .env. Memory auto-promote stop controls are the exception:
# an emergency opt-out or kill switch in .env must override stale enables.

set -euo pipefail

if [ "$#" -lt 1 ]; then
  echo "usage: agent-launch <script> [args...]" >&2
  exit 64
fi

SCRIPT="$1"
shift

memory_auto_promote_stop_control_active() {
  local key="$1" token
  token="$(printf '%s' "$2" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | tr '[:upper:]' '[:lower:]')"
  [ -n "$token" ] || return 1
  case "$key" in
    ALFRED_AUTO_PROMOTE)
      case "$token" in
        1|true|yes|on|enabled) return 1 ;;
        *) return 0 ;;
      esac
      ;;
    ALFRED_AUTO_PROMOTE_KILL)
      case "$token" in
        0|false|no|off|disabled) return 1 ;;
        *) return 0 ;;
      esac
      ;;
  esac
  return 1
}

load_env_file() {
  local file="$1" no_clobber="${2:-}" line key value quote_style existing_value
  [ -f "$file" ] || return 0
  env_value_quote_style() {
    case "$1" in
      \'*\') printf '%s' single ;;
      \"*\") printf '%s' double ;;
      *) printf '%s' none ;;
    esac
  }
  # Keep in lockstep with `decode_env_value` in lib/agent_runner/paths.py,
  # which the Python .env readers share. Changing the unquoting rules here
  # means changing them there too, or the two will disagree on a token value.
  decode_env_value() {
    local value="$1" sq="'" dq='"' splice
    splice="${sq}${dq}${sq}${dq}${sq}"
    case "$value" in
      \'*\')
        value="${value#\'}"
        value="${value%\'}"
        value="${value//$splice/$sq}"
        ;;
      \"*\")
        value="${value#\"}"
        value="${value%\"}"
        ;;
    esac
    printf '%s' "$value"
  }
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      ''|\#*) continue ;;
    esac
    case "$line" in
      export\ *) line="${line#export }" ;;
    esac
    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      ''|[0-9]*|*[!A-Za-z0-9_]*)
        continue
        ;;
    esac
    quote_style="$(env_value_quote_style "$value")"
    value="$(decode_env_value "$value")"
    if [ "$quote_style" != "single" ]; then
      value="${value//\$\{HOME\}/$HOME}"
      value="${value//\$HOME/$HOME}"
    fi
    # In no-clobber mode, an already-exported value (real environment or an
    # earlier-loaded file) wins. Keeps .env a gap-filler, not an override,
    # except for fail-closed memory stop controls.
    if [ -n "$no_clobber" ] && [ -n "${!key+x}" ]; then
      existing_value="${!key}"
      if memory_auto_promote_stop_control_active "$key" "$existing_value"; then
        continue
      fi
      if ! memory_auto_promote_stop_control_active "$key" "$value"; then
        continue
      fi
    fi
    export "$key=$value"
  done < "$file"
}

load_selected_alfredrc() {
  local selected_alfredrc="${ALFREDRC:-$HOME/.alfredrc}"
  ALFREDRC="$selected_alfredrc"
  export ALFREDRC
  load_env_file "$ALFREDRC"
  if [ -n "${ALFREDRC:-}" ] && [ "$ALFREDRC" != "$selected_alfredrc" ]; then
    selected_alfredrc="$ALFREDRC"
    load_env_file "$ALFREDRC"
    ALFREDRC="$selected_alfredrc"
    export ALFREDRC
  fi
}

load_selected_alfredrc

: "${ALFRED_HOME:=$HOME/.alfred}"

# Load the canonical runtime store once ALFRED_HOME is known. no-clobber so
# anything already set by .alfredrc or the scheduler unit takes precedence.
load_env_file "$ALFRED_HOME/.env" no_clobber

: "${WORKSPACE_ROOT:=$HOME/code}"

export ALFRED_HOME WORKSPACE_ROOT ALFREDRC

case "$SCRIPT" in
  */*) TARGET="$SCRIPT" ;;
  *) TARGET="$ALFRED_HOME/bin/$SCRIPT" ;;
esac

if [ ! -x "$TARGET" ]; then
  echo "agent-launch: target not executable: $TARGET" >&2
  exit 127
fi

# Python interpreter resolution (Python targets only):
#   1. ${ALFRED_PYTHON}              - explicit operator override
#   2. ${ALFRED_HOME}/venv/bin/python - install.sh-managed venv (has
#                                       slack-sdk + boto3 baked in)
#   3. agent shebang                 - preserves source-checkout / dev paths
#
# Non-Python targets (shell scripts, etc.) always execute via their own
# shebang so the venv-python path never tries to parse `.sh` files as
# Python source. Detection: `.py` extension first, then the shebang line.
is_python_target() {
  case "$TARGET" in
    *.py) return 0 ;;
  esac
  local shebang=""
  IFS= read -r shebang < "$TARGET" 2>/dev/null || true
  case "$shebang" in
    "#!"*python*) return 0 ;;
    *)            return 1 ;;
  esac
}

if is_python_target; then
  if [ -n "${ALFRED_PYTHON:-}" ] && [ -x "$ALFRED_PYTHON" ]; then
    exec "$ALFRED_PYTHON" "$TARGET" "$@"
  fi
  if [ -x "$ALFRED_HOME/venv/bin/python" ]; then
    exec "$ALFRED_HOME/venv/bin/python" "$TARGET" "$@"
  fi
fi

exec "$TARGET" "$@"
