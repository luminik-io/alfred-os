#!/usr/bin/env bash
# hermes-claude - switch which Claude account the launchd-spawned agents use.
#
# Primary auth lives in ~/.claude/  (the default).
# Secondary auth lives in ~/.claude-secondary/ (used when primary hits weekly cap).
#
# This script flips the launchctl global env var CLAUDE_CONFIG_DIR. Only
# launchd-spawned processes (the 14 cron agents) inherit it. Your interactive
# Claude Code sessions in iTerm / Cursor / VS Code are unaffected because
# they don't go through launchd.
#
# Usage:
#   hermes-claude              show current routing + which agents are firing
#   hermes-claude status       same as bare invocation
#   hermes-claude primary      route agents to ~/.claude/ (unset CLAUDE_CONFIG_DIR)
#   hermes-claude secondary    route agents to ~/.claude-secondary/
#   hermes-claude swap         flip primary <-> secondary
#
# After switching, in-flight agent runs keep using their old auth until they
# finish; the next firing picks up the new env automatically. No restart needed.

set -euo pipefail

PRIMARY_DIR="$HOME/.claude"
SECONDARY_DIR="$HOME/.claude-secondary"

current_dir() {
  # Returns the configured CLAUDE_CONFIG_DIR for launchd, or empty string
  # if unset (which means agents use ~/.claude by default).
  launchctl getenv CLAUDE_CONFIG_DIR 2>/dev/null || echo ""
}

current_label() {
  local d
  d="$(current_dir)"
  case "$d" in
    "")                echo "primary (~/.claude)" ;;
    "$PRIMARY_DIR")    echo "primary (~/.claude)" ;;
    "$SECONDARY_DIR")  echo "secondary (~/.claude-secondary)" ;;
    *)                 echo "custom ($d)" ;;
  esac
}

show_status() {
  echo "Current routing for launchd-spawned agents: $(current_label)"
  echo ""
  echo "Auth dir state:"
  for label in primary secondary; do
    [ "$label" = "primary" ] && d="$PRIMARY_DIR" || d="$SECONDARY_DIR"
    if [ -d "$d" ]; then
      local mtime
      mtime=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M" "$d/.claude.json" 2>/dev/null || echo "no .claude.json")
      printf "  %-12s %s   (last touched: %s)\n" "$label:" "$d" "$mtime"
    else
      printf "  %-12s %s   (NOT PRESENT)\n" "$label:" "$d"
    fi
  done
  echo ""
  local agent_count
  # FLEET_LABEL_PREFIX defaults to nothing — show all live launchd jobs.
  # Override (e.g. FLEET_LABEL_PREFIX=my.fleet) to filter to your fleet.
  local prefix="${FLEET_LABEL_PREFIX:-}"
  if [ -n "$prefix" ]; then
    agent_count=$(launchctl list | grep -c "$prefix" || true)
  else
    agent_count=$(launchctl list | grep -cE 'agent|fleet|cron' || true)
  fi
  echo "Live launchd agents: $agent_count"
  echo ""
  echo "Switch with: hermes-claude {primary|secondary|swap}"
}

set_primary() {
  launchctl unsetenv CLAUDE_CONFIG_DIR 2>/dev/null || true
  echo "Agents now route to PRIMARY (~/.claude). Next firing of each agent picks this up."
}

set_secondary() {
  if [ ! -d "$SECONDARY_DIR" ]; then
    echo "ERROR: $SECONDARY_DIR not present. Set it up first:" >&2
    echo "  CLAUDE_CONFIG_DIR=$SECONDARY_DIR claude   # then complete login" >&2
    exit 2
  fi
  launchctl setenv CLAUDE_CONFIG_DIR "$SECONDARY_DIR"
  echo "Agents now route to SECONDARY (~/.claude-secondary). Next firing of each agent picks this up."
}

swap() {
  case "$(current_dir)" in
    "$SECONDARY_DIR") set_primary ;;
    *)                set_secondary ;;
  esac
}

case "${1:-status}" in
  status|"")    show_status ;;
  primary|main) set_primary ;;
  secondary|2)  set_secondary ;;
  swap|toggle)  swap ;;
  -h|--help|help)
    sed -n '2,/^set -e/p' "$0" | sed 's/^# \?//'
    ;;
  *)
    echo "ERROR: unknown command: $1" >&2
    echo "Usage: hermes-claude {status|primary|secondary|swap}" >&2
    exit 1
    ;;
esac
