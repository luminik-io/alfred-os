#!/usr/bin/env bash
# code-memory-mcp - launcher and indexer for codebase-memory-mcp.
#
# codebase-memory-mcp (DeusData, MIT: https://github.com/DeusData/codebase-memory-mcp)
# is a STANDALONE external binary. Alfred invokes it over MCP as the
# code-structure memory layer: it indexes the in-scope repos into a code graph
# and answers read-only structure queries (search, call graph, impact / blast
# radius, who-owns). The binary is NEVER vendored into this repo, so the tree
# stays OSS-clean and passes scrub-check.
#
# Subcommands:
#   serve     start the stdio MCP server (used by the fleet; default)
#   index     build / rebuild the code index for the in-scope repos
#   refresh   incremental re-index of repos that changed since last index
#   doctor    print resolved binary, version, and index location
#
# Resolution order for the binary (first hit wins):
#   1. $ALFRED_CODE_MEMORY_BIN              explicit path
#   2. codebase-memory-mcp on $PATH         system / package install
#   3. $ALFRED_HOME/bin/codebase-memory-mcp pinned cache (auto-fetched here)
#
# On first run, if the binary is not found, this script fetches the pinned
# release ($ALFRED_CODE_MEMORY_VERSION) tarball from GitHub into the cache. The
# download is sha256-verified against a pinned digest (the value upstream
# publishes in checksums.txt for that exact tag) BEFORE it is extracted or made
# executable; a mismatch deletes the download and fails closed, so an
# unverified binary is never run. Fetching is opt-out with
# ALFRED_CODE_MEMORY_AUTOFETCH=0; in that case a missing binary is a clean
# no-op (exit 0) so attaching the MCP server is always safe.

set -uo pipefail

# --- pinned upstream release ------------------------------------------------
# The pinned version and the per-platform sha256 digests below MUST move
# together: every digest is the published checksums.txt value for this exact
# tag (DeusData/codebase-memory-mcp). Bumping the version without refreshing the
# digests fails closed (mismatch -> no install), which is the safe direction.
CODE_MEMORY_BIN_NAME="codebase-memory-mcp"

# Pinned sha256 of each release tarball, copied verbatim from the upstream
# checksums.txt published with $CODE_MEMORY_VERSION. Keyed by the Go-style
# platform tag emitted by platform_tag (os-arch). A self-hosted binary via
# ALFRED_CODE_MEMORY_BIN bypasses fetch entirely and never consults these.
# Each value is overridable via env (ALFRED_CODE_MEMORY_SHA256_<TAG_UPPER>,
# dashes -> underscores) for forward-compat when bumping the pin, but the
# default is always a real published digest, never a placeholder.
pinned_sha256() {
  local tag="$1" override_var
  override_var="ALFRED_CODE_MEMORY_SHA256_$(printf '%s' "$tag" | tr 'a-z-' 'A-Z_')"
  if [ -n "${!override_var:-}" ]; then
    printf '%s' "${!override_var}"
    return 0
  fi
  case "$tag" in
    darwin-amd64) printf '%s' "fb62da3016ea12b948351208759b5c083fb1446cf6e78d6db8b7cd28fe86fd54" ;;
    darwin-arm64) printf '%s' "fbd047509852021b5446a11141bcb0a3d1dcaebf6e5112460960f29f052c1c58" ;;
    linux-amd64)  printf '%s' "dbd3b92ea870ef240b63059f26bda15015f76ef9978931bebc3a0f9d09470973" ;;
    linux-arm64)  printf '%s' "d2f842d1365da5c35d9c5796f57a821c9745267350994346735e1e6e04d46091" ;;
    *) return 1 ;;
  esac
}

log() { printf '[code-memory-mcp] %s\n' "$*" >&2; }

capture_inherited_env_keys() {
  local line key value
  env | while IFS='=' read -r key value || [ -n "${key:-}" ]; do
    case "$key" in
      ''|[0-9]*|*[!A-Za-z0-9_]*) continue ;;
    esac
    [ -n "${value:-}" ] || continue
    printf '%s\n' "$key"
  done
}

INHERITED_ENV_KEYS="$(capture_inherited_env_keys)"

is_inherited_env_key() {
  local key="$1"
  case "$(printf '\n%s\n' "$INHERITED_ENV_KEYS")" in
    *"
$key
"*) return 0 ;;
    *) return 1 ;;
  esac
}

load_env_file() {
  local file="$1" no_clobber="${2:-}" line key value quote_style
  [ -f "$file" ] || return 0
  env_value_quote_style() {
    case "$1" in
      \'*\') printf '%s' single ;;
      \"*\") printf '%s' double ;;
      *) printf '%s' none ;;
    esac
  }
  decode_env_value() {
    local value="$1" sq="'" dq='"' splice
    splice="${sq}${dq}${sq}${dq}${sq}"
    case "$value" in
      \'*\')
        value="${value#\'}"
        value="${value%\'}"
        value="${value//$splice/$sq}"
        ;;
      \"*\")
        value="${value#\"}"
        value="${value%\"}"
        ;;
    esac
    printf '%s' "$value"
  }
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      ''|\#*) continue ;;
      export\ *) line="${line#export }" ;;
    esac
    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      ''|[0-9]*|*[!A-Za-z0-9_]*) continue ;;
    esac
    if is_inherited_env_key "$key"; then
      continue
    fi
    if [ -n "$no_clobber" ] && [ -n "${!key+x}" ]; then
      continue
    fi
    quote_style="$(env_value_quote_style "$value")"
    value="$(decode_env_value "$value")"
    if [ "$quote_style" != "single" ]; then
      value="${value//\$\{HOME\}/$HOME}"
      value="${value//\$HOME/$HOME}"
    fi
    export "$key=$value"
  done < "$file"
}

expand_user_path() {
  local value="$1"
  case "$value" in
    \~) printf '%s' "$HOME" ;;
    \~/*) printf '%s/%s' "$HOME" "${value#\~/}" ;;
    *) printf '%s' "$value" ;;
  esac
}

load_env_file "$HOME/.alfredrc"
: "${ALFRED_HOME:=$HOME/.alfred}"
ALFRED_HOME="$(expand_user_path "$ALFRED_HOME")"
load_env_file "$ALFRED_HOME/.env" no_clobber
ALFRED_HOME="$(expand_user_path "$ALFRED_HOME")"
export ALFRED_HOME

CODE_MEMORY_VERSION="${ALFRED_CODE_MEMORY_VERSION:-v0.8.1}"
CODE_MEMORY_REPO="${ALFRED_CODE_MEMORY_REPO:-DeusData/codebase-memory-mcp}"
CODE_MEMORY_FETCH_TIMEOUT_S="${ALFRED_CODE_MEMORY_FETCH_TIMEOUT_S:-120}"
CODE_MEMORY_CONNECT_TIMEOUT_S="${ALFRED_CODE_MEMORY_CONNECT_TIMEOUT_S:-10}"
CODE_MEMORY_DISCOVERY_LIMIT="${ALFRED_CODE_MEMORY_DISCOVERY_LIMIT:-25}"

CACHE_BIN="$ALFRED_HOME/bin/$CODE_MEMORY_BIN_NAME"
INDEX_DIR="${ALFRED_CODE_MEMORY_INDEX_DIR:-$ALFRED_HOME/state/code-memory}"
CODE_MEMORY_HOME="${ALFRED_CODE_MEMORY_HOME:-$INDEX_DIR}"
CODE_MEMORY_CACHE_DIR="${CBM_CACHE_DIR:-$CODE_MEMORY_HOME/.cache/$CODE_MEMORY_BIN_NAME}"
WORKSPACE_ROOT="${WORKSPACE_ROOT:-$HOME/code}"
if [ "${ALFRED_WORKSPACE_SUBDIR+x}" = x ]; then
  WORKSPACE_SUBDIR="$ALFRED_WORKSPACE_SUBDIR"
elif [ "${WORKSPACE_SUBDIR+x}" != x ]; then
  WORKSPACE_SUBDIR="product"
fi
if [ -n "$WORKSPACE_SUBDIR" ]; then
  WORKSPACE="$WORKSPACE_ROOT/$WORKSPACE_SUBDIR"
else
  WORKSPACE="$WORKSPACE_ROOT"
fi

autofetch_enabled() {
  local value
  value="$(printf '%s' "${ALFRED_CODE_MEMORY_AUTOFETCH:-1}" | tr '[:upper:]' '[:lower:]')"
  case "$value" in
    0|false|no|off|"") return 1 ;;
    *) return 0 ;;
  esac
}

platform_tag() {
  # Go-style os-arch tag matching upstream release asset names, e.g.
  # codebase-memory-mcp-darwin-arm64.tar.gz.
  local os arch
  case "$(uname -s)" in
    Darwin) os="darwin" ;;
    Linux)  os="linux" ;;
    *) return 1 ;;
  esac
  case "$(uname -m)" in
    x86_64|amd64) arch="amd64" ;;
    arm64|aarch64) arch="arm64" ;;
    *) return 1 ;;
  esac
  printf '%s-%s' "$os" "$arch"
}

sha256_of() {
  # Print the lowercase hex sha256 of a file, using whatever tool is present.
  local file="$1"
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$file" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$file" | awk '{print $1}'
  else
    return 1
  fi
}

verify_checksum() {
  # Fail-closed sha256 check: 0 only when the file's digest equals the
  # expected one (case-insensitive). Any missing tool, unreadable file, empty
  # expectation, or mismatch is a failure so an unverified binary is never run.
  local file="$1" expected="$2" actual
  [ -n "$expected" ] || { log "no pinned sha256 for this platform; refusing unverified binary"; return 1; }
  [ -f "$file" ] || { log "checksum target missing: $file"; return 1; }
  actual="$(sha256_of "$file")" || { log "no sha256 tool (need sha256sum or shasum)"; return 1; }
  expected="$(printf '%s' "$expected" | tr '[:upper:]' '[:lower:]')"
  actual="$(printf '%s' "$actual" | tr '[:upper:]' '[:lower:]')"
  if [ "$actual" != "$expected" ]; then
    log "checksum MISMATCH for $(basename "$file"): expected $expected got $actual"
    return 1
  fi
  return 0
}

fetch_binary() {
  # Best-effort fetch of the pinned release tarball into the cache. The
  # download is sha256-verified against the pinned (published) digest before
  # anything is extracted or made executable; on any failure (including a
  # checksum mismatch) the partial download is deleted and we return non-zero,
  # so the caller degrades to a clean no-op and an unverified binary is never
  # run. Returns non-zero on any failure.
  command -v curl >/dev/null 2>&1 || { log "curl not found; cannot fetch"; return 1; }
  command -v tar >/dev/null 2>&1 || { log "tar not found; cannot extract"; return 1; }
  local tag asset url expected tmpdir tarball extracted
  tag="$(platform_tag)" || { log "unsupported platform for prebuilt binary"; return 1; }
  expected="$(pinned_sha256 "$tag")" || expected=""
  asset="${CODE_MEMORY_BIN_NAME}-${tag}.tar.gz"
  url="https://github.com/${CODE_MEMORY_REPO}/releases/download/${CODE_MEMORY_VERSION}/${asset}"
  tmpdir="$(mktemp -d)" || return 1
  tarball="$tmpdir/$asset"
  log "fetching ${CODE_MEMORY_REPO}@${CODE_MEMORY_VERSION} (${tag})"
  if ! curl -fsSL \
    --connect-timeout "$CODE_MEMORY_CONNECT_TIMEOUT_S" \
    --max-time "$CODE_MEMORY_FETCH_TIMEOUT_S" \
    "$url" -o "$tarball"; then
    log "download failed: $url"
    rm -rf "$tmpdir"
    return 1
  fi
  if ! verify_checksum "$tarball" "$expected"; then
    log "deleting unverified download and aborting"
    rm -rf "$tmpdir"
    return 1
  fi
  log "checksum verified ($tag)"
  if ! tar -xzf "$tarball" -C "$tmpdir" "$CODE_MEMORY_BIN_NAME" 2>/dev/null; then
    # Fall back to extracting the whole archive if the binary is nested.
    if ! tar -xzf "$tarball" -C "$tmpdir" 2>/dev/null; then
      log "extraction failed for $asset"
      rm -rf "$tmpdir"
      return 1
    fi
  fi
  extracted="$(find "$tmpdir" -type f -name "$CODE_MEMORY_BIN_NAME" -print -quit 2>/dev/null)"
  if [ -z "$extracted" ] || [ ! -f "$extracted" ]; then
    log "binary $CODE_MEMORY_BIN_NAME not found in $asset"
    rm -rf "$tmpdir"
    return 1
  fi
  mkdir -p "$(dirname "$CACHE_BIN")"
  chmod +x "$extracted"
  mv "$extracted" "$CACHE_BIN"
  rm -rf "$tmpdir"
  log "installed to $CACHE_BIN"
}

resolve_binary() {
  if [ -n "${ALFRED_CODE_MEMORY_BIN:-}" ] && [ -x "${ALFRED_CODE_MEMORY_BIN}" ]; then
    printf '%s' "$ALFRED_CODE_MEMORY_BIN"
    return 0
  fi
  local on_path
  on_path="$(command -v "$CODE_MEMORY_BIN_NAME" 2>/dev/null || true)"
  if [ -n "$on_path" ]; then
    printf '%s' "$on_path"
    return 0
  fi
  if [ -x "$CACHE_BIN" ]; then
    printf '%s' "$CACHE_BIN"
    return 0
  fi
  if autofetch_enabled && fetch_binary && [ -x "$CACHE_BIN" ]; then
    printf '%s' "$CACHE_BIN"
    return 0
  fi
  return 1
}

scope_raw() {
  printf '%s' "${ALFRED_CODE_MEMORY_REPOS:-${ALFRED_CODE_MAP_REPOS:-}}"
}

scope_raw_has_entries() {
  [ -n "$(scope_raw | tr -d '[:space:],')" ]
}

# In-scope repos for indexing: ALFRED_CODE_MEMORY_REPOS (comma-separated local
# dir names under WORKSPACE), falling back to ALFRED_CODE_MAP_REPOS so a single
# scope list drives both the planning code map and the code-memory index.
configured_scope_repos() {
  local raw="${ALFRED_CODE_MEMORY_REPOS:-${ALFRED_CODE_MAP_REPOS:-}}"
  printf '%s\n' "$raw" | tr ',' '\n' | while IFS= read -r name; do
    name="$(printf '%s' "$name" | tr -d '[:space:]')"
    [ -n "$name" ] || continue
    [ -d "$WORKSPACE/$name" ] || continue
    [ -e "$WORKSPACE/$name/.git" ] || continue
    printf '%s\n' "$WORKSPACE/$name"
  done
  return 0
}

discovery_limit() {
  case "$CODE_MEMORY_DISCOVERY_LIMIT" in
    ''|*[!0-9]*) printf '25' ;;
    0) printf '25' ;;
    *) printf '%s' "$CODE_MEMORY_DISCOVERY_LIMIT" ;;
  esac
}

discover_scope_repos() {
  local limit count dir child base real_dir seen_real
  local -a stack children
  limit="$(discovery_limit)"
  count=0
  [ -d "$WORKSPACE" ] || return 0
  stack=("$WORKSPACE")
  seen_real=""
  while [ "${#stack[@]}" -gt 0 ]; do
    dir="${stack[0]}"
    stack=("${stack[@]:1}")
    real_dir="$(cd "$dir" 2>/dev/null && pwd -P || printf '%s' "$dir")"
    case "
$seen_real
" in
      *"
$real_dir
"*) continue ;;
    esac
    seen_real="${seen_real}${real_dir}
"
    if [ -e "$dir/.git" ]; then
      printf '%s\n' "$dir"
      count=$((count + 1))
      [ "$count" -ge "$limit" ] && break
      continue
    fi
    children=()
    while IFS= read -r child; do
      base="${child##*/}"
      case "$base" in
        .archive|.cache|.external|.external-submissions|.venv|.worktrees|build|dist|node_modules|target|venv)
          continue
          ;;
      esac
      children+=("$child")
    done < <(find -L "$dir" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
    if [ "${#children[@]}" -gt 0 ]; then
      stack+=("${children[@]}")
    fi
  done
  return 0
}

scope_repos() {
  local configured
  if scope_raw_has_entries; then
    configured="$(configured_scope_repos)"
    if [ -n "$configured" ]; then
      printf '%s\n' "$configured"
      return 0
    fi
  fi
  discover_scope_repos
  return 0
}

scope_repo_summary() {
  local rel repo repos
  repos=""
  while IFS= read -r repo; do
    if [ "$repo" = "$WORKSPACE" ]; then
      rel="."
    else
      rel="${repo#"$WORKSPACE"/}"
    fi
    if [ -n "$repos" ]; then
      repos="$repos, $rel"
    else
      repos="$rel"
    fi
  done < <(scope_repos)
  if scope_raw_has_entries; then
    if [ -n "$(configured_scope_repos)" ]; then
      printf '%s' "$repos"
    elif [ -n "$repos" ]; then
      printf 'configured scope not found; auto-discovered: %s' "$repos"
    else
      printf 'configured scope not found; auto-discovered: none found'
    fi
  elif [ -n "$repos" ]; then
    printf 'auto-discovered: %s' "$repos"
  else
    printf 'auto-discovered: none found'
  fi
}

run_index() {
  local bin="$1" mode="$2" repo had=0
  mkdir -p "$CODE_MEMORY_HOME"
  while IFS= read -r repo; do
    [ -n "$repo" ] || continue
    had=1
    log "${mode}: $repo"
    # Upstream v0.8.x exposes indexing as an MCP CLI tool. It stores the graph
    # under "$HOME/.cache/codebase-memory-mcp", so pin HOME to Alfred's
    # configured code-memory home before invoking it. Failures are logged, not
    # fatal, so one bad repo never blocks the others.
    HOME="$CODE_MEMORY_HOME" "$bin" cli index_repository \
      "{\"repo_path\":$(json_string "$repo")}" \
      || log "${mode} failed for $repo (continuing)"
  done < <(scope_repos)
  if [ "$had" -eq 0 ]; then
    log "no in-scope repos found under $WORKSPACE (set ALFRED_CODE_MEMORY_REPOS or add git repos)"
  fi
}

json_string() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '"%s"' "$value"
}

# Default subcommand. When the scheduler launches us as the refresh agent it
# sets AGENT_CODENAME but passes no args (the conf/render path carries the
# script name only), so default to an incremental refresh rather than serve.
DEFAULT_CMD="serve"
case "${AGENT_CODENAME:-}" in
  code-memory-refresh|code-memory-index) DEFAULT_CMD="refresh" ;;
esac

CMD="${1:-$DEFAULT_CMD}"
[ "$#" -gt 0 ] && shift || true

case "$CMD" in
  serve)
    BIN="$(resolve_binary)" || {
      log "binary unavailable; code-memory MCP is a no-op this run"
      exit 0
    }
    mkdir -p "$CODE_MEMORY_HOME"
    HOME="$CODE_MEMORY_HOME" exec "$BIN" "$@"
    ;;
  index)
    BIN="$(resolve_binary)" || { log "binary unavailable; cannot index"; exit 0; }
    run_index "$BIN" "auto-index"
    ;;
  refresh)
    BIN="$(resolve_binary)" || { log "binary unavailable; cannot refresh"; exit 0; }
    run_index "$BIN" "refresh"
    ;;
  doctor)
    if BIN="$(resolve_binary)"; then
      log "binary:  $BIN"
      "$BIN" --version 2>/dev/null || log "version: (binary did not report)"
    else
      log "binary:  NOT RESOLVED (set ALFRED_CODE_MEMORY_BIN or enable autofetch)"
    fi
    log "version-pin: ${CODE_MEMORY_REPO}@${CODE_MEMORY_VERSION}"
    log "index-home:  $CODE_MEMORY_HOME"
    log "cache-dir:   $CODE_MEMORY_CACHE_DIR"
    log "workspace:   $WORKSPACE"
    log "repos:       $(scope_repo_summary)"
    ;;
  __scope-repos)
    scope_repos
    ;;
  __verify-checksum)
    # Internal, undocumented hook for the unit test: verify-checksum the file in
    # $1 against the expected sha256 in $2 (or, when $2 is a bare platform tag
    # like darwin-arm64, against the pinned digest for that tag). Exits 0 on a
    # match, non-zero (fail-closed) otherwise. Not part of the public CLI.
    file="${1:-}"; expected="${2:-}"
    case "$expected" in
      darwin-amd64|darwin-arm64|linux-amd64|linux-arm64)
        expected="$(pinned_sha256 "$expected")" || expected="" ;;
    esac
    verify_checksum "$file" "$expected"
    exit $?
    ;;
  *)
    log "unknown subcommand: $CMD (use serve|index|refresh|doctor)"
    exit 2
    ;;
esac
