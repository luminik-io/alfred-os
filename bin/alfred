NATIVE_DRY_RUN_SCRIPTS = {"lucius.py", "hello.py", "echo_summarise.py"}
PRIMARY_CLAUDE_DIR = Path.home() / ".claude"
SECONDARY_CLAUDE_DIR = Path.home() / ".claude-secondary"

