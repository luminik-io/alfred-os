#!/usr/bin/env python3
"""``alfred`` — operator CLI for the alfred-os fleet.

A small, dependency-free entry point covering the operator's day-to-day
verbs. Heavy logic lives in ``lib/agent_runner.py``; this file is just
arg-parsing and pretty-printing.

Subcommands today:

  alfred agents               List configured agents from ``agents.conf``
                              with role, schedule, resolved enable state,
                              and whether the host scheduler currently has
                              the unit loaded.
  alfred pause <codename|all> Stop scheduled firings for an agent. Writes a
                              marker at ``$ALFRED_HOME/state/_paused/<name>``
                              so the pause survives ``deploy.sh``, then
                              unloads the unit from the host scheduler
                              (launchd on macOS, systemd --user on Linux).
                              Already-running firings are not killed.
  alfred resume <codename|all>
                              Reverse a pause: remove the marker and reload
                              the unit. No-op if the agent was not paused.
  alfred run <codename>       Kick a single agent now (one-shot), killing
                              any in-flight firing first. Honors the pause
                              marker unless ``--force`` is passed.
  alfred enable <codename>    Add ``codename`` to the runner-level fleet
                              gate file.
                              Idempotent.
  alfred disable <codename>   Remove ``codename`` from the runner-level
                              fleet gate file. Idempotent.
  alfred enabled-agents       Print the parsed list of enabled codenames
                              (or explain that the gate file is missing).
  alfred engine status [agent]
                              Show resolved Claude/Codex engine mode for one
                              agent or the configured LLM runner fleet.
  alfred engine set <agent> <claude|codex|hybrid>
                              Persist an engine override in
                              $ALFRED_HOME/state/engines/<agent>.
                              Alias: provider.
  alfred codex [status|probe] Show Codex CLI availability and run a tiny
                              non-interactive probe.
  alfred auth [status|probe]  Check Claude Code and Codex CLI auth surfaces.
  alfred claude [status|primary|secondary|swap|probe]
                              Show or change the Claude account used by
                              scheduled agents.
  alfred status               Show local fleet health, locks, pauses, and
                              approval waits.
  alfred shipped              Summarize merged PRs, issues, LOC, and
                              model/config changes.

The runner-level fleet gate file lives at
``$ALFRED_HOME/state/fleet/enabled.txt``. Listed codenames are enabled.
Missing codenames fall back to each runner's default: stable agents are
default-enabled, while opt-in agents such as Batman default to disabled
until explicitly enabled.

Pure stdlib. The operator reads this file when something breaks; keep
it that way — no external deps.
"""

from __future__ import annotations

import argparse
import ast
import json
import os
import shlex
import shutil
import subprocess
import sys
import tempfile
from datetime import UTC, datetime
from pathlib import Path

# Resolve lib/ relative to the script regardless of how it was invoked.
# In the fleet layout the script lives in ``$ALFRED_HOME/bin/`` and the
# library in ``$ALFRED_HOME/lib/``; in a checkout the script lives in
# ``<repo>/bin/`` and the library in ``<repo>/lib/``. Add both candidate
# parents to sys.path so either layout works without packaging.
_HERE = Path(__file__).resolve().parent
for candidate in (
    _HERE.parent / "lib",
    Path(os.environ.get("ALFRED_HOME", "")) / "lib",
):
    if candidate.exists() and str(candidate) not in sys.path:
        sys.path.insert(0, str(candidate))

import agent_runner  # noqa: E402
import scheduler  # noqa: E402

OPT_IN_AGENTS = {"batman"}
ENGINE_AGENTS = ("bane", "batman", "drake", "lucius", "nightwing", "rasalghul", "robin")
ENGINE_SCRIPTS = tuple(f"{agent}.py" for agent in ENGINE_AGENTS)
PRIMARY_CLAUDE_DIR = Path.home() / ".claude"
SECONDARY_CLAUDE_DIR = Path.home() / ".claude-secondary"


def _default_enabled(codename: str) -> bool:
    return codename not in OPT_IN_AGENTS


def _agents_conf_path() -> Path:
    """Return the path to ``agents.conf``.

    Prefers ``$ALFRED_HOME/launchd/agents.conf`` (deployed location);
    falls back to ``<repo>/launchd/agents.conf`` for in-checkout use.
    """
    candidates = [
        Path(os.environ.get("ALFRED_HOME", "")) / "launchd" / "agents.conf",
        _HERE.parent / "launchd" / "agents.conf",
        _HERE.parent / "launchd" / "agents.conf.example",
    ]
    for p in candidates:
        if p and p.exists():
            return p
    return candidates[-1]


def _parse_agents_conf(path: Path) -> list[dict[str, str]]:
    """Return the list of agent records from ``agents.conf``.

    Each record is a dict with keys ``label, script, schedule,
    needs_java, log_stem, role, disabled``. ``disabled`` is True when
    the conf line is commented out (``#my.fleet.batman ...``).
    """
    if not path.exists():
        return []
    out: list[dict[str, str]] = []
    for raw in path.read_text().splitlines():
        line = raw.rstrip("\n")
        stripped = line.lstrip()
        if not stripped:
            continue
        if stripped.startswith("# ") or stripped == "#":
            continue
        disabled = False
        if stripped.startswith("#"):
            # Heuristic: a commented agent line still has tabs in it.
            # (Plain comments like "# Format: ..." are dropped above.)
            if "\t" not in stripped:
                continue
            disabled = True
            stripped = stripped.lstrip("#").lstrip()
        cols = stripped.split("\t")
        # Pad to 6 columns so missing trailing fields don't IndexError.
        cols = cols + [""] * (6 - len(cols))
        label, script, schedule, needs_java, log_stem, role = cols[:6]
        if not label:
            continue
        out.append(
            {
                "label": label,
                "script": script,
                "schedule": schedule,
                "needs_java": needs_java,
                "log_stem": log_stem,
                "role": role,
                "disabled": "yes" if disabled else "no",
            }
        )
    return out


def _codename_from_label(label: str) -> str:
    """Last dot-segment of a launchd label is the codename."""
    return label.rsplit(".", 1)[-1] if "." in label else label


def cmd_agents(_args: argparse.Namespace) -> int:
    conf = _agents_conf_path()
    agents = _parse_agents_conf(conf)
    if not agents:
        print(f"alfred: no agents found at {conf}", file=sys.stderr)
        return 0

    loaded_labels = scheduler.loaded_labels()
    pause_dir = agent_runner.STATE_ROOT / "_paused"
    rows = []
    for a in agents:
        codename = _codename_from_label(a["label"])
        enabled = agent_runner.is_agent_enabled(codename, default=_default_enabled(codename))
        if (pause_dir / codename).exists():
            loaded = "paused"
        elif a["disabled"] == "yes":
            loaded = "off"
        elif a["label"] in loaded_labels:
            loaded = "yes"
        else:
            loaded = "no"
        rows.append(
            (
                codename,
                a["schedule"] or "-",
                "off" if a["disabled"] == "yes" else "on",
                loaded,
                "yes" if enabled else "no",
                a["role"] or "-",
            )
        )

    headers = ("codename", "schedule", "configured", "loaded", "enabled", "role")
    widths = [max(len(h), max((len(r[i]) for r in rows), default=0)) for i, h in enumerate(headers)]
    fmt = "  ".join(f"{{:<{w}}}" for w in widths)
    print(fmt.format(*headers))
    print(fmt.format(*("-" * w for w in widths)))
    for r in rows:
        print(fmt.format(*r))

    if not agent_runner.FLEET_ENABLED_FILE.exists():
        print(
            f"\nFleet gate file missing ({agent_runner.FLEET_ENABLED_FILE}); "
            "default-enabled agents are shown as enabled, while opt-in agents "
            "such as Batman stay disabled until `alfred enable <codename>`."
        )
    return 0


def cmd_enable(args: argparse.Namespace) -> int:
    out = agent_runner.enable_agent(args.codename)
    print(f"alfred: enabled {args.codename}")
    print(f"alfred: {len(out)} agent(s) now enabled: {', '.join(out) or '(none)'}")
    return 0


def cmd_disable(args: argparse.Namespace) -> int:
    out = agent_runner.disable_agent(args.codename)
    print(f"alfred: disabled {args.codename}")
    print(f"alfred: {len(out)} agent(s) now enabled: {', '.join(out) or '(none)'}")
    return 0


def cmd_enabled_agents(_args: argparse.Namespace) -> int:
    if not agent_runner.FLEET_ENABLED_FILE.exists():
        print(
            f"alfred: fleet gate file missing ({agent_runner.FLEET_ENABLED_FILE}); "
            "listed opt-in gates are empty, so each runner falls back to its default."
        )
        return 0
    enabled = agent_runner.list_enabled_agents()
    if not enabled:
        print("alfred: 0 agents enabled (file present but empty)")
        return 0
    for c in enabled:
        print(c)
    return 0


# ----- scheduler-backed pause / resume / run -----
#
# alfred-os labels are operator-defined (``my.fleet.lucius``,
# ``alfred.cleanup``, ...); there is no fixed prefix to bolt a codename
# onto. So pause/resume/run accept a codename and resolve it to the full
# label via agents.conf. The scheduler module handles the launchd/systemd
# split underneath.


def _label_map() -> dict[str, str]:
    """codename -> full label, from agents.conf (commented rows included)."""
    out: dict[str, str] = {}
    for record in _parse_agents_conf(_agents_conf_path()):
        codename = _codename_from_label(record["label"])
        if codename:
            out.setdefault(codename, record["label"])
    return out


def _resolve_label(name: str) -> str | None:
    """Accept a codename or a full label; return the full label or None."""
    mapping = _label_map()
    if name in mapping:
        return mapping[name]
    # Already a full label present in agents.conf?
    if name in mapping.values():
        return name
    return None


def _pause_dir() -> Path:
    return agent_runner.STATE_ROOT / "_paused"


def _pause_one(codename: str, label: str) -> None:
    pause_dir = _pause_dir()
    pause_dir.mkdir(parents=True, exist_ok=True)
    marker = pause_dir / codename
    marker.write_text(datetime.now(UTC).strftime("%Y-%m-%dT%H:%M:%SZ") + "\n", encoding="utf-8")
    if scheduler.unit_loaded(label):
        scheduler.unit_unload(label)
        print(f"  paused {codename} (was loaded; unloaded from {scheduler.SCHEDULER})")
    else:
        print(f"  paused {codename} (was not loaded; marker set)")


def _resume_one(codename: str, label: str) -> int:
    marker = _pause_dir() / codename
    if marker.exists():
        marker.unlink()
    unit_path = scheduler.unit_file(label)
    if unit_path is None or not unit_path.exists():
        where = unit_path if unit_path is not None else "(no scheduler on this host)"
        print(
            f"  {codename}: no unit file at {where} — run `bash deploy.sh` first", file=sys.stderr
        )
        return 1
    if scheduler.unit_loaded(label):
        print(f"  resumed {codename} (already loaded; marker cleared)")
        return 0
    detail = scheduler.unit_load(label, unit_path)
    suffix = f" ({detail})" if detail else ""
    print(f"  resumed {codename}{suffix}")
    return 0


def cmd_pause(args: argparse.Namespace) -> int:
    if not scheduler.supported():
        print(
            f"alfred pause: no supported host scheduler ({scheduler.SCHEDULER}); "
            "pause/resume need launchd (macOS) or systemd --user (Linux).",
            file=sys.stderr,
        )
        return 2
    mapping = _label_map()
    targets = sorted(mapping) if args.codename == "all" else [args.codename]
    rc = 0
    for codename in targets:
        label = mapping.get(codename) or _resolve_label(codename)
        if label is None:
            print(f"alfred pause: unknown agent '{codename}'", file=sys.stderr)
            rc = 1
            continue
        _pause_one(_codename_from_label(label), label)
    return rc


def cmd_resume(args: argparse.Namespace) -> int:
    if not scheduler.supported():
        print(
            f"alfred resume: no supported host scheduler ({scheduler.SCHEDULER}); "
            "pause/resume need launchd (macOS) or systemd --user (Linux).",
            file=sys.stderr,
        )
        return 2
    mapping = _label_map()
    targets = sorted(mapping) if args.codename == "all" else [args.codename]
    rc = 0
    for codename in targets:
        label = mapping.get(codename) or _resolve_label(codename)
        if label is None:
            print(f"alfred resume: unknown agent '{codename}'", file=sys.stderr)
            rc = 1
            continue
        rc = _resume_one(_codename_from_label(label), label) or rc
    return rc


def cmd_run(args: argparse.Namespace) -> int:
    if not scheduler.supported():
        print(
            f"alfred run: no supported host scheduler ({scheduler.SCHEDULER}); "
            "run needs launchd (macOS) or systemd --user (Linux).",
            file=sys.stderr,
        )
        return 2
    if args.codename == "all":
        print(
            "alfred run: 'all' is intentionally not supported (would stampede the host)",
            file=sys.stderr,
        )
        return 2
    label = _resolve_label(args.codename)
    if label is None:
        print(f"alfred run: unknown agent '{args.codename}'", file=sys.stderr)
        return 1
    codename = _codename_from_label(label)
    if not args.force and (_pause_dir() / codename).exists():
        print(f"  {codename}: paused; pass --force to override", file=sys.stderr)
        return 1
    if not scheduler.unit_loaded(label):
        print(f"  {codename}: not loaded; run `alfred resume {codename}` first", file=sys.stderr)
        return 1
    detail = scheduler.unit_kickstart(label)
    suffix = f" ({detail})" if detail else ""
    print(f"  kicked {codename}{suffix}")
    return 0


def _normalize_agent_name(agent: str) -> str:
    raw = agent.strip().lower()
    aliases = {
        "review": "rasalghul",
        "ras": "rasalghul",
        "ras-al-ghul": "rasalghul",
        "tim": "drake",
        "tim-drake": "drake",
        "night-wing": "nightwing",
    }
    return aliases.get(raw, raw)


def _engine_state_file(agent: str) -> Path:
    return agent_runner.STATE_ROOT / "engines" / agent


def _engine_agent_codenames() -> tuple[str, ...]:
    seen = list(ENGINE_AGENTS)
    for record in _parse_agents_conf(_agents_conf_path()):
        if Path(record["script"]).name not in ENGINE_SCRIPTS:
            continue
        codename = _codename_from_label(record["label"])
        if codename and codename not in seen:
            seen.append(codename)
    return tuple(seen)


def _engine_behavior(mode: str) -> str:
    resolved = agent_runner.normalize_engine(mode)
    if resolved == "claude":
        return "Claude Code only"
    if resolved == "codex":
        return "Codex only"
    return "Claude Code first, Codex fallback on Claude auth/limit/budget errors"


def _require_engine_agent(agent: str) -> str:
    normalized = _normalize_agent_name(agent)
    supported_agents = _engine_agent_codenames()
    if normalized not in supported_agents:
        supported = ", ".join(supported_agents)
        raise ValueError(f"unsupported engine-aware agent '{normalized}'. Supported: {supported}")
    return normalized


def cmd_engine_status(args: argparse.Namespace) -> int:
    if args.agent:
        try:
            agent = _require_engine_agent(args.agent)
        except ValueError as e:
            print(f"alfred engine: {e}", file=sys.stderr)
            return 2
        mode = agent_runner.agent_engine(
            agent,
            legacy_env="ALFRED_REVIEW_ENGINE" if agent == "rasalghul" else None,
            legacy_state_file=(
                agent_runner.STATE_ROOT / "review-engine" if agent == "rasalghul" else None
            ),
        )
        print(f"{agent} engine: {mode}")
        print(f"state file: {_engine_state_file(agent)}")
        print(f"behavior: {_engine_behavior(mode)}")
        return 0

    headers = ("agent", "engine", "behavior")
    rows = []
    for agent in _engine_agent_codenames():
        mode = agent_runner.agent_engine(
            agent,
            legacy_env="ALFRED_REVIEW_ENGINE" if agent == "rasalghul" else None,
            legacy_state_file=(
                agent_runner.STATE_ROOT / "review-engine" if agent == "rasalghul" else None
            ),
        )
        rows.append((agent, mode, _engine_behavior(mode)))
    widths = [max(len(h), max((len(r[i]) for r in rows), default=0)) for i, h in enumerate(headers)]
    fmt = "  ".join(f"{{:<{w}}}" for w in widths)
    print(fmt.format(*headers))
    print(fmt.format(*("-" * w for w in widths)))
    for row in rows:
        print(fmt.format(*row))
    return 0


def cmd_engine_set(args: argparse.Namespace) -> int:
    try:
        agent = _require_engine_agent(args.agent)
    except ValueError as e:
        print(f"alfred engine: {e}", file=sys.stderr)
        return 2
    mode = agent_runner.normalize_engine(args.mode)
    target = _engine_state_file(agent)
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(mode + "\n", encoding="utf-8")
    if agent == "rasalghul":
        (agent_runner.STATE_ROOT / "review-engine").write_text(mode + "\n", encoding="utf-8")
    print(f"alfred: {agent} engine set to {mode}")
    print(f"alfred: wrote {target}")
    return 0


def _print_engine_roster() -> None:
    for agent in _engine_agent_codenames():
        mode = agent_runner.agent_engine(
            agent,
            legacy_env="ALFRED_REVIEW_ENGINE" if agent == "rasalghul" else None,
            legacy_state_file=(
                agent_runner.STATE_ROOT / "review-engine" if agent == "rasalghul" else None
            ),
        )
        print(f"engine {agent}: {mode} ({_engine_behavior(mode)})")


def _codex_status() -> int:
    binary = agent_runner.CODEX_BIN
    binary_path = Path(binary)
    resolved = str(binary_path) if binary_path.is_absolute() and binary_path.exists() else None
    if not resolved and not binary_path.is_absolute():
        resolved = shutil.which(binary)
    if not resolved:
        print(f"codex: not found on PATH ({binary})", file=sys.stderr)
        print("Set CODEX_BIN in ~/.alfredrc or install/sign in to Codex CLI.", file=sys.stderr)
        return 1

    print(f"codex binary: {resolved}")
    result = subprocess.run(
        [resolved, "--version"],
        check=False,
        capture_output=True,
        text=True,
        timeout=15,
    )
    version = (result.stdout or result.stderr).strip()
    if version:
        print(f"codex version: {version}")
    else:
        print(f"codex version: unavailable (exit {result.returncode})")
    print("")
    _print_engine_roster()
    print("")
    print("Probe with: alfred codex probe")
    return 0 if result.returncode == 0 else result.returncode


def _probe_codex() -> int:
    binary = agent_runner.CODEX_BIN
    binary_path = Path(binary)
    resolved = str(binary_path) if binary_path.is_absolute() and binary_path.exists() else None
    if not resolved and not binary_path.is_absolute():
        resolved = shutil.which(binary)
    if not resolved:
        print(f"codex probe: failed; binary not found ({binary})", file=sys.stderr)
        return 1

    probe_dir = Path.cwd()
    if not (probe_dir / ".git").exists():
        probe_dir = _HERE.parent
    out_dir = Path(tempfile.mkdtemp(prefix="alfred-codex-probe-"))
    last = out_dir / "last.md"
    prompt = "Reply with exactly: ALFRED_CODEX_OK"
    cmd = [
        resolved,
        "exec",
        "--skip-git-repo-check",
        "--cd",
        str(probe_dir),
        "--sandbox",
        "read-only",
        "-c",
        'approval_policy="never"',
        "--output-last-message",
        str(last),
        "-",
    ]
    print(f"Probing Codex CLI auth in {probe_dir}")
    print(f"Probe artifacts: {out_dir}")
    try:
        result = subprocess.run(
            cmd,
            input=prompt,
            check=False,
            capture_output=True,
            text=True,
            timeout=120,
        )
    except subprocess.TimeoutExpired:
        print("Codex probe: failed")
        print("codex probe timed out after 120s", file=sys.stderr)
        return 1

    (out_dir / "stdout.txt").write_text(result.stdout or "", encoding="utf-8")
    (out_dir / "stderr.txt").write_text(result.stderr or "", encoding="utf-8")
    body = ""
    if last.exists():
        body = last.read_text(encoding="utf-8", errors="replace").strip()
    if result.returncode == 0 and "ALFRED_CODEX_OK" in body:
        print("Codex probe: ok")
        print(f"last message: {last}")
        return 0
    print("Codex probe: failed")
    if body:
        print(f"last message: {body[:500]}")
    tail = (result.stderr or result.stdout or "")[-800:].strip()
    if tail:
        print(tail)
    return 1


def cmd_codex(args: argparse.Namespace) -> int:
    command = args.codex_command
    if command in ("status", ""):
        return _codex_status()
    if command == "probe":
        return _probe_codex()
    print("Usage: alfred codex {status|probe}", file=sys.stderr)
    return 2


def cmd_shipped(args: argparse.Namespace) -> int:
    script = _HERE / "alfred-shipped-summary.py"
    cmd = [sys.executable, str(script), "--period", args.period]
    if args.days is not None:
        cmd.extend(["--days", str(args.days)])
    if args.since:
        cmd.extend(["--since", args.since])
    if args.until:
        cmd.extend(["--until", args.until])
    for repo in args.repo or []:
        cmd.extend(["--repo", repo])
    if args.json:
        cmd.append("--json")
    if args.slack:
        cmd.append("--slack")
    if args.no_file_scan:
        cmd.append("--no-file-scan")
    return subprocess.run(cmd, check=False).returncode


def cmd_status(args: argparse.Namespace) -> int:
    script = _HERE / "alfred-status.py"
    cmd = [sys.executable, str(script)]
    if args.json:
        cmd.append("--json")
    if args.slack:
        cmd.append("--slack")
    return subprocess.run(cmd, check=False).returncode


def _launchctl(args: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(["launchctl", *args], check=False, capture_output=True, text=True)


def _systemctl_user(args: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["systemctl", "--user", *args],
        check=False,
        capture_output=True,
        text=True,
        timeout=15,
    )


def _decode_systemd_env_value(value: str) -> str:
    try:
        if value.startswith("$'") and value.endswith("'"):
            return str(ast.literal_eval("'" + value[2:-1] + "'"))
        if value.startswith(("'", '"')):
            parts = shlex.split(value)
            return parts[0] if parts else ""
    except Exception:
        return value
    return value


def _current_claude_dir() -> str:
    if scheduler.SCHEDULER == "launchd":
        if not shutil.which("launchctl"):
            return os.environ.get("CLAUDE_CONFIG_DIR", "")
        result = _launchctl(["getenv", "CLAUDE_CONFIG_DIR"])
        if result.returncode != 0:
            return ""
        return result.stdout.strip()
    if scheduler.SCHEDULER == "systemd":
        result = _systemctl_user(["show-environment"])
        if result.returncode != 0:
            return os.environ.get("CLAUDE_CONFIG_DIR", "")
        for line in result.stdout.splitlines():
            key, _, value = line.partition("=")
            if key == "CLAUDE_CONFIG_DIR":
                return _decode_systemd_env_value(value)
        return ""
    return os.environ.get("CLAUDE_CONFIG_DIR", "")


def _current_claude_label() -> str:
    value = _current_claude_dir()
    if not value or value == str(PRIMARY_CLAUDE_DIR):
        return "primary (~/.claude)"
    if value == str(SECONDARY_CLAUDE_DIR):
        return "secondary (~/.claude-secondary)"
    return f"custom ({value})"


def _claude_auth_mtime(path: Path) -> str:
    auth_file = path / ".claude.json"
    if not auth_file.exists():
        return "no .claude.json"
    return datetime.fromtimestamp(auth_file.stat().st_mtime).strftime("%Y-%m-%d %H:%M")


def _count_scheduled_agents() -> int | None:
    if not scheduler.supported():
        return None
    labels = scheduler.loaded_labels()
    prefix = os.environ.get("FLEET_LABEL_PREFIX", "")
    if prefix:
        return sum(1 for label in labels if label.startswith(prefix))
    return sum(
        1 for label in labels if any(token in label for token in ("agent", "fleet", "alfred"))
    )


def _claude_status() -> int:
    print(f"Current routing for scheduled agents: {_current_claude_label()}")
    print("")
    print("Auth dir state:")
    for label, directory in (
        ("primary:", PRIMARY_CLAUDE_DIR),
        ("secondary:", SECONDARY_CLAUDE_DIR),
    ):
        if directory.exists():
            print(f"  {label:<12} {directory}   (last touched: {_claude_auth_mtime(directory)})")
        else:
            print(f"  {label:<12} {directory}   (NOT PRESENT)")
    print("")
    agent_count = _count_scheduled_agents()
    if agent_count is None:
        print("Live scheduled agents: unavailable (no supported host scheduler)")
    else:
        print(f"Live {scheduler.SCHEDULER} agents: {agent_count}")
    print("")
    print("Switch with: alfred claude {primary|secondary|swap}")
    print("Verify real API auth with: alfred claude probe")
    return 0


def _set_claude_dir(path: Path, label: str) -> int:
    if scheduler.SCHEDULER not in {"launchd", "systemd"}:
        print(
            "alfred claude: no supported host scheduler; set CLAUDE_CONFIG_DIR "
            f"to {path} in your shell or cron.",
            file=sys.stderr,
        )
        return 2
    if label == "secondary" and not path.exists():
        print(f"ERROR: {path} not present. Set it up first:", file=sys.stderr)
        print(f"  CLAUDE_CONFIG_DIR={path} claude   # then complete login", file=sys.stderr)
        return 2
    if scheduler.SCHEDULER == "launchd":
        if not shutil.which("launchctl"):
            print(
                "alfred claude: launchctl is not available; set CLAUDE_CONFIG_DIR "
                f"to {path} manually.",
                file=sys.stderr,
            )
            return 2
        result = _launchctl(["setenv", "CLAUDE_CONFIG_DIR", str(path)])
    else:
        result = _systemctl_user(["set-environment", f"CLAUDE_CONFIG_DIR={path}"])
    if result.returncode != 0:
        print(
            result.stderr.strip()
            or f"alfred claude: {scheduler.SCHEDULER} environment update failed",
            file=sys.stderr,
        )
        return result.returncode
    print(f"Agents now route to {label.upper()} ({path}). Next firing of each agent picks this up.")
    return 0


def _swap_claude_dir() -> int:
    if _current_claude_dir() == str(SECONDARY_CLAUDE_DIR):
        return _set_claude_dir(PRIMARY_CLAUDE_DIR, "primary")
    return _set_claude_dir(SECONDARY_CLAUDE_DIR, "secondary")


def _probe_claude_auth() -> int:
    print(f"Probing Claude Code API auth for {_current_claude_label()}")
    print("This sends one tiny non-interactive Claude request when auth is healthy.")
    env = os.environ.copy()
    current = _current_claude_dir()
    if current:
        env["CLAUDE_CONFIG_DIR"] = current
    cmd = [
        "claude",
        "-p",
        "Reply exactly ALFRED_CLAUDE_OK",
        "--output-format",
        "json",
        "--max-turns",
        "1",
        "--model",
        "claude-haiku-4-5",
    ]
    try:
        result = subprocess.run(
            cmd, check=False, capture_output=True, text=True, timeout=90, env=env
        )
    except FileNotFoundError:
        print("Claude probe: failed")
        print("claude binary not found on PATH", file=sys.stderr)
        return 1
    except subprocess.TimeoutExpired:
        print("Claude probe: failed")
        print("claude probe timed out after 90s", file=sys.stderr)
        return 1

    payload = result.stdout.strip() or result.stderr.strip()
    try:
        data = json.loads(payload)
        body = str(data.get("result") or "")
        summary = (
            f"exit_json subtype={data.get('subtype')} is_error={data.get('is_error')} "
            f"api_error_status={data.get('api_error_status')} result={body[:300]}"
        )
    except json.JSONDecodeError:
        body = payload
        summary = payload[-500:]
    if result.returncode == 0 and "ALFRED_CLAUDE_OK" in body:
        print("Claude probe: ok")
        return 0
    print("Claude probe: failed")
    print(summary)
    return 1


def cmd_claude(args: argparse.Namespace) -> int:
    command = args.claude_command
    if command in ("status", ""):
        return _claude_status()
    if command in ("primary", "main"):
        return _set_claude_dir(PRIMARY_CLAUDE_DIR, "primary")
    if command in ("secondary", "2"):
        return _set_claude_dir(SECONDARY_CLAUDE_DIR, "secondary")
    if command in ("swap", "toggle"):
        return _swap_claude_dir()
    if command == "probe":
        return _probe_claude_auth()
    print("Usage: alfred claude {status|primary|secondary|swap|probe}", file=sys.stderr)
    return 2


def cmd_auth(args: argparse.Namespace) -> int:
    command = args.auth_command
    if command in ("status", ""):
        claude_rc = _claude_status()
        print("")
        codex_rc = _codex_status()
        return 0 if claude_rc == 0 and codex_rc == 0 else 1
    if command == "probe":
        claude_rc = _probe_claude_auth()
        print("")
        codex_rc = _probe_codex()
        return 0 if claude_rc == 0 and codex_rc == 0 else 1
    print("Usage: alfred auth {status|probe}", file=sys.stderr)
    return 2


def main(argv: list[str] | None = None) -> int:
    p = argparse.ArgumentParser(prog="alfred", description="Alfred operator CLI")
    sub = p.add_subparsers(dest="command", required=True)

    p_agents = sub.add_parser("agents", help="list configured agents")
    p_agents.set_defaults(func=cmd_agents)

    p_enable = sub.add_parser("enable", help="list an agent in the runner gate file")
    p_enable.add_argument("codename")
    p_enable.set_defaults(func=cmd_enable)

    p_disable = sub.add_parser("disable", help="remove an agent from the runner gate file")
    p_disable.add_argument("codename")
    p_disable.set_defaults(func=cmd_disable)

    p_enabled = sub.add_parser("enabled-agents", help="print the list of enabled codenames")
    p_enabled.set_defaults(func=cmd_enabled_agents)

    p_pause = sub.add_parser("pause", help="stop scheduled firings for an agent")
    p_pause.add_argument("codename", help="agent codename, or 'all'")
    p_pause.set_defaults(func=cmd_pause)

    p_resume = sub.add_parser("resume", help="reverse a pause")
    p_resume.add_argument("codename", help="agent codename, or 'all'")
    p_resume.set_defaults(func=cmd_resume)

    p_run = sub.add_parser("run", help="kick a single agent now (one-shot)")
    p_run.add_argument("codename", help="agent codename")
    p_run.add_argument("--force", action="store_true", help="run even if the agent is paused")
    p_run.set_defaults(func=cmd_run)

    p_status = sub.add_parser("status", help="show local fleet health")
    p_status.add_argument("--json", action="store_true")
    p_status.add_argument("--slack", action="store_true")
    p_status.set_defaults(func=cmd_status)

    p_engine = sub.add_parser("engine", aliases=["provider"], help="manage per-agent engines")
    engine_sub = p_engine.add_subparsers(dest="engine_command", required=True)
    p_engine_status = engine_sub.add_parser("status", help="show resolved engine state")
    p_engine_status.add_argument("agent", nargs="?")
    p_engine_status.set_defaults(func=cmd_engine_status)
    p_engine_set = engine_sub.add_parser("set", help="set one agent's engine")
    p_engine_set.add_argument("agent")
    p_engine_set.add_argument("mode", choices=["claude", "codex", "hybrid", "both"])
    p_engine_set.set_defaults(func=cmd_engine_set)

    p_claude = sub.add_parser("claude", help="manage Claude Code account routing")
    p_claude.add_argument(
        "claude_command",
        nargs="?",
        default="status",
        metavar="{status,primary,secondary,swap,probe}",
    )
    p_claude.set_defaults(func=cmd_claude)

    p_codex = sub.add_parser("codex", help="inspect Codex CLI availability/auth")
    p_codex.add_argument(
        "codex_command",
        nargs="?",
        default="status",
        metavar="{status,probe}",
    )
    p_codex.set_defaults(func=cmd_codex)

    p_auth = sub.add_parser("auth", help="inspect Claude Code and Codex auth surfaces")
    p_auth.add_argument(
        "auth_command",
        nargs="?",
        default="status",
        metavar="{status,probe}",
    )
    p_auth.set_defaults(func=cmd_auth)

    p_shipped = sub.add_parser("shipped", help="summarize shipped GitHub activity")
    p_shipped.add_argument("--period", choices=["daily", "weekly"], default="daily")
    p_shipped.add_argument("--days", type=int)
    p_shipped.add_argument("--since")
    p_shipped.add_argument("--until")
    p_shipped.add_argument("--repo", action="append")
    p_shipped.add_argument("--json", action="store_true")
    p_shipped.add_argument("--slack", action="store_true")
    p_shipped.add_argument("--no-file-scan", action="store_true")
    p_shipped.set_defaults(func=cmd_shipped)

    args = p.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
