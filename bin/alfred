_EXTRA_BOOTSTRAP_LABELS: tuple[tuple[str, str, str], ...] = (
    ("agent:authored", "1d76db", "PR authored by an Alfred agent."),
    (
        "agent:plan-pending-approval",
        "fbca04",
        "Batman drafted a plan and is waiting for operator approval.",
    ),
    ("do-not-review", "cccccc", "Operator override: automated reviewers must skip this PR."),
    ("do-not-merge", "b60205", "Operator override: automerge must skip this PR."),
    ("needs:info", "d4c5f9", "Reporter needs to provide more detail."),
    ("needs:triage", "fef2c0", "Needs triage."),
    ("bug", "ee0701", "Confirmed bug."),
    ("test-coverage", "bfdadc", "Test coverage work."),
    ("severity:p0", "b60205", "Production broken, data loss, or security leak."),
    ("severity:p1", "d93f0b", "User-visible bug, not blocking."),
    ("severity:p2", "fbca04", "Minor or polish issue."),
    ("severity:p3", "0e8a16", "Trivial or won't fix."),
)


def _label_bootstrap_catalog() -> list[tuple[str, str, str]]:
    """Return the repo label catalogue used by setup and standalone bootstrap."""
    out: dict[str, tuple[str, str, str]] = {}
    for name, color, desc in (
        *agent_runner.LIFECYCLE_LABELS,
        *agent_runner.STANDARD_LABELS,
        *_EXTRA_BOOTSTRAP_LABELS,
    ):
        out.setdefault(name, (name, color, desc))
    return list(out.values())


def _full_repo_arg(repo: str) -> str:
    if "/" in repo:
        return repo
    gh_org = os.environ.get("GH_ORG", "").strip()
    if not gh_org:
        raise ValueError(f"GH_ORG is unset; pass a full repo slug like owner/{repo}")
    return f"{gh_org}/{repo}"


def _fleet_repos_from_env() -> list[str]:
    """Collect repos from the fleet's comma-separated repo env vars."""
    keys = sorted(k for k in os.environ if k.startswith("ALFRED_") and k.endswith("_REPOS"))
    keys.extend(["LABEL_STATE_SWEEP_REPOS", "ALFRED_CLAIM_SWEEP_REPOS"])
    seen: set[str] = set()
    repos: list[str] = []
    for key in keys:
        for raw in os.environ.get(key, "").split(","):
            repo = raw.strip()
            if not repo or repo in seen:
                continue
            seen.add(repo)
            repos.append(repo)
    return repos


def _load_repo_labels(repo: str) -> dict[str, dict[str, str]]:
    result = subprocess.run(
        ["gh", "label", "list", "-R", repo, "--json", "name,color,description", "--limit", "500"],
        check=False,
        capture_output=True,
        text=True,
        timeout=30,
    )
    if result.returncode != 0:
        detail = (result.stderr or result.stdout).strip()
        raise RuntimeError(f"gh label list failed for {repo}: {detail}")
    try:
        labels = json.loads(result.stdout or "[]")
    except json.JSONDecodeError as exc:
        raise RuntimeError(f"gh label list returned invalid JSON for {repo}: {exc}") from exc
    return {
        str(row.get("name")): {
            "color": str(row.get("color") or "").lstrip("#").lower(),
            "description": str(row.get("description") or ""),
        }
        for row in labels
        if row.get("name")
    }


def _gh_label_create(repo: str, name: str, color: str, desc: str) -> int:
    result = subprocess.run(
        [
            "gh",
            "label",
            "create",
            name,
            "--color",
            color,
            "--description",
            desc,
            "-R",
            repo,
        ],
        check=False,
        capture_output=True,
        text=True,
        timeout=30,
    )
    if result.returncode != 0:
        print((result.stderr or result.stdout).strip(), file=sys.stderr)
    return result.returncode


def _gh_label_edit(repo: str, name: str, color: str, desc: str) -> int:
    result = subprocess.run(
        [
            "gh",
            "label",
            "edit",
            name,
            "--color",
            color,
            "--description",
            desc,
            "-R",
            repo,
        ],
        check=False,
        capture_output=True,
        text=True,
        timeout=30,
    )
    if result.returncode != 0:
        print((result.stderr or result.stdout).strip(), file=sys.stderr)
    return result.returncode


def _labels_bootstrap_one(repo_arg: str, *, check: bool, force: bool) -> int:
    try:
        repo = _full_repo_arg(repo_arg)
    except ValueError as exc:
        print(f"alfred labels: {exc}", file=sys.stderr)
        return 2

    try:
        existing = _load_repo_labels(repo)
    except RuntimeError as exc:
        print(f"alfred labels: {exc}", file=sys.stderr)
        return 1

    print(f"==> labels {'check' if check else 'bootstrap'} on {repo}")
    rc = 0
    missing: list[tuple[str, str, str]] = []
    for name, color, desc in _label_bootstrap_catalog():
        current = existing.get(name)
        if current is None:
            missing.append((name, color, desc))
            if check:
                print(f"  x {name} (MISSING)")
                continue
            created = _gh_label_create(repo, name, color, desc)
            if created == 0:
                print(f"  + {name}")
            else:
                rc = 1
            continue
        color_match = current["color"] == color.lower()
        desc_match = current["description"] == desc
        if force and not check and (not color_match or not desc_match):
            edited = _gh_label_edit(repo, name, color, desc)
            if edited == 0:
                print(f"  ~ {name}")
            else:
                rc = 1
        else:
            print(f"  ok {name}")

    if check and missing:
        print(f"  Run `alfred labels bootstrap {repo_arg}` to add {len(missing)} missing label(s).")
        return 1
    if not check and rc == 0:
        print(f"  ok {len(missing)} label(s) bootstrapped")
    return rc


def cmd_labels(args: argparse.Namespace) -> int:
    if args.labels_command == "check":
        args.check = True
    if args.all:
        repos = _fleet_repos_from_env()
        if not repos:
            print(
                "alfred labels: --all found no ALFRED_*_REPOS or LABEL_STATE_SWEEP_REPOS values",
                file=sys.stderr,
            )
            return 2
    else:
        if not args.repo:
            print("alfred labels: repo is required unless --all is passed", file=sys.stderr)
            return 2
        repos = [args.repo]
    rc = 0
    for repo in repos:
        rc = _labels_bootstrap_one(repo, check=args.check, force=args.force) or rc
    return rc


def _lock_dir_for_agent(agent: str) -> Path:
    return Path("/tmp") / f"agent-lock-{agent}"


def _pid_alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True


def _read_lock_metadata(lock_dir: Path) -> dict[str, object]:
    metadata = lock_dir / "metadata.json"
    if not metadata.exists():
        return {}
    try:
        return json.loads(metadata.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}


def _read_lock_pid(lock_dir: Path, metadata: dict[str, object]) -> int | None:
    raw = metadata.get("pid")
    if isinstance(raw, int):
        return raw
    pid_file = lock_dir / "pid"
    try:
        return int(pid_file.read_text(encoding="utf-8").strip())
    except (OSError, ValueError):
        return None


def _git_output(args: list[str], cwd: Path) -> str:
    result = subprocess.run(
        ["git", *args],
        cwd=cwd,
        check=False,
        capture_output=True,
        text=True,
        timeout=15,
    )
    return result.stdout.strip() if result.returncode == 0 else ""


def _matching_worktree_risks(agent: str, *, create_recovery: bool = False) -> list[str]:
    root = agent_runner.WORKTREE_ROOT
    if not root.exists():
        return []
    risks: list[str] = []
    for wt in sorted(root.iterdir()):
        if not wt.is_dir():
            continue
        branch = _git_output(["branch", "--show-current"], wt)
        if agent not in wt.name and agent not in branch:
            continue
        risk = agent_runner.worktree_risk_reason(wt)
        if risk:
            recovery = None
            if create_recovery:
                recovery = agent_runner.create_recovery_ref(wt, branch=branch or None)
            recovery_part = f", recovery={recovery}" if recovery else ""
            risks.append(f"{wt} ({branch or 'unknown branch'}, {risk}{recovery_part})")
    return risks


def _describe_lock(lock_dir: Path, agent: str) -> tuple[int | None, bool, bool | None]:
    metadata = _read_lock_metadata(lock_dir)
    pid = _read_lock_pid(lock_dir, metadata)
    alive = _pid_alive(pid) if pid is not None else False
    identity_status: bool | None = None
    if pid is not None and alive:
        identity_status = agent_runner.lock_pid_identity_status(lock_dir, pid, expected_agent=agent)
    return pid, alive, identity_status


def _clear_lock_scheduler_health(agent: str) -> str:
    label = _resolve_label(agent)
    if label is None:
        return "scheduler: unknown agent label"
    unit_path = scheduler.unit_file(label)
    if unit_path is None:
        return f"scheduler: unsupported on this host ({scheduler.SCHEDULER})"
    if not unit_path.exists():
        return f"scheduler: unit file missing at {unit_path}"
    loaded = scheduler.unit_loaded(label)
    return f"scheduler: {'loaded' if loaded else 'not loaded'} ({scheduler.SCHEDULER})"


def _clear_lock_one(agent: str, *, check: bool, force: bool, quiet: bool) -> int:
    lock_dir = _lock_dir_for_agent(agent)
    print(f"{agent}:")
    print(f"  lock dir: {lock_dir}")
    if not lock_dir.exists():
        print("  state: no lock present")
        return 0
    pid, alive, identity_status = _describe_lock(lock_dir, agent)
    print(f"  pid: {pid if pid is not None else 'unknown'}")
    print(f"  pid alive: {'yes' if alive else 'no'}")
    if identity_status is not None:
        print(f"  identity match: {'yes' if identity_status else 'no'}")
    risks = _matching_worktree_risks(agent, create_recovery=not check)
    for risk in risks:
        print(f"  worktree risk: {risk}")
    if check:
        return 1 if alive or risks else 0
    if pid is None and not force:
        print("  refusing to clear: lock holder pid is unknown; pass --force to override")
        return 1
    if alive and identity_status is not False and not force:
        print("  refusing to clear: lock holder still appears alive; pass --force to override")
        return 1
    if risks and not force:
        print("  refusing to clear: matching worktree has unpushed or dirty work")
        print("  recover the worktree or pass --force after preserving it")
        return 1
    shutil.rmtree(lock_dir, ignore_errors=True)
    print("  cleared")
    health = _clear_lock_scheduler_health(agent)
    print(f"  {health}")
    if not quiet:
        agent_runner.slack_post(f"alfred clear-lock: cleared {agent} lock at {lock_dir}; {health}")
    return 0


def cmd_clear_lock(args: argparse.Namespace) -> int:
    if args.all:
        agents = sorted(
            p.name.removeprefix("agent-lock-")
            for p in Path("/tmp").glob("agent-lock-*")
            if p.is_dir()
        )
        if not agents:
            print("alfred clear-lock: no agent locks found")
            return 0
    else:
        if not args.codename:
            print("alfred clear-lock: codename is required unless --all is passed", file=sys.stderr)
            return 2
        agents = [args.codename]
    rc = 0
    for agent in agents:
        rc = _clear_lock_one(agent, check=args.check, force=args.force, quiet=args.quiet) or rc
    return rc


def _launchctl(args: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(["launchctl", *args], check=False, capture_output=True, text=True)


def _systemctl_user(args: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["systemctl", "--user", *args],
        check=False,
        capture_output=True,
        text=True,
        timeout=15,
    )


def _decode_systemd_env_value(value: str) -> str:
    try:
        if value.startswith("$'") and value.endswith("'"):
            return str(ast.literal_eval("'" + value[2:-1] + "'"))
        if value.startswith(("'", '"')):
            parts = shlex.split(value)
            return parts[0] if parts else ""
    except Exception:
        return value
    return value


def _current_claude_dir() -> str:
    if scheduler.SCHEDULER == "launchd":
        if not shutil.which("launchctl"):
            return os.environ.get("CLAUDE_CONFIG_DIR", "")
        result = _launchctl(["getenv", "CLAUDE_CONFIG_DIR"])
        if result.returncode != 0:
            return ""
        return result.stdout.strip()
    if scheduler.SCHEDULER == "systemd":
        result = _systemctl_user(["show-environment"])
        if result.returncode != 0:
            return os.environ.get("CLAUDE_CONFIG_DIR", "")
        for line in result.stdout.splitlines():
            key, _, value = line.partition("=")
            if key == "CLAUDE_CONFIG_DIR":
                return _decode_systemd_env_value(value)
        return ""
    return os.environ.get("CLAUDE_CONFIG_DIR", "")


def _current_claude_label() -> str:
    value = _current_claude_dir()
    if not value or value == str(PRIMARY_CLAUDE_DIR):
        return "primary (~/.claude)"
    if value == str(SECONDARY_CLAUDE_DIR):
        return "secondary (~/.claude-secondary)"
    return f"custom ({value})"


def _claude_auth_mtime(path: Path) -> str:
    auth_file = path / ".claude.json"
    if not auth_file.exists():
        return "no .claude.json"
    return datetime.fromtimestamp(auth_file.stat().st_mtime).strftime("%Y-%m-%d %H:%M")


def _count_scheduled_agents() -> int | None:
    if not scheduler.supported():
        return None
    labels = scheduler.loaded_labels()
    prefix = os.environ.get("FLEET_LABEL_PREFIX", "")
    if prefix:
        return sum(1 for label in labels if label.startswith(prefix))
    return sum(
        1 for label in labels if any(token in label for token in ("agent", "fleet", "alfred"))
    )


def _claude_status() -> int:
    print(f"Current routing for scheduled agents: {_current_claude_label()}")
    print("")
    print("Auth dir state:")
    for label, directory in (
        ("primary:", PRIMARY_CLAUDE_DIR),
        ("secondary:", SECONDARY_CLAUDE_DIR),
    ):
        if directory.exists():
            print(f"  {label:<12} {directory}   (last touched: {_claude_auth_mtime(directory)})")
        else:
            print(f"  {label:<12} {directory}   (NOT PRESENT)")
    print("")
    agent_count = _count_scheduled_agents()
    if agent_count is None:
        print("Live scheduled agents: unavailable (no supported host scheduler)")
    else:
        print(f"Live {scheduler.SCHEDULER} agents: {agent_count}")
    print("")
    print("Switch with: alfred claude {primary|secondary|swap}")
    print("Verify real API auth with: alfred claude probe")
    return 0


def _set_claude_dir(path: Path, label: str) -> int:
    if scheduler.SCHEDULER not in {"launchd", "systemd"}:
        print(
            "alfred claude: no supported host scheduler; set CLAUDE_CONFIG_DIR "
            f"to {path} in your shell or cron.",
            file=sys.stderr,
        )
        return 2
    if label == "secondary" and not path.exists():
        print(f"ERROR: {path} not present. Set it up first:", file=sys.stderr)
        print(f"  CLAUDE_CONFIG_DIR={path} claude   # then complete login", file=sys.stderr)
        return 2
    if scheduler.SCHEDULER == "launchd":
        if not shutil.which("launchctl"):
            print(
                "alfred claude: launchctl is not available; set CLAUDE_CONFIG_DIR "
                f"to {path} manually.",
                file=sys.stderr,
            )
            return 2
        result = _launchctl(["setenv", "CLAUDE_CONFIG_DIR", str(path)])
    else:
        result = _systemctl_user(["set-environment", f"CLAUDE_CONFIG_DIR={path}"])
    if result.returncode != 0:
        print(
            result.stderr.strip()
            or f"alfred claude: {scheduler.SCHEDULER} environment update failed",
            file=sys.stderr,
        )
        return result.returncode
    print(f"Agents now route to {label.upper()} ({path}). Next firing of each agent picks this up.")
    return 0


def _swap_claude_dir() -> int:
    if _current_claude_dir() == str(SECONDARY_CLAUDE_DIR):
        return _set_claude_dir(PRIMARY_CLAUDE_DIR, "primary")
    return _set_claude_dir(SECONDARY_CLAUDE_DIR, "secondary")


def _probe_claude_auth() -> int:
    print(f"Probing Claude Code API auth for {_current_claude_label()}")
    print("This sends one tiny non-interactive Claude request when auth is healthy.")
    env = os.environ.copy()
    current = _current_claude_dir()
    if current:
        env["CLAUDE_CONFIG_DIR"] = current
    cmd = [
        "claude",
        "-p",
        "Reply exactly ALFRED_CLAUDE_OK",
        "--output-format",
        "json",
        "--max-turns",
        "1",
        "--model",
        "claude-haiku-4-5",
    ]
    try:
        result = subprocess.run(
            cmd, check=False, capture_output=True, text=True, timeout=90, env=env
        )
    except FileNotFoundError:
        print("Claude probe: failed")
        print("claude binary not found on PATH", file=sys.stderr)
        return 1
    except subprocess.TimeoutExpired:
        print("Claude probe: failed")
        print("claude probe timed out after 90s", file=sys.stderr)
        return 1

    payload = result.stdout.strip() or result.stderr.strip()
    try:
        data = json.loads(payload)
        body = str(data.get("result") or "")
        summary = (
            f"exit_json subtype={data.get('subtype')} is_error={data.get('is_error')} "
            f"api_error_status={data.get('api_error_status')} result={body[:300]}"
        )
    except json.JSONDecodeError:
        body = payload
        summary = payload[-500:]
    if result.returncode == 0 and "ALFRED_CLAUDE_OK" in body:
        print("Claude probe: ok")
        return 0
    print("Claude probe: failed")
    print(summary)
    return 1


def cmd_claude(args: argparse.Namespace) -> int:
    command = args.claude_command
    if command in ("status", ""):
        return _claude_status()
    if command in ("primary", "main"):
        return _set_claude_dir(PRIMARY_CLAUDE_DIR, "primary")
    if command in ("secondary", "2"):
        return _set_claude_dir(SECONDARY_CLAUDE_DIR, "secondary")
    if command in ("swap", "toggle"):
        return _swap_claude_dir()
    if command == "probe":
        return _probe_claude_auth()
    print("Usage: alfred claude {status|primary|secondary|swap|probe}", file=sys.stderr)
    return 2


def cmd_setup_token(args: argparse.Namespace) -> int:
    """Forward to ``bin/alfred-setup-token.py``.

    Keeps the heavy logic out of the dispatcher so the standalone script
    is callable directly (``python3 ~/.alfred/bin/alfred-setup-token.py``)
    for operators who prefer to bypass the ``alfred`` CLI.
    """
    script = _HERE / "alfred-setup-token.py"
    cmd = [sys.executable, str(script)]
    if args.force:
        cmd.append("--force")
    if args.check_only:
        cmd.append("--check-only")
    return subprocess.run(cmd, check=False).returncode


def cmd_batman_setup(args: argparse.Namespace) -> int:
    """Forward to ``bin/alfred-batman-setup.py``."""
    script = _HERE / "alfred-batman-setup.py"
    cmd = [sys.executable, str(script)]
    for attr, flag in (
        ("check_only", "--check-only"),
        ("force", "--force"),
        ("non_interactive", "--non-interactive"),
        ("skip_token_setup", "--skip-token-setup"),
        ("skip_doctor", "--skip-doctor"),
        ("run_slack_tests", "--run-slack-tests"),
    ):
        if getattr(args, attr, False):
            cmd.append(flag)
    for attr, flag in (
        ("slack_bot_token", "--slack-bot-token"),
        ("operator_user_id", "--operator-user-id"),
        ("slack_channel", "--slack-channel"),
        ("parent_repo", "--parent-repo"),
        ("mode", "--mode"),
        ("picker", "--picker"),
        ("bundle_slug_prefix", "--bundle-slug-prefix"),
    ):
        value = getattr(args, attr, None)
        if value:
            cmd.extend([flag, str(value)])
    if getattr(args, "approval_timeout_s", None) is not None:
        cmd.extend(["--approval-timeout-s", str(args.approval_timeout_s)])
    return subprocess.run(cmd, check=False).returncode


def cmd_auth(args: argparse.Namespace) -> int:
    command = args.auth_command
    if command in ("status", ""):
        claude_rc = _claude_status()
        print("")
        codex_rc = _codex_status()
        return 0 if claude_rc == 0 and codex_rc == 0 else 1
    if command == "probe":
        claude_rc = _probe_claude_auth()
        print("")
        codex_rc = _probe_codex()
        return 0 if claude_rc == 0 and codex_rc == 0 else 1
    print("Usage: alfred auth {status|probe}", file=sys.stderr)
    return 2


def main(argv: list[str] | None = None) -> int:
    p = argparse.ArgumentParser(prog="alfred", description="Alfred operator CLI")
    sub = p.add_subparsers(dest="command", required=True)

    p_agents = sub.add_parser("agents", help="list configured agents")
    p_agents.set_defaults(func=cmd_agents)

    p_enable = sub.add_parser("enable", help="list an agent in the runner gate file")
    p_enable.add_argument("codename")
    p_enable.set_defaults(func=cmd_enable)

    p_disable = sub.add_parser("disable", help="remove an agent from the runner gate file")
    p_disable.add_argument("codename")
    p_disable.set_defaults(func=cmd_disable)

    p_enabled = sub.add_parser("enabled-agents", help="print the list of enabled codenames")
    p_enabled.set_defaults(func=cmd_enabled_agents)

    p_pause = sub.add_parser("pause", help="stop scheduled firings for an agent")
    p_pause.add_argument("codename", help="agent codename, or 'all'")
    p_pause.set_defaults(func=cmd_pause)

    p_resume = sub.add_parser("resume", help="reverse a pause")
    p_resume.add_argument("codename", help="agent codename, or 'all'")
    p_resume.set_defaults(func=cmd_resume)

    p_run = sub.add_parser("run", help="kick a single agent now (one-shot)")
    p_run.add_argument("codename", help="agent codename")
    p_run.add_argument("--force", action="store_true", help="run even if the agent is paused")
    p_run.set_defaults(func=cmd_run)

    p_dry_run = sub.add_parser(
        "dry-run",
        help="simulate one agent firing without scheduler or external side effects",
    )
    p_dry_run.add_argument("codename", help="agent codename, full label, or 'all'")
    p_dry_run.add_argument(
        "--native",
        action="store_true",
        help="prefer native lifecycle dry-run when the runner declares support",
    )
    p_dry_run.add_argument(
        "--simulate",
        action="store_true",
        help="force no-side-effect simulation even when native dry-run exists",
    )
    p_dry_run.add_argument("--json", action="store_true")
    p_dry_run.set_defaults(func=cmd_dry_run)

    p_clear_lock = sub.add_parser("clear-lock", help="diagnose and clear stale agent locks")
    p_clear_lock.add_argument("codename", nargs="?", help="agent codename")
    p_clear_lock.add_argument("--all", action="store_true", help="sweep every /tmp/agent-lock-*")
    p_clear_lock.add_argument("--check", action="store_true", help="report state without clearing")
    p_clear_lock.add_argument(
        "--force", action="store_true", help="clear even if safety checks fail"
    )
    p_clear_lock.add_argument(
        "--quiet", action="store_true", help="do not post the clear event to Slack"
    )
    p_clear_lock.set_defaults(func=cmd_clear_lock)

    p_status = sub.add_parser("status", help="show local fleet health")
    p_status.add_argument("--json", action="store_true")
    p_status.add_argument("--slack", action="store_true")
    p_status.set_defaults(func=cmd_status)

    p_labels = sub.add_parser("labels", help="bootstrap GitHub labels on fleet repos")
    labels_sub = p_labels.add_subparsers(dest="labels_command", required=True)
    p_labels_bootstrap = labels_sub.add_parser(
        "bootstrap",
        help="add canonical Alfred labels to one repo or every configured repo",
    )
    p_labels_bootstrap.add_argument("repo", nargs="?", help="repo slug or owner/repo")
    p_labels_bootstrap.add_argument("--all", action="store_true", help="use configured repo lists")
    p_labels_bootstrap.add_argument(
        "--check",
        action="store_true",
        help="report missing labels without creating them",
    )
    p_labels_bootstrap.add_argument(
        "--force",
        action="store_true",
        help="update color/description on labels that already exist",
    )
    p_labels_bootstrap.set_defaults(func=cmd_labels)
    p_labels_check = labels_sub.add_parser(
        "check",
        help="report missing canonical Alfred labels without creating them",
    )
    p_labels_check.add_argument("repo", nargs="?", help="repo slug or owner/repo")
    p_labels_check.add_argument("--all", action="store_true", help="use configured repo lists")
    p_labels_check.add_argument("--force", action="store_true", help=argparse.SUPPRESS)
    p_labels_check.set_defaults(func=cmd_labels, check=True)

    p_engine = sub.add_parser("engine", aliases=["provider"], help="manage per-agent engines")
    engine_sub = p_engine.add_subparsers(dest="engine_command", required=True)
    p_engine_status = engine_sub.add_parser("status", help="show resolved engine state")
    p_engine_status.add_argument("agent", nargs="?")
    p_engine_status.set_defaults(func=cmd_engine_status)
    p_engine_set = engine_sub.add_parser("set", help="set one agent's engine")
    p_engine_set.add_argument("agent")
    p_engine_set.add_argument("mode", choices=["claude", "codex", "hybrid", "both"])
    p_engine_set.set_defaults(func=cmd_engine_set)

    p_claude = sub.add_parser("claude", help="manage Claude Code account routing")
    p_claude.add_argument(
        "claude_command",
        nargs="?",
        default="status",
        metavar="{status,primary,secondary,swap,probe}",
    )
    p_claude.set_defaults(func=cmd_claude)

    p_codex = sub.add_parser("codex", help="inspect Codex CLI availability/auth")
    p_codex.add_argument(
        "codex_command",
        nargs="?",
        default="status",
        metavar="{status,probe}",
    )
    p_codex.set_defaults(func=cmd_codex)

    p_setup_token = sub.add_parser(
        "setup-token",
        help="mint a long-lived Claude OAuth token for scheduled firings",
    )
    p_setup_token.add_argument(
        "--force",
        action="store_true",
        help="re-run even if a token is already configured (rotate)",
    )
    p_setup_token.add_argument(
        "--check-only",
        action="store_true",
        help="report status without spawning `claude setup-token`",
    )
    p_setup_token.set_defaults(func=cmd_setup_token)

    def add_batman_setup_args(parser: argparse.ArgumentParser) -> None:
        parser.add_argument(
            "--check-only", action="store_true", help="report setup state without writing"
        )
        parser.add_argument(
            "--force", action="store_true", help="prompt for values even when configured"
        )
        parser.add_argument(
            "--non-interactive", action="store_true", help="accept defaults and provided flags"
        )
        parser.add_argument(
            "--skip-token-setup", action="store_true", help="do not spawn alfred setup-token"
        )
        parser.add_argument(
            "--skip-doctor", action="store_true", help="do not run lifecycle doctor"
        )
        parser.add_argument(
            "--run-slack-tests", action="store_true", help="call Slack auth.test and users.info"
        )
        parser.add_argument("--slack-bot-token", default="", help="Slack bot token to persist")
        parser.add_argument(
            "--operator-user-id", default="", help="Slack member id whose reactions count"
        )
        parser.add_argument(
            "--slack-channel", default="", help="Slack channel name or id for Batman posts"
        )
        parser.add_argument(
            "--parent-repo", default="", help="owner/repo that holds Batman parent issues"
        )
        parser.add_argument(
            "--mode", choices=["0", "approval-gate", "1"], default="", help="Batman execution mode"
        )
        parser.add_argument(
            "--picker", choices=["oldest", "newest"], default="", help="parent issue picker"
        )
        parser.add_argument("--bundle-slug-prefix", default="", help="optional bundle slug prefix")
        parser.add_argument("--approval-timeout-s", type=int, help="approval wait timeout seconds")

    p_setup_batman = sub.add_parser(
        "setup-batman",
        help="configure Batman parent-repo and approval-gate settings",
    )
    add_batman_setup_args(p_setup_batman)
    p_setup_batman.set_defaults(func=cmd_batman_setup)

    p_batman = sub.add_parser("batman", help="manage Batman cross-repo coordination")
    batman_sub = p_batman.add_subparsers(dest="batman_command", required=True)
    p_batman_setup = batman_sub.add_parser(
        "setup",
        help="configure Batman parent-repo and approval-gate settings",
    )
    add_batman_setup_args(p_batman_setup)
    p_batman_setup.set_defaults(func=cmd_batman_setup)

    p_auth = sub.add_parser("auth", help="inspect Claude Code and Codex auth surfaces")
    p_auth.add_argument(
        "auth_command",
        nargs="?",
        default="status",
        metavar="{status,probe}",
    )
    p_auth.set_defaults(func=cmd_auth)

    p_metrics = sub.add_parser("metrics", help="weekly fleet rollup of firings/cost/turns")
    p_metrics.add_argument("--since", default=None, help="window size (e.g. 7d, 48h, 2w)")
    p_metrics.add_argument("--days", type=int, help="window size in days (overrides --since)")
    p_metrics.add_argument(
        "--codename", action="append", help="restrict to one codename (repeatable)"
    )
    p_metrics.add_argument("--by-agent", action="store_true", help="default per-agent view")
    p_metrics.add_argument("--by-day", action="store_true", help="per-day breakdown")
    p_metrics.add_argument("--json", action="store_true")
    p_metrics.set_defaults(func=cmd_metrics)

    p_logs = sub.add_parser("logs", help="inspect stream-JSON transcripts for one agent")
    p_logs.add_argument("codename", help="agent codename (directory under state/transcripts/)")
    p_logs.add_argument("--firing-id", dest="firing_id", help="dump this firing id only")
    p_logs.add_argument(
        "--last", type=int, default=None, help="how many recent firings (default 10)"
    )
    p_logs.add_argument("--show-tool-calls", action="store_true", help="aggregate tool/skill calls")
    p_logs.add_argument("--json", action="store_true")
    p_logs.set_defaults(func=cmd_logs)

    p_brain = sub.add_parser("brain", help="inspect and seed local fleet-brain memory")
    p_brain.add_argument("brain_args", nargs=argparse.REMAINDER)
    p_brain.set_defaults(func=cmd_brain)

    p_github_poll = sub.add_parser("github-poll", help="poll GitHub issues/PRs into fleet-brain")
    p_github_poll.add_argument("--repo", action="append")
    p_github_poll.add_argument("--state", choices=["open", "closed", "all"], default="all")
    p_github_poll.add_argument("--limit", type=int, default=100)
    p_github_poll.add_argument("--db")
    p_github_poll.add_argument("--dry-run", action="store_true")
    p_github_poll.add_argument("--json", action="store_true")
    p_github_poll.set_defaults(func=cmd_github_poll)

    p_mcp = sub.add_parser("mcp", help="serve read-only Alfred MCP tools")
    p_mcp.add_argument("mcp_args", nargs=argparse.REMAINDER)
    p_mcp.set_defaults(func=cmd_mcp)

    p_serve = sub.add_parser("serve", help="open the read-only localhost dashboard")
    p_serve.add_argument("--host", help="bind address passed to alfred-serve")
    p_serve.add_argument("--port", type=int, help="bind port passed to alfred-serve")
    p_serve.add_argument(
        "--no-browser", action="store_true", help="do not auto-open a browser tab"
    )
    p_serve.add_argument(
        "--log-level",
        choices=["debug", "info", "warning", "error"],
        help="uvicorn log level passed to alfred-serve",
    )
    p_serve.set_defaults(func=cmd_serve)

    p_schedule = sub.add_parser("schedule", help="inspect or edit configured agent cadences")
    p_schedule.add_argument("schedule_args", nargs=argparse.REMAINDER)
    p_schedule.set_defaults(func=cmd_schedule)

    p_assign = sub.add_parser("assign", help="route an existing issue to the right agent lane")
    p_assign.add_argument("issue", help="issue URL or owner/repo#N")
    p_assign.add_argument("--dry-run", action="store_true")
    p_assign.add_argument("--json", action="store_true")
    p_assign.set_defaults(func=cmd_assign)

    p_spec = sub.add_parser("spec", help="create and lint specs for agent work")
    p_spec.add_argument("spec_args", nargs=argparse.REMAINDER)
    p_spec.set_defaults(func=cmd_spec)

    p_slack_listener = sub.add_parser(
        "slack-listener",
        aliases=["slack"],
        help="run or test the Slack planning listener",
    )
    p_slack_listener.add_argument("listener_args", nargs=argparse.REMAINDER)
    p_slack_listener.set_defaults(func=cmd_slack_listener)

    p_slack_thread_sync = sub.add_parser(
        "slack-thread-sync",
        help="post fleet progress (claimed/PR/CI/merged) to issue-filing Slack threads",
    )
    p_slack_thread_sync.add_argument("--json", action="store_true", help="emit a JSON summary")
    p_slack_thread_sync.add_argument(
        "--dry-run", action="store_true", help="compute deltas without posting to Slack"
    )
    p_slack_thread_sync.add_argument(
        "--state-root", help="override the thread-status state directory"
    )
    p_slack_thread_sync.set_defaults(func=cmd_slack_thread_sync)

    p_shipped = sub.add_parser("shipped", help="summarize shipped GitHub activity")
    p_shipped.add_argument("--period", choices=["daily", "weekly"], default="daily")
    p_shipped.add_argument("--days", type=int)
    p_shipped.add_argument("--since")
    p_shipped.add_argument("--until")
    p_shipped.add_argument("--repo", action="append")
    p_shipped.add_argument("--json", action="store_true")
    p_shipped.add_argument("--slack", action="store_true")
    p_shipped.add_argument("--no-file-scan", action="store_true")
    p_shipped.set_defaults(func=cmd_shipped)

    args = p.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
